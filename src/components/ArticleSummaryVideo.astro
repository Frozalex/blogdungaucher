---
interface Props {
  src: string;
  poster?: string;
  aspect?: "16:9" | "9:16";
  videoTitle: string;
  /** Titre visible au-dessus du lecteur. */
  heading: string;
}

const { src, poster, aspect = "16:9", videoTitle, heading } = Astro.props;
const portrait = aspect === "9:16";
---

<div class="article-summary-video-wrap fade-up" style="--motion-delay: 90ms;">
  <p class="summary-video-eyebrow">{heading}</p>
  <figure
    class:list={["article-inline-video", portrait ? "is-portrait" : "is-landscape"]}
  >
    <video
      controls
      preload="metadata"
      playsinline
      poster={poster}
      aria-label={videoTitle}
    >
      <source src={src} type="video/mp4" />
    </video>
  </figure>
</div>

<style>
  .article-summary-video-wrap {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-soft);
  }

  .summary-video-eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .article-inline-video {
    margin: 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border-soft);
    background: var(--surface);
    box-shadow: var(--shadow-xs);
  }

  .article-inline-video video {
    display: block;
    width: 100%;
    vertical-align: middle;
  }

  .article-inline-video.is-landscape video {
    aspect-ratio: 16 / 9;
    object-fit: cover;
    background: color-mix(in srgb, var(--surface-warm) 65%, transparent);
  }

  .article-inline-video.is-portrait {
    max-width: min(420px, 100%);
    margin-left: auto;
    margin-right: auto;
  }

  .article-inline-video.is-portrait video {
    aspect-ratio: 9 / 16;
    object-fit: cover;
    background: color-mix(in srgb, var(--surface-warm) 65%, transparent);
  }
</style>
