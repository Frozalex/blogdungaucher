---
import BaseLayout from "../layouts/BaseLayout.astro";
import AdBanner from "./AdBanner.astro";
import ArticleCard from "./ArticleCard.astro";

import { categoryLandingRich } from "../data/category-landing-rich";
import { categoryMap, type CategorySlug } from "../data/site";
import {
  buildBreadcrumbJsonLd,
  filterPostsForLang,
  getPostsByCategory,
} from "../utils/blog";
import { swapLangPrefix, withTrailingSlash, type SiteLang } from "../utils/lang-paths";

const { category, lang = "fr" } = Astro.props as { category: CategorySlug; lang?: SiteLang };
const meta = categoryMap[category];
const landingRich = categoryLandingRich[category]?.[lang];
const posts = filterPostsForLang(
  await getPostsByCategory(category),
  lang,
);
const hero = posts.find((p) => p.data.featured) ?? posts[0];
const rest = posts.filter((p) => p.id !== hero?.id);

const frCanonical = withTrailingSlash(meta.href);

const homeLabel =
  lang === "en" ? "Home" : lang === "de" ? "Startseite" : "Accueil";

const structuredData = buildBreadcrumbJsonLd([
  { name: homeLabel, path: swapLangPrefix("/", lang) },
  { name: meta.label, path: swapLangPrefix(frCanonical, lang) },
]);

const pageTitle =
  lang === "en"
    ? (meta.seoTitleEn ?? `${meta.label} | A Left-Hander's Blog`)
    : (meta.seoTitle ?? `${meta.label} | Blog d'un Gaucher`);
const pageDesc =
  lang === "en"
    ? (meta.seoDescriptionEn ?? `${meta.description} ${meta.audiencePromise}`)
    : (meta.seoDescription ?? `${meta.description} ${meta.audiencePromise}`);
const canonPath = swapLangPrefix(frCanonical, lang);
const catDescription =
  lang === "en"
    ? (meta.descriptionEn ?? meta.description)
    : meta.description;

const blogHref = swapLangPrefix("/fr/blog/", lang);

const richEyebrow =
  lang === "en"
    ? "What we explore here"
    : lang === "de"
      ? "Was wir hier vertiefen"
      : "Ce qu'on creuse ici";

const cardsIntro =
  lang === "en"
    ? "Short focal points to revisit after reading:"
    : lang === "de"
      ? "Kurze Schwerpunkte zum Mitnehmen:"
      : "Trois angles pour résumer l’essentiel :";
---
<BaseLayout
  title={pageTitle}
  description={pageDesc}
  canonicalPath={canonPath}
  lang={lang}
  structuredData={structuredData}
>
  <section
    class:list={["cat-hero", landingRich && "cat-hero--accent"]}
    style={landingRich ? `--cat-accent: ${meta.accent};` : undefined}
  >
    <div class="container">
      <span class="eyebrow reveal" data-t={`categories.${category}.shortLabel`}>{meta.shortLabel}</span>
      <h1 class="reveal" data-t={`categories.${category}.label`}>{meta.label}</h1>
      <p class="cat-tagline reveal" data-t={`categories.${category}.tagline`}>{meta.tagline}</p>
      {!landingRich && <p class="cat-desc reveal">{catDescription}</p>}
    </div>
  </section>

  {landingRich && (
    <section class="cat-rich">
      <div class="container">
        <span class="eyebrow reveal">{richEyebrow}</span>
        <div class="cat-rich__essay reveal-group">
          {landingRich.sections.map((sec) => (
            <div class="cat-rich__block reveal">
              <h3 class="cat-rich__h3">{sec.title}</h3>
              {sec.paragraphs.map((p) => (
                <p class="cat-rich__p">{p}</p>
              ))}
            </div>
          ))}
        </div>
        <p class="cat-rich__cards-intro reveal">{cardsIntro}</p>
        <ul class="cat-rich__cards">
          {landingRich.cards.map((card) => (
            <li class="cat-rich__card reveal">
              <strong>{card.title}</strong>
              <p>{card.body}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <div class="container">
    <AdBanner format="leaderboard" />
  </div>

  {hero && (
    <section class="cat-section">
      <div class="container">
        <span class="eyebrow reveal" data-t="category.featured">À la une</span>
        <div class="cat-hero-card reveal">
          <ArticleCard post={hero} featured={true} lang={lang} />
        </div>
      </div>
    </section>
  )}

  {rest.length > 0 ? (
    <section class="cat-section">
      <div class="container">
        <div class="cat-section__head reveal">
          <span class="eyebrow" data-t="category.allArticles">Tous les articles</span>
          <a href={blogHref} class="text-link" data-t="category.seeAll">Voir tout le blog</a>
        </div>
        <div class="post-grid reveal-group">
          {rest.map((post) => <ArticleCard post={post} lang={lang} />)}
        </div>
      </div>
    </section>
  ) : !hero && (
    <section class="cat-section">
      <div class="container">
        <div class="empty-state reveal">
          <div class="empty-icon" style={`color:${meta.accent}`}>
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 2C8 2 6 5 6 8c0 2 1 3 1 5H8l-1 4h10l-1-4h1c0-2 1-3 1-5 0-3-2-6-6-6z"/>
              <path d="M9 21h6"/>
            </svg>
          </div>
          <h2 data-t="category.comingSoon">Les premiers articles arrivent bientôt.</h2>
          <p data-t="category.comingSoonDesc">Cette rubrique sera publiée prochainement. En attendant, retrouve tous les articles disponibles.</p>
          <a href={blogHref} class="button-primary" data-t="category.seeAllCta">Voir tous les articles</a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .cat-hero {
    padding: 4.5rem 0 2rem;
  }

  .cat-hero--accent {
    position: relative;
    padding-bottom: 2.5rem;
    background: radial-gradient(
        ellipse 90% 70% at 88% -15%,
        color-mix(in srgb, var(--cat-accent) 16%, transparent),
        transparent 55%
      ),
      radial-gradient(ellipse 70% 50% at 5% 100%, color-mix(in srgb, var(--cat-accent) 8%, transparent), transparent 50%),
      var(--bg);
  }

  [data-theme="dark"] .cat-hero--accent {
    background: radial-gradient(
        ellipse 90% 70% at 88% -15%,
        color-mix(in srgb, var(--cat-accent) 12%, transparent),
        transparent 55%
      ),
      radial-gradient(ellipse 70% 50% at 5% 100%, color-mix(in srgb, var(--cat-accent) 6%, transparent), transparent 50%),
      var(--bg);
  }

  .cat-rich {
    padding: 0 0 2.5rem;
  }

  .cat-rich .eyebrow {
    margin-bottom: 1.1rem;
  }

  .cat-rich__essay {
    display: grid;
    gap: clamp(1.75rem, 4vw, 2.75rem);
    max-width: 52rem;
    margin-top: 0.75rem;
  }

  .cat-rich__block {
    display: grid;
    gap: 0.85rem;
  }

  .cat-rich__h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 0.9vw + 0.95rem, 1.25rem);
    font-weight: 650;
    letter-spacing: -0.02em;
    color: var(--text-main);
  }

  .cat-rich__p {
    margin: 0;
    font-size: clamp(0.98rem, 0.65vw + 0.91rem, 1.08rem);
    line-height: 1.72;
    color: var(--text-muted);
  }

  .cat-rich__cards-intro {
    margin: clamp(1.75rem, 4vw, 2.5rem) 0 0.85rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-muted);
  }

  .cat-rich__cards {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .cat-rich__card {
    margin: 0;
    padding: 1rem 1.1rem 1.05rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-soft);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
  }

  .cat-rich__card strong {
    display: block;
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-main);
    margin-bottom: 0.35rem;
  }

  .cat-rich__card p {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-muted);
  }

  .cat-hero h1 {
    font-family: var(--font-serif);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(2.6rem, 6.2vw, 4.2rem);
    letter-spacing: -0.015em;
    line-height: 1.05;
    margin: 0.5rem 0 0.9rem;
    font-optical-sizing: auto;
  }
  .cat-tagline {
    font-size: 1.1rem;
    color: var(--text-main);
    margin-bottom: 0.5rem;
  }
  .cat-desc {
    color: var(--text-muted);
    max-width: 38rem;
  }

  .cat-section { padding: 1.5rem 0 3.5rem; }

  .cat-hero-card { margin-top: 1rem; max-width: 44rem; }

  .cat-section__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .text-link {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-muted);
    transition: color 150ms ease;
  }
  .text-link:hover { color: var(--green); }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.85rem;
  }

  .empty-state {
    display: grid;
    place-items: center;
    text-align: center;
    gap: 0.75rem;
    padding: 4rem 1rem;
    max-width: 30rem;
    margin: 0 auto;
  }
  .empty-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4.5rem;
    height: 4.5rem;
    border-radius: 50%;
    background: var(--bg-warm);
    border: 1.5px solid var(--border-soft);
    margin-bottom: 0.25rem;
  }
  .empty-state h2 { font-size: 1.3rem; }
  .empty-state p { color: var(--text-muted); font-size: 0.92rem; }

  @media (max-width: 680px) {
    .cat-section__head { flex-direction: column; align-items: flex-start; }
  }
</style>
