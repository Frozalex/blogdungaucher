---
import BaseLayout from "../layouts/BaseLayout.astro";
import AdBanner from "./AdBanner.astro";
import ArticleCard from "./ArticleCard.astro";

import { categoryLandingRich } from "../data/category-landing-rich";
import { categoryMap, type CategorySlug } from "../data/site";
import {
  buildBreadcrumbJsonLd,
  filterPostsForLang,
  getPostsByCategory,
} from "../utils/blog";
import { swapLangPrefix, withTrailingSlash, type SiteLang } from "../utils/lang-paths";

const { category, lang = "fr" } = Astro.props as { category : CategorySlug; lang?: SiteLang };
const meta = categoryMap[category];
const landingRich = categoryLandingRich[category]?.[lang];
const posts = filterPostsForLang(
  await getPostsByCategory(category),
  lang,
);
const hero = posts.find((p) => p.data.featured) ?? posts[0];
const rest = posts.filter((p) => p.id !== hero?.id);

const frCanonical = withTrailingSlash(meta.href);

const homeLabel =
  lang === "en" ? "Home" : lang === "de" ? "Startseite" : "Accueil";

const structuredData = buildBreadcrumbJsonLd([
  { name : homeLabel, path : swapLangPrefix("/", lang) },
  { name : meta.label, path : swapLangPrefix(frCanonical, lang) },
]);

const pageTitle =
  lang === "en"
    ? (meta.seoTitleEn ?? `${meta.label} | A Left-Hander's Blog`)
    : (meta.seoTitle ?? `${meta.label} | Blog d'un Gaucher`);
const pageDesc =
  lang === "en"
    ? (meta.seoDescriptionEn ?? `${meta.description} ${meta.audiencePromise}`)
    : (meta.seoDescription ?? `${meta.description} ${meta.audiencePromise}`);
const canonPath = swapLangPrefix(frCanonical, lang);
const catDescription =
  lang === "en"
    ? (meta.descriptionEn ?? meta.description)
    : meta.description;

const blogHref = swapLangPrefix("/fr/blog/", lang);

const richEyebrow =
  lang === "en"
    ? "What we explore here"
    : lang === "de"
      ? "Was wir hier vertiefen"
      : "Ce qu'on creuse ici";

const cardsIntro =
  lang === "en"
    ? "Short focal points to revisit after reading:"
    : lang === "de"
      ? "Kurze Schwerpunkte zum Mitnehmen:"
      : "Trois angles pour résumer l’essentiel :";

/** Stats agrégées pour la strip sous le H1 (signature visuelle de la rubrique). */
const totalMinutes = posts.reduce((acc, p) => {
  const m = String(p.data.readingTime ?? "").match(/(\d+)/);
  return acc + (m ? Number(m[1]) : 0);
}, 0);

const latestDate = posts
  .map((p) => p.data.publishDate)
  .filter((d): d is Date => d instanceof Date)
  .sort((a, b) => b.getTime() - a.getTime())[0];

const dateLocale = lang === "en" ? "en-US" : lang === "de" ? "de-DE" : "fr-FR";
const latestDateLabel = latestDate
  ? latestDate.toLocaleDateString(dateLocale, { month : "short", year : "numeric" })
  : null;

const statsLabels = {
  fr: { articles: "articles", minutes: "min de lecture", latest: "dernier publié" },
  en: { articles: "articles", minutes: "min of reading", latest: "latest post" },
  de: { articles: "Artikel", minutes: "Lesezeit (min)", latest: "letzter Beitrag" },
}[lang === "fr" || lang === "en" || lang === "de" ? lang : "fr"];

/** Glyphes pièces par rubrique : signature visuelle reproduite de la home. */
const categoryGlyph : Record<CategorySlug, string> = {
  science: "♞",
  esprit: "♛",
  societe: "♜",
  "grand-oral" : "♚",
};
---
<BaseLayout
  title={pageTitle}
  description={pageDesc}
  canonicalPath={canonPath}
  lang={lang}
  structuredData={structuredData}
>
  <section
    class:list={["cat-hero", landingRich && "cat-hero--accent"]}
    style={`--cat-accent: ${meta.accent};`}
  >
    <span class="cat-hero__glyph" aria-hidden="true">{categoryGlyph[category]}</span>
    <div class="container">
      <span class="eyebrow reveal" data-t={`categories.${category}.shortLabel`}>{meta.shortLabel}</span>
      <h1 class="cat-hero__title reveal" data-t={`categories.${category}.label`}>{meta.label}</h1>
      <p class="cat-tagline reveal" data-t={`categories.${category}.tagline`}>{meta.tagline}</p>
      {!landingRich && <p class="cat-desc reveal">{catDescription}</p>}

      {posts.length > 0 && (
        <dl class="cat-stats reveal" aria-label="Statistiques de la rubrique">
          <div class="cat-stats__item">
            <dt>{statsLabels.articles}</dt>
            <dd>{posts.length}</dd>
          </div>
          {totalMinutes > 0 && (
            <div class="cat-stats__item">
              <dt>{statsLabels.minutes}</dt>
              <dd>{totalMinutes}</dd>
            </div>
          )}
          {latestDateLabel && (
            <div class="cat-stats__item">
              <dt>{statsLabels.latest}</dt>
              <dd class="cat-stats__date">{latestDateLabel}</dd>
            </div>
          )}
        </dl>
      )}
    </div>
  </section>

  {landingRich && (
    <section class="cat-rich" style={`--cat-accent: ${meta.accent};`}>
      <div class="container">
        <span class="eyebrow reveal">{richEyebrow}</span>

        {landingRich.slides && landingRich.slides.length > 0 ? (
          <div class="cat-slides reveal-group">
            {landingRich.slides.map((slide, idx) => (
              <article class={`cat-slide cat-slide--${idx % 2 === 0 ? "left" : "right"} reveal`}>
                <header class="cat-slide__head">
                  <span class="cat-slide__num">{String(idx + 1).padStart(2, "0")}</span>
                  {slide.kicker && <span class="cat-slide__kicker">{slide.kicker}</span>}
                </header>
                <h3 class="cat-slide__title">{slide.title}</h3>
                {slide.lead && <p class="cat-slide__lead">{slide.lead}</p>}
                <ul class="cat-slide__points">
                  {slide.points.map((pt) => (
                    <li>
                      <span class="cat-slide__bullet" aria-hidden="true">→</span>
                      <span>{pt}</span>
                    </li>
                  ))}
                </ul>
                {slide.pullquote && (
                  <p class="cat-slide__quote">
                    <span class="cat-slide__quote-mark" aria-hidden="true">“</span>
                    {slide.pullquote}
                  </p>
                )}
              </article>
            ))}
          </div>
        ) : (
          <div class="cat-rich__essay reveal-group">
            {landingRich.sections.map((sec) => (
              <div class="cat-rich__block reveal">
                <h3 class="cat-rich__h3">{sec.title}</h3>
                {sec.paragraphs.map((p) => (
                  <p class="cat-rich__p">{p}</p>
                ))}
              </div>
            ))}
          </div>
        )}

        <p class="cat-rich__cards-intro reveal">{cardsIntro}</p>
        <ul class="cat-rich__cards">
          {landingRich.cards.map((card) => (
            <li class="cat-rich__card reveal">
              <strong>{card.title}</strong>
              <p>{card.body}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <div class="container">
    <AdBanner format="leaderboard" />
  </div>

  {hero && (
    <section class="cat-section">
      <div class="container">
        <span class="eyebrow reveal" data-t="category.featured">À la une</span>
        <div class="cat-hero-card reveal">
          <ArticleCard post={hero} featured={true} lang={lang} />
        </div>
      </div>
    </section>
  )}

  {rest.length > 0 ? (
    <section class="cat-section">
      <div class="container">
        <div class="cat-section__head reveal">
          <span class="eyebrow" data-t="category.allArticles">Tous les articles</span>
          <a href={blogHref} class="text-link" data-t="category.seeAll">Voir tout le blog</a>
        </div>
        <div class="post-grid reveal-group">
          {rest.map((post) => <ArticleCard post={post} lang={lang} />)}
        </div>
      </div>
    </section>
  ) : !hero && (
    <section class="cat-section">
      <div class="container">
        <div class="empty-state reveal">
          <div class="empty-icon" style={`color:${meta.accent}`}>
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 2C8 2 6 5 6 8c0 2 1 3 1 5H8l-1 4h10l-1-4h1c0-2 1-3 1-5 0-3-2-6-6-6z"/>
              <path d="M9 21h6"/>
            </svg>
          </div>
          <h2 data-t="category.comingSoon">Les premiers articles arrivent bientôt.</h2>
          <p data-t="category.comingSoonDesc">Cette rubrique sera publiée prochainement. En attendant, retrouve tous les articles disponibles.</p>
          <a href={blogHref} class="button-primary" data-t="category.seeAllCta">Voir tous les articles</a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .cat-hero {
    position: relative;
    padding: 4.5rem 0 2rem;
    overflow: hidden;
  }

  /* Glyphe pièce d'échecs surdimensionné en filigrane : signature visuelle.
     Plage clamp resserrée pour éviter le débordement sur écran <500px. */
  .cat-hero__glyph {
    position: absolute;
    top: 50%;
    right: clamp(-2rem, -2vw, 1rem);
    font-family: var(--font-serif);
    font-size: clamp(7rem, 22vw, 22rem);
    line-height: 0.85;
    color: color-mix(in srgb, var(--cat-accent) 11%, transparent);
    pointer-events: none;
    user-select: none;
    transform: translateY(-50%) rotate(-8deg);
    z-index: 0;
  }

  /* Sur très petit écran, on l'efface presque totalement pour ne pas voler de l'air au contenu. */
  @media (max-width: 540px) {
    .cat-hero__glyph {
      font-size: 8rem;
      right: -1.5rem;
      opacity: 0.6;
    }
  }

  [data-theme="dark"] .cat-hero__glyph {
    color: color-mix(in srgb, var(--cat-accent) 14%, transparent);
  }

  .cat-hero .container {
    position: relative;
    z-index: 1;
  }

  .cat-hero--accent {
    padding-bottom: 2.5rem;
    background: radial-gradient(
        ellipse 90% 70% at 88% -15%,
        color-mix(in srgb, var(--cat-accent) 16%, transparent),
        transparent 55%
      ),
      radial-gradient(ellipse 70% 50% at 5% 100%, color-mix(in srgb, var(--cat-accent) 8%, transparent), transparent 50%),
      var(--bg);
  }

  /* Titre H1 : rule colorée qui se déploie à l'affichage. */
  .cat-hero__title {
    position: relative;
    display: inline-block;
  }

  .cat-hero__title::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -0.1em;
    height: 4px;
    width: 0;
    background: linear-gradient(90deg, var(--cat-accent), color-mix(in srgb, var(--cat-accent) 25%, transparent));
    border-radius: 2px;
    transition: width 920ms cubic-bezier(0.22, 1, 0.36, 1) 120ms;
  }

  .cat-hero__title.is-visible::after {
    width: clamp(3.5rem, 12vw, 7rem);
  }

  /* Strip de stats : trois chiffres typographiés à l'italique Fraunces, signature éditoriale. */
  .cat-stats {
    margin: 1.5rem 0 0;
    padding: 1.1rem 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(7rem, 1fr));
    gap: clamp(1rem, 3vw, 1.75rem) clamp(1.25rem, 4vw, 2.5rem);
    align-items: flex-end;
    border-top: 1px solid color-mix(in srgb, var(--cat-accent) 22%, var(--border-soft));
    max-width: 38rem;
  }

  @media (max-width: 480px) {
    .cat-stats {
      grid-template-columns: 1fr 1fr;
    }
  }

  .cat-stats__item {
    display: flex;
    flex-direction: column-reverse;
    gap: 0.18rem;
    margin: 0;
  }

  .cat-stats__item dt {
    font-family: var(--font-display);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .cat-stats__item dd {
    margin: 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(1.85rem, 4vw, 2.5rem);
    line-height: 0.95;
    color: var(--cat-accent);
    letter-spacing: -0.02em;
  }

  .cat-stats__item dd.cat-stats__date {
    font-size: clamp(1.1rem, 2.2vw, 1.4rem);
    line-height: 1.2;
    color: var(--text-main);
  }

  [data-theme="dark"] .cat-hero--accent {
    background: radial-gradient(
        ellipse 90% 70% at 88% -15%,
        color-mix(in srgb, var(--cat-accent) 12%, transparent),
        transparent 55%
      ),
      radial-gradient(ellipse 70% 50% at 5% 100%, color-mix(in srgb, var(--cat-accent) 6%, transparent), transparent 50%),
      var(--bg);
  }

  .cat-rich {
    padding: 0 0 2.5rem;
  }

  .cat-rich .eyebrow {
    margin-bottom: 1.1rem;
  }

  .cat-rich__essay {
    display: grid;
    gap: clamp(1.75rem, 4vw, 2.75rem);
    max-width: 52rem;
    margin-top: 0.75rem;
  }

  .cat-rich__block {
    display: grid;
    gap: 0.85rem;
  }

  .cat-rich__h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 0.9vw + 0.95rem, 1.25rem);
    font-weight: 650;
    letter-spacing: -0.02em;
    color: var(--text-main);
  }

  .cat-rich__p {
    margin: 0;
    font-size: clamp(0.98rem, 0.65vw + 0.91rem, 1.08rem);
    line-height: 1.72;
    color: var(--text-muted);
  }

  /* ─── Slides magazine illustré (remplace cat-rich__essay quand slides existent) ─── */
  .cat-slides {
    display: grid;
    gap: clamp(1.25rem, 3vw, 1.85rem);
    margin: 1.5rem 0 0;
    max-width: 64rem;
  }

  .cat-slide {
    position: relative;
    padding: clamp(1.5rem, 3vw, 2.25rem) clamp(1.5rem, 3vw, 2.25rem) clamp(1.5rem, 3vw, 2rem);
    border-radius: 8px;
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-left: 4px solid var(--cat-accent);
    box-shadow: var(--shadow-sm);
    transition: transform 280ms var(--ease-spring), box-shadow 280ms var(--ease-out), border-color 180ms ease;
    overflow: hidden;
  }

  /* Filigrane numéroté géant en arrière-plan : signature magazine. */
  .cat-slide::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 95% 0%, color-mix(in srgb, var(--cat-accent) 9%, transparent), transparent 45%);
    z-index: 0;
  }

  .cat-slide > * {
    position: relative;
    z-index: 1;
  }

  .cat-slide:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: color-mix(in srgb, var(--cat-accent) 35%, var(--border-soft));
  }

  /* Alternance gauche/droite : effet visible UNIQUEMENT en desktop.
     Sur mobile, toutes les bordures restent à gauche pour préserver l'alignement. */
  @media (min-width: 760px) {
    .cat-slide--right {
      border-left: 1px solid var(--border-soft);
      border-right: 4px solid var(--cat-accent);
      padding-left: clamp(1.5rem, 3vw, 2.25rem);
      margin-left: clamp(2rem, 8vw, 5rem);
    }
    .cat-slide--right::before {
      background:
        radial-gradient(circle at 5% 0%, color-mix(in srgb, var(--cat-accent) 9%, transparent), transparent 45%);
    }
    .cat-slide--left {
      margin-right: clamp(2rem, 8vw, 5rem);
    }
  }

  .cat-slide__head {
    display: flex;
    align-items: baseline;
    gap: 0.85rem;
    margin-bottom: 0.85rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid color-mix(in srgb, var(--cat-accent) 18%, var(--border-soft));
  }

  .cat-slide__num {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(2.1rem, 4.5vw, 3rem);
    line-height: 0.9;
    color: var(--cat-accent);
    letter-spacing: -0.04em;
  }

  .cat-slide__kicker {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-dim);
    padding-bottom: 0.3rem;
  }

  .cat-slide__title {
    margin: 0 0 0.85rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.35rem, 2.8vw, 1.85rem);
    line-height: 1.18;
    letter-spacing: -0.025em;
    color: var(--text-main);
  }

  .cat-slide__lead {
    margin: 0 0 1.1rem;
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1rem, 1.8vw, 1.12rem);
    line-height: 1.55;
    color: var(--text-muted);
    max-width: 38rem;
  }

  .cat-slide__points {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.7rem;
  }

  .cat-slide__points li {
    display: grid;
    grid-template-columns: 1.1rem 1fr;
    gap: 0.55rem;
    align-items: baseline;
    font-size: 0.96rem;
    line-height: 1.6;
    color: var(--text-main);
  }

  .cat-slide__bullet {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--cat-accent);
    line-height: 1;
  }

  .cat-slide__quote {
    margin: 1.25rem 0 0;
    padding: 0.95rem 1.1rem 0.95rem 1.5rem;
    background: color-mix(in srgb, var(--cat-accent) 7%, var(--bg-warm));
    border-radius: 6px;
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(1rem, 1.7vw, 1.1rem);
    line-height: 1.5;
    color: var(--text-main);
    position: relative;
  }

  .cat-slide__quote-mark {
    position: absolute;
    top: -0.5rem;
    left: 0.5rem;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 2.3rem;
    line-height: 1;
    color: color-mix(in srgb, var(--cat-accent) 55%, transparent);
    pointer-events: none;
  }

  @media (max-width: 600px) {
    .cat-slide {
      padding: 1.25rem 1.15rem 1.35rem;
    }
    .cat-slide__quote {
      padding: 0.85rem 0.95rem 0.85rem 1.25rem;
    }
  }

  @media (prefers-reduced-motion : reduce) {
    .cat-slide,
    .cat-slide__quote-mark {
      transition: none !important;
    }
    .cat-slide:hover {
      transform: none;
    }
  }

  .cat-rich__cards-intro {
    margin: clamp(1.75rem, 4vw, 2.5rem) 0 0.85rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-muted);
  }

  .cat-rich__cards {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .cat-rich__card {
    margin: 0;
    padding: 1rem 1.1rem 1.05rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-soft);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
  }

  .cat-rich__card strong {
    display: block;
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-main);
    margin-bottom: 0.35rem;
  }

  .cat-rich__card p {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-muted);
  }

  .cat-hero h1 {
    font-family: var(--font-serif);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(2.6rem, 6.2vw, 4.2rem);
    letter-spacing: -0.015em;
    line-height: 1.05;
    margin: 0.5rem 0 0.9rem;
    font-optical-sizing: auto;
  }
  .cat-tagline {
    font-size: 1.1rem;
    color: var(--text-main);
    margin-bottom: 0.5rem;
  }
  .cat-desc {
    color: var(--text-muted);
    max-width: 38rem;
  }

  .cat-section { padding: 1.5rem 0 3.5rem; }

  .cat-hero-card { margin-top: 1rem; max-width: 44rem; }

  .cat-section__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .text-link {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-muted);
    transition: color 150ms ease;
  }
  .text-link:hover { color : var(--green); }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.85rem;
  }

  .empty-state {
    display: grid;
    place-items: center;
    text-align: center;
    gap: 0.75rem;
    padding: 4rem 1rem;
    max-width: 30rem;
    margin: 0 auto;
  }
  .empty-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4.5rem;
    height: 4.5rem;
    border-radius: 50%;
    background: var(--bg-warm);
    border: 1.5px solid var(--border-soft);
    margin-bottom: 0.25rem;
  }
  .empty-state h2 { font-size: 1.3rem; }
  .empty-state p { color : var(--text-muted); font-size: 0.92rem; }

  @media (max-width: 680px) {
    .cat-section__head { flex-direction : column; align-items : flex-start; }
  }
</style>
