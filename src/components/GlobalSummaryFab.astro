---
---
<button
  id="global-summary-btn"
  class="summary-fab"
  type="button"
  aria-label="Ouvrir le sommaire"
  aria-expanded="false"
  aria-controls="global-summary-panel"
>
  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M8 6h13"/><path d="M8 12h13"/><path d="M8 18h13"/><path d="M3 6h.01"/><path d="M3 12h.01"/><path d="M3 18h.01"/>
  </svg>
  <span>Sommaire</span>
</button>

<aside id="global-summary-panel" class="summary-panel" hidden>
  <div class="summary-head">
    <strong>Sommaire</strong>
    <button id="global-summary-close" type="button" aria-label="Fermer le sommaire">×</button>
  </div>
  <ol id="global-summary-list"></ol>
</aside>

<style>
  .summary-fab {
    position: fixed;
    left: 1rem;
    bottom: calc(1.05rem + env(safe-area-inset-bottom));
    z-index: 46;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-height: 2.6rem;
    padding: 0 0.95rem;
    border: 1px solid color-mix(in srgb, var(--green) 18%, var(--border-soft));
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--green) 12%, rgba(255,255,255,0.92));
    color: var(--text-main);
    box-shadow: var(--shadow-md);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    opacity: 0;
    transform: translateY(12px);
    pointer-events: none;
    transition:
      opacity 220ms ease,
      transform 220ms var(--ease-spring),
      background 180ms ease,
      border-color 180ms ease;
  }

  .summary-fab.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .summary-panel {
    position: fixed;
    left: 1rem;
    bottom: calc(4.05rem + env(safe-area-inset-bottom));
    z-index: 46;
    width: min(22rem, calc(100vw - 2rem));
    max-height: min(62vh, 30rem);
    overflow: auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-soft);
    background: var(--surface);
    box-shadow: var(--shadow-md);
    padding: 0.8rem 0.85rem;
  }

  .summary-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.6rem;
  }

  .summary-head strong {
    font-size: 0.86rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .summary-head button {
    border: 1px solid var(--border-soft);
    border-radius: 50%;
    width: 1.8rem;
    height: 1.8rem;
    background: var(--bg-warm);
    color: var(--text-main);
    cursor: pointer;
  }

  #global-summary-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.2rem;
  }

  #global-summary-list li {
    margin: 0;
    padding: 0;
  }

  #global-summary-list li.sub {
    padding-left: 0.9rem;
  }

  #global-summary-list a {
    display: block;
    padding: 0.35rem 0.45rem;
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    font-size: 0.86rem;
    line-height: 1.35;
  }

  #global-summary-list a:hover {
    background: var(--bg-warm);
    color: var(--text-main);
  }

  @media (max-width: 900px) {
    .summary-fab {
      left: 1rem;
      bottom: calc(1.05rem + env(safe-area-inset-bottom));
    }

    :global(body.has-dual-fabs) .summary-fab {
      bottom: calc(1.05rem + env(safe-area-inset-bottom));
    }

    .summary-panel {
      left: 1rem;
      right: 1rem;
      width: auto;
      bottom: calc(4.05rem + env(safe-area-inset-bottom));
      max-height: min(56vh, 28rem);
    }
  }

  @media (max-width: 520px) {
    .summary-fab {
      min-height: 2.55rem;
      padding: 0 0.88rem;
      font-size: 0.8rem;
      gap: 0.38rem;
    }

    :global(body.has-dual-fabs) .summary-fab {
      bottom: calc(1.45rem + env(safe-area-inset-bottom));
    }

    .summary-panel {
      left: 0.7rem;
      right: 0.7rem;
      bottom: calc(3.9rem + env(safe-area-inset-bottom));
      border-radius: var(--radius-md);
      padding: 0.72rem 0.75rem;
      max-height: min(58vh, 26rem);
    }
  }
</style>

<script>
  function getEls() {
    return {
      btn: document.getElementById("global-summary-btn"),
      panel: document.getElementById("global-summary-panel"),
      closeBtn: document.getElementById("global-summary-close"),
      list: document.getElementById("global-summary-list"),
    };
  }

  function getThreshold() {
    return Math.min(260, Math.max(120, Math.round(window.innerHeight * 0.22)));
  }

  function slugify(text) {
    return text
      .toLowerCase()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .replace(/[^a-z0-9\s-]/g, "")
      .trim()
      .replace(/\s+/g, "-")
      .replace(/-+/g, "-");
  }

  function collectHeadings() {
    const main = document.getElementById("main-content");
    if (!main) return [];
    const els = Array.from(main.querySelectorAll("h1, h2, h3"));
    return els
      .map((el, i) => {
        if (!el.id) {
          const base = slugify(el.textContent || `section-${i + 1}`) || `section-${i + 1}`;
          el.id = base;
        }
        return { id: el.id, text: (el.textContent || "").trim(), depth: Number(el.tagName.slice(1)) };
      })
      .filter((h) => h.text.length > 0);
  }

  function renderList(headings) {
    const { list } = getEls();
    if (!list) return;
    list.innerHTML = "";
    headings.forEach((h) => {
      const li = document.createElement("li");
      if (h.depth === 3) li.classList.add("sub");
      const a = document.createElement("a");
      a.href = `#${h.id}`;
      a.textContent = h.text;
      a.addEventListener("click", () => {
        const { panel, btn } = getEls();
        if (panel) panel.hidden = true;
        btn?.setAttribute("aria-expanded", "false");
      });
      li.appendChild(a);
      list.appendChild(li);
    });
  }

  function closePanel() {
    const { panel, btn } = getEls();
    if (panel) panel.hidden = true;
    btn?.setAttribute("aria-expanded", "false");
  }

  function initGlobalSummary() {
    const { btn, panel } = getEls();
    if (!btn || !panel) return;
    const headings = collectHeadings();
    if (headings.length < 1) {
      btn.classList.remove("visible");
      btn.setAttribute("aria-expanded", "false");
      panel.hidden = true;
      return;
    }

    renderList(headings);
    const shouldShow = window.scrollY > getThreshold();
    btn.classList.toggle("visible", shouldShow);
    panel.hidden = true;
    btn.setAttribute("aria-expanded", "false");
  }

  function onScrollSummary() {
    const { btn, list, panel } = getEls();
    if (!btn || !list) return;
    const hasItems = list.children.length > 0;
    btn.classList.toggle("visible", hasItems && window.scrollY > getThreshold());
    const btt = document.getElementById("back-to-top");
    const bothVisible = btn.classList.contains("visible") && !!btt?.classList.contains("visible");
    document.body.classList.toggle("has-dual-fabs", bothVisible);
    if (panel && !panel.hidden && window.scrollY < 120) {
      closePanel();
    }
  }

  function bindSummaryEvents() {
    const { btn, closeBtn } = getEls();
    if (btn && !btn.dataset.bound) {
      btn.addEventListener("click", () => {
        const { panel, btn: currentBtn } = getEls();
        if (!panel || !currentBtn) return;
        const willOpen = panel.hidden;
        panel.hidden = !willOpen;
        currentBtn.setAttribute("aria-expanded", willOpen ? "true" : "false");
      });
      btn.dataset.bound = "true";
    }

    if (closeBtn && !closeBtn.dataset.bound) {
      closeBtn.addEventListener("click", closePanel);
      closeBtn.dataset.bound = "true";
    }
  }

  function syncDualFabsState() {
    const { btn } = getEls();
    const btt = document.getElementById("back-to-top");
    const bothVisible = !!btn?.classList.contains("visible") && !!btt?.classList.contains("visible");
    document.body.classList.toggle("has-dual-fabs", bothVisible);
  }

  if (!window.__summaryClickOutsideBound) {
    document.addEventListener("click", (e) => {
      const { panel, btn } = getEls();
      if (!panel || panel.hidden) return;
      const target = e.target;
      if (target instanceof Node && !panel.contains(target) && !btn?.contains(target)) {
        closePanel();
      }
    });
    window.__summaryClickOutsideBound = true;
  }

  if (!window.__summaryEscapeBound) {
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closePanel();
    });
    window.__summaryEscapeBound = true;
  }

  document.addEventListener("astro:page-load", initGlobalSummary);
  document.addEventListener("astro:page-load", bindSummaryEvents);
  document.addEventListener("astro:page-load", syncDualFabsState);

  if (!window.__summaryScrollBound) {
    window.addEventListener("scroll", onScrollSummary, { passive: true });
    window.addEventListener("resize", onScrollSummary, { passive: true });
    window.__summaryScrollBound = true;
  }

  bindSummaryEvents();
  initGlobalSummary();
  syncDualFabsState();
</script>
