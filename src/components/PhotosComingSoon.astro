---
type Lang = "fr" | "en" | "de";
const { lang = "fr" } = Astro.props as { lang?: Lang };

const copy: Record<
  Lang,
  { eyebrow: string; h1: string; lead: string; curtainTitle: string; curtainText: string }
> = {
  fr: {
    eyebrow: "Carnet visuel",
    h1: "Photos",
    lead: "Voyages, escapades et moments hors échiquier : une galerie pour partager le reste du parcours.",
    curtainTitle: "Bientôt disponible",
    curtainText:
      "Un rideau blanc, pour l’instant : les clichés de nos sorties et de nos voyages seront publiés ici très prochainement.",
  },
  en: {
    eyebrow: "Visual diary",
    h1: "Photos",
    lead: "Travels, outings and life beyond the chessboard: a gallery to share the rest of the journey.",
    curtainTitle: "Coming soon",
    curtainText:
      "For now, a white curtain: snapshots from our trips and outings will appear here shortly.",
  },
  de: {
    eyebrow: "Visuelles Notizen",
    h1: "Fotos",
    lead: "Reisen, Ausflüge und Momente abseits des Bretts: eine Galerie für den Rest der Reise.",
    curtainTitle: "Demnächst",
    curtainText:
      "Vorläufig ein weißer Vorhang: Fotos von Ausflügen und Reisen erscheinen hier in Kürze.",
  },
};

const t = copy[lang];
---

<section class="page-hero photos-hero">
  <div class="container">
    <span class="eyebrow reveal">{t.eyebrow}</span>
    <h1 class="reveal">{t.h1}</h1>
    <p class="page-lead reveal">{t.lead}</p>
  </div>
</section>

<div class="photos-stage">
  <div class="container photos-stage__wrap">
    <div class="photos-backdrop" aria-hidden="true"></div>
    <div class="photos-curtain reveal">
      <p class="photos-curtain__title">{t.curtainTitle}</p>
      <p class="photos-curtain__text">{t.curtainText}</p>
      <div class="photos-curtain__fold" aria-hidden="true"></div>
    </div>
  </div>
</div>

<style>
  .photos-hero.page-hero {
    padding: 4.5rem 0 2rem;
  }

  .photos-hero h1 {
    font-size: clamp(2.4rem, 6vw, 4rem);
    margin: 0.5rem 0 0.75rem;
  }

  .page-lead {
    max-width: 42rem;
    margin: 0;
    font-size: 1.125rem;
    line-height: 1.65;
    color: var(--text-muted, inherit);
    opacity: 0.92;
  }

  .photos-stage {
    padding: 0 0 4rem;
  }

  .photos-stage__wrap {
    position: relative;
    min-height: min(62vh, 520px);
    display: flex;
    align-items: stretch;
    justify-content: center;
  }

  .photos-backdrop {
    position: absolute;
    inset: 0;
    border-radius: 12px;
    background:
      radial-gradient(circle at 20% 30%, rgba(91, 159, 212, 0.07) 0%, transparent 45%),
      radial-gradient(circle at 80% 70%, rgba(240, 160, 80, 0.06) 0%, transparent 40%),
      linear-gradient(145deg, var(--surface-warm, rgba(0, 0, 0, 0.03)) 0%, transparent 100%);
    border: 1px solid var(--border-soft, rgba(0, 0, 0, 0.06));
    pointer-events: none;
  }

  .photos-curtain {
    position: relative;
    z-index: 1;
    align-self: center;
    width: 100%;
    max-width: 52rem;
    min-height: min(52vh, 440px);
    margin: 2rem 0;
    padding: clamp(2.5rem, 6vw, 4rem) clamp(1.75rem, 5vw, 3rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: #ffffff;
    color: #1a1a1a;
    border-radius: 4px;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.85) inset,
      0 28px 56px rgba(0, 0, 0, 0.1),
      0 8px 16px rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(0, 0, 0, 0.06);
  }

  :global([data-theme="dark"]) .photos-curtain {
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.06) inset,
      0 28px 56px rgba(0, 0, 0, 0.45),
      0 8px 24px rgba(0, 0, 0, 0.35);
    border-color: rgba(255, 255, 255, 0.12);
  }

  .photos-curtain__title {
    margin: 0 0 1rem;
    font-family: var(--font-display, Georgia, serif);
    font-size: clamp(1.75rem, 4vw, 2.35rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: #111;
  }

  .photos-curtain__text {
    margin: 0;
    max-width: 28rem;
    font-size: 1.05rem;
    line-height: 1.65;
    color: #444;
  }

  .photos-curtain__fold {
    margin-top: 2.25rem;
    width: min(100%, 240px);
    height: 6px;
    border-radius: 3px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(0, 0, 0, 0.07) 20%,
      rgba(0, 0, 0, 0.07) 80%,
      transparent
    );
    opacity: 0.85;
  }
</style>
