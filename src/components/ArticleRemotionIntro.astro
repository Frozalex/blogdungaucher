---
import type { VideoPostProps } from "@remotion/types";

import RemotionIntroPlayer from "./remotion/RemotionIntroPlayer";

interface Props {
  inputProps: VideoPostProps;
  aspect?: "16:9" | "9:16";
}

const { inputProps, aspect = "16:9" } = Astro.props;
const portrait = aspect === "9:16";
---

<figure
  class:list={["article-inline-video", "fade-up", portrait ? "is-portrait" : "is-landscape"]}
  style="--motion-delay: 55ms;"
  data-remotion-intro
>
  <RemotionIntroPlayer client:only="react" inputProps={inputProps} aspect={aspect} />
</figure>

<style>
  .article-inline-video {
    margin: 0 0 1.25rem;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border-soft);
    background: var(--surface);
    box-shadow: var(--shadow-xs);
  }

  .article-inline-video :global([data-remotion-canvas], video) {
    display: block;
    width: 100% !important;
  }

  .article-inline-video.is-landscape {
    aspect-ratio: 16 / 9;
  }

  .article-inline-video.is-portrait {
    max-width: min(420px, 100%);
    margin-left: auto;
    margin-right: auto;
    aspect-ratio: 9 / 16;
  }
</style>
