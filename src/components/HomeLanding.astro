---
import AdBanner from "./AdBanner.astro";
import ArticleCard from "./ArticleCard.astro";
import { categoryMap, categorySlugs } from "../data/site";
import { swapLangPrefix } from "../utils/lang-paths";
import type { BlogEntry } from "../utils/blog";

interface Props {
  lang: "fr" | "en" | "de";
  latestPosts: BlogEntry[];
}

const { lang, latestPosts } = Astro.props;
const sectionsId = lang === "en" ? "sections" : "rubriques";
const blogHref = `/${lang}/blog/`;

type HomeCopy = {
  siteName: string;
  signatureTagline: string;
  eyebrow: string;
  titleHtml: string;
  lead: string;
  startReading: string;
  seeSections: string;
  proofListLabel: string;
  proof1: string;
  proof2: string;
  proof3: string;
  editorialNote: string;
  sectionsEyebrow: string;
  sectionsTitle: string;
  recentEyebrow: string;
  latestTitle: string;
  seeAll: string;
};

const homeByLang: Record<typeof lang, HomeCopy> = {
  fr: {
    siteName: "Blog d'un Gaucher",
    signatureTagline: "Science du jeu, esprit compétitif, échecs dans le monde réel.",
    eyebrow: "Éditorial indépendant",
    titleHtml:
      'Comprendre les <span class="hero__accent display-serif">échecs</span><br/>sans simplifier le jeu.',
    lead:
      "Chaque semaine, des analyses claires sur la science du jeu, le mental compétitif et l'impact des échecs dans la société, avec une approche humaine et exigeante.",
    startReading: "Commencer la lecture",
    seeSections: "Voir les rubriques",
    proofListLabel: "Repères éditoriaux",
    proof1: "Articles de fond",
    proof2: "Ton accessible",
    proof3: "Approche rigoureuse",
    editorialNote:
      "Ici, on ne promet pas des progrès magiques en 7 jours. On propose des idées solides, des exemples concrets et des analyses que tu peux appliquer à ta pratique, que tu sois joueur de club, compétiteur ou simple passionné.",
    sectionsEyebrow: "4 rubriques",
    sectionsTitle: "Ce dont on parle ici",
    recentEyebrow: "Récents",
    latestTitle: "Derniers articles",
    seeAll: "Tout voir →",
  },
  en: {
    siteName: "A Left-Hander's Blog",
    signatureTagline: "Game science, competitive mindset, chess in the real world.",
    eyebrow: "Independent editorial",
    titleHtml:
      'Understanding <span class="hero__accent display-serif">chess</span><br/>without oversimplifying.',
    lead:
      "Each week, clear analyses on the science of the game, the competitive mindset and the impact of chess on society, with a human and demanding approach.",
    startReading: "Start reading",
    seeSections: "See sections",
    proofListLabel: "Editorial markers",
    proof1: "In-depth articles",
    proof2: "Accessible tone",
    proof3: "Rigorous approach",
    editorialNote:
      "Here, we don't promise magical progress in 7 days. We offer solid ideas, concrete examples and analyses that you can apply to your practice, whether you're a club player, a competitor, or simply passionate about the game.",
    sectionsEyebrow: "4 sections",
    sectionsTitle: "What we cover here",
    recentEyebrow: "Recent",
    latestTitle: "Latest articles",
    seeAll: "See all →",
  },
  de: {
    siteName: "Blog d'un Gaucher",
    signatureTagline: "Spielwissenschaft, Wettkampfgeist, Schach in der realen Welt.",
    eyebrow: "Unabhängiges Editorial",
    titleHtml:
      '<span class="hero__accent display-serif">Schach</span> verstehen<br/>ohne das Spiel zu vereinfachen.',
    lead:
      "Jede Woche klare Analysen zur Spielwissenschaft, zum Wettkampfgeist und zur Rolle des Schachs in der Gesellschaft, mit einem menschlichen und anspruchsvollen Ansatz.",
    startReading: "Zur Lektüre",
    seeSections: "Rubriken ansehen",
    proofListLabel: "Redaktionelle Merkmale",
    proof1: "Hintergrundartikel",
    proof2: "Zugänglicher Ton",
    proof3: "Rigoroser Ansatz",
    editorialNote:
      "Hier versprechen wir keinen magischen Fortschritt in 7 Tagen. Wir bieten solide Ideen, konkrete Beispiele und Analysen, die du in deine Praxis übernehmen kannst, egal ob Vereinsspieler, Turnierspieler oder begeisterter Amateur.",
    sectionsEyebrow: "4 Rubriken",
    sectionsTitle: "Darum geht es hier",
    recentEyebrow: "Neu",
    latestTitle: "Neueste Artikel",
    seeAll: "Alle anzeigen →",
  },
};

const c = homeByLang[lang];

/** Comme Dead cells.css (`.banner`) : placer une image plein écran dans `public/images/hero-banner.jpg` (ex. copie de `1738625483834.jpg`). */
const heroBannerUrl = "/images/hero-banner.jpg";
---

<div class="home-landing">
  <section class="hero hero--immersive" aria-labelledby="home-hero-heading">
    <div class="hero__backdrop" style={`--hero-banner: url('${heroBannerUrl}')`} aria-hidden="true"></div>
    <div class="hero__noise" aria-hidden="true"></div>

    <div class="hero__shell">
      <div class="hero__center">
        <p class="hero__tagline hero__tagline--dark fade-up" style="--motion-delay: 30ms;" data-t="home.signatureTagline">
          {c.signatureTagline}
        </p>

        <p class="hero__kicker fade-up" style="--motion-delay: 55ms;" data-t="home.eyebrow">
          {c.eyebrow}
        </p>

        <h1
          id="home-hero-heading"
          class="hero__title hero__title--immersive fade-up"
          style="--motion-delay: 110ms;"
          data-t-html="home.titleHtml"
          set:html={c.titleHtml}
        ></h1>

        <p class="hero__lead hero__lead--dark fade-up" style="--motion-delay: 175ms;" data-t="home.lead">
          {c.lead}
        </p>

        <div class="hero__actions hero__actions--immersive fade-up" style="--motion-delay: 235ms;">
          <a href={blogHref} class="hero__cta--immersive" data-t="home.startReading">
            {c.startReading}
          </a>
          <a href={`#${sectionsId}`} class="hero__cta-ghost" data-t="home.seeSections">
            {c.seeSections}
          </a>
        </div>

        <ul
          class="hero-proof hero-proof--dark fade-up"
          style="--motion-delay: 300ms;"
          aria-label={c.proofListLabel}
        >
          <li data-t="home.proof1">{c.proof1}</li>
          <li data-t="home.proof2">{c.proof2}</li>
          <li data-t="home.proof3">{c.proof3}</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="editorial-intro">
    <div class="container editorial-intro__wrap">
      <div class="editorial-note editorial-note--home reveal scale-in" data-t="home.editorialNote">
        {c.editorialNote}
      </div>
    </div>
  </section>

  <section class="pillars" id={sectionsId}>
    <div class="container">
      <span class="eyebrow reveal" data-t="home.sectionsEyebrow">
        {c.sectionsEyebrow}
      </span>
      <h2 class="drop-heading section-title reveal" data-t="home.sectionsTitle">
        {c.sectionsTitle}
      </h2>
      <div class="pillar-grid reveal-group">
        {
          categorySlugs.map((slug) => {
            const cat = categoryMap[slug];
            const href = lang === "fr" ? cat.href : swapLangPrefix(cat.href, lang);
            return (
              <a href={href} class="pillar" style={`--p:${cat.accent};`}>
                <span class="pillar__dot"></span>
                <div>
                  <span class="pillar__kicker" data-t={`categories.${slug}.shortLabel`}>
                    {cat.shortLabel}
                  </span>
                  <strong data-t={`categories.${slug}.label`}>{cat.label}</strong>
                  <p data-t={`categories.${slug}.tagline`}>{cat.tagline}</p>
                </div>
                <svg
                  class="pillar__arrow"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M5 12h14" />
                  <path d="M12 5l7 7-7 7" />
                </svg>
              </a>
            );
          })
        }
      </div>
    </div>
  </section>

  <div class="container">
    <AdBanner format="leaderboard" />
  </div>

  <section class="latest">
    <div class="container">
      <div class="section-head reveal">
        <div class="section-head__titles">
          <span class="eyebrow" data-t="home.recentEyebrow">
            {c.recentEyebrow}
          </span>
          <h2 class="drop-heading section-title" data-t="home.latestTitle">
            {c.latestTitle}
          </h2>
        </div>
        <a href={blogHref} class="see-all link-underline" data-t="home.seeAll">
          {c.seeAll}
        </a>
      </div>
      <div class="latest-grid reveal-group">
        {latestPosts.map((post, i) => <ArticleCard post={post} featured={i === 0} lang={lang} />)}
      </div>
    </div>
  </section>
</div>

<style>
  /* Réf. Dead cells/Dead cells.css : .banner (100vh, cover, contenu centré max 900px, btn ff0157 → vert blog). */
  @import url("https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,600;0,700;0,800;1,400&display=swap");

  .home-landing {
    overflow-x: clip;
    background:
      radial-gradient(ellipse 100% 70% at 50% -15%, color-mix(in srgb, var(--green) 9%, transparent), transparent 52%),
      var(--bg);
  }

  [data-theme="dark"] .home-landing {
    background:
      radial-gradient(ellipse 100% 65% at 50% -12%, color-mix(in srgb, var(--green) 12%, transparent), transparent 50%),
      var(--bg);
  }

  .editorial-intro .container,
  .pillars .container,
  .latest .container {
    width: min(1280px, calc(100% - 2rem));
    margin-inline: auto;
  }

  /* ── Hero type Dead cells `.banner` : 100vh, flex centre, image cover ── */
  .hero--immersive {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    max-width: none;
    color: #fff;
    font-family: "Poppins", system-ui, sans-serif;
  }

  .hero__backdrop {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-color: #050605;
    background-image:
      linear-gradient(180deg, rgba(0, 0, 0, 0.42) 0%, rgba(0, 0, 0, 0.62) 100%),
      var(--hero-banner),
      radial-gradient(ellipse 88% 62% at 50% 102%, rgba(61, 139, 55, 0.28), transparent 58%),
      radial-gradient(ellipse 52% 44% at 82% 18%, rgba(90, 178, 84, 0.14), transparent 52%),
      linear-gradient(168deg, #040705 0%, #070d0a 42%, #020302 100%);
    background-size: cover;
    background-position: center center;
    background-repeat: no-repeat;
  }

  .hero__backdrop::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(ellipse 75% 65% at 50% 45%, transparent 22%, rgba(0, 0, 0, 0.55) 100%);
  }

  .hero__noise {
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: 0.06;
    pointer-events: none;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/></filter><rect width='100%25' height='100%25' filter='url(%23n)' opacity='0.55'/></svg>");
  }

  .hero__shell {
    position: relative;
    z-index: 2;
    box-sizing: border-box;
    width: min(1280px, calc(100% - 2rem));
    margin-inline: auto;
    min-height: 100vh;
    padding-top: var(--navbar-h);
    display: flex;
    justify-content: center;
    align-items: center;
    padding-bottom: clamp(1.5rem, 4vw, 2.5rem);
  }

  .hero__center {
    width: 100%;
    max-width: 900px;
    text-align: center;
    padding: 0 0.75rem;
  }

  .hero__tagline--dark {
    margin: 0 0 0.85rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
  }

  .hero__kicker {
    margin: 0 0 0.75rem;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.42);
  }

  /* .banner .content h2 { font-size: 5em } — équivalent fluide */
  .hero__title--immersive {
    font-family: "Poppins", system-ui, sans-serif;
    font-weight: 700;
    font-size: clamp(2.75rem, 13vw, 5rem);
    margin: 0 0 1rem;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: #fff;
  }

  .hero__title--immersive .hero__accent {
    color: #9ae894;
    font-weight: 700;
    font-style: normal;
    font-family: "Poppins", system-ui, sans-serif;
  }

  .hero__title--immersive .hero__accent.display-serif {
    font-family: "Poppins", system-ui, sans-serif;
    font-style: normal;
  }

  .hero__lead--dark {
    font-size: clamp(0.95rem, 2.2vw, 1.05rem);
    font-weight: 300;
    color: rgba(255, 255, 255, 0.88);
    max-width: 38rem;
    margin: 0 auto;
    line-height: 1.65;
  }

  .hero__actions--immersive {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    justify-content: center;
    margin-top: 1.25rem;
  }

  /* .btn : padding 10px 30px, uppercase, letter-spacing 2px, hover letter-spacing 6px */
  .hero__cta--immersive {
    font-family: "Poppins", system-ui, sans-serif;
    font-size: 1em;
    font-weight: 600;
    color: #fff !important;
    background: var(--green);
    border: none;
    border-radius: 0;
    display: inline-block;
    padding: 10px 30px;
    margin-top: 8px;
    text-transform: uppercase;
    text-decoration: none;
    letter-spacing: 2px;
    transition: letter-spacing 0.5s ease, background 0.25s ease, box-shadow 0.25s ease;
    cursor: pointer;
    box-shadow: 0 4px 24px rgba(61, 139, 55, 0.35);
    min-height: unset;
  }

  .hero__cta--immersive:hover {
    background: var(--green-hover);
    color: #fff !important;
    letter-spacing: 6px;
  }

  .hero__cta-ghost {
    font-family: "Poppins", system-ui, sans-serif;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 26px;
    margin-top: 8px;
    border-radius: 0;
    border: 1px solid rgba(255, 255, 255, 0.4);
    font-weight: 500;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.95);
    background: rgba(255, 255, 255, 0.06);
    text-decoration: none;
    letter-spacing: 1px;
    transition:
      letter-spacing 0.45s ease,
      border-color 0.2s ease,
      background 0.2s ease;
  }

  .hero__cta-ghost:hover {
    letter-spacing: 3px;
    border-color: rgba(255, 255, 255, 0.65);
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
  }

  .hero-proof--dark {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    justify-content: center;
  }

  .hero-proof--dark li {
    padding: 0.32rem 0.72rem;
    border-radius: 2px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.69rem;
    font-weight: 500;
    font-family: "Poppins", system-ui, sans-serif;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__cta--immersive,
    .hero__cta-ghost {
      transition: background 0.2s ease, border-color 0.2s ease;
    }
    .hero__cta--immersive:hover,
    .hero__cta-ghost:hover {
      letter-spacing: 2px;
    }
  }

  @media (max-width: 560px) {
    .hero__actions--immersive {
      flex-direction: column;
      width: 100%;
      max-width: 22rem;
      margin-inline: auto;
    }

    .hero__cta--immersive,
    .hero__cta-ghost {
      width: 100%;
    }
  }

  .editorial-intro {
    padding: clamp(2.5rem, 6vw, 4rem) 0;
  }

  .editorial-intro__wrap {
    display: flex;
    justify-content: center;
  }

  .editorial-note--home {
    width: 100%;
    max-width: 40rem;
    margin-inline: auto;
    text-align: left;
    border: 1px solid var(--border-soft);
    border-radius: 3px;
    padding: 1.35rem 1.35rem 1.35rem 1.25rem;
    border-left: 4px solid var(--green);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
  }

  /* Titres type maquette : première lettre massacrée en vert (reste en noir via tokens). */
  .home-landing h2.drop-heading.section-title {
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 700;
    font-size: clamp(1.85rem, 4.8vw, 2.85rem);
    letter-spacing: -0.03em;
    line-height: 1.12;
    margin: 0 0 0.25rem;
    color: var(--text-main);
  }

  .home-landing h2.drop-heading.section-title::first-letter {
    color: var(--green);
    font-weight: 800;
    font-size: clamp(2.75rem, 9vw, 4.25rem);
    line-height: 0.85;
    margin-right: 0.02em;
  }

  .pillars {
    padding: clamp(2rem, 5vw, 3rem) 0 3.75rem;
  }

  .pillars .container {
    text-align: center;
  }

  .pillar-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15.5rem, 1fr));
    gap: 1.15rem;
    margin-top: 1.75rem;
    align-items: stretch;
  }

  .pillar {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 1.35rem 1.25rem;
    border-radius: 3px;
    border: 1px solid var(--border-soft);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
    transition:
      transform 240ms var(--ease-spring),
      border-color 180ms ease,
      box-shadow 240ms var(--ease-out);
    text-align: left;
  }

  .pillar:hover {
    transform: translateY(-4px);
    border-color: var(--p);
    box-shadow: var(--shadow-md);
  }

  .pillar__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--p);
    flex-shrink: 0;
    margin-top: 0.4rem;
    transition: transform 240ms var(--ease-spring);
  }

  .pillar:hover .pillar__dot {
    transform: scale(1.45);
  }

  .pillar > div {
    flex: 1;
    min-width: 0;
  }

  .pillar__kicker {
    display: inline-flex;
    margin-bottom: 0.2rem;
    font-size: 0.64rem;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    color: var(--text-dim);
    font-weight: 700;
  }

  .pillar strong {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.94rem;
    color: var(--text-main);
    margin-bottom: 0.2rem;
  }

  .pillar p {
    font-size: 0.84rem;
    color: var(--text-muted);
    line-height: 1.55;
    margin: 0;
  }

  .pillar__arrow {
    color: var(--text-dim);
    flex-shrink: 0;
    margin-top: 0.2rem;
    transition:
      color 180ms ease,
      transform 240ms var(--ease-spring);
  }

  .pillar:hover .pillar__arrow {
    color: var(--p);
    transform: translateX(3px);
  }

  .latest {
    padding: clamp(2rem, 5vw, 3rem) 0 5.5rem;
  }

  .latest .container {
    text-align: center;
  }

  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.65rem;
    max-width: 72rem;
    margin-inline: auto;
  }

  .section-head__titles {
    text-align: left;
  }

  .section-head .drop-heading {
    margin-bottom: 0;
  }

  .see-all {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-muted);
    transition: color 160ms ease;
  }

  .see-all:hover {
    color: var(--green);
  }

  .latest-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.15rem;
    text-align: left;
    max-width: 72rem;
    margin-inline: auto;
  }

  .latest-grid > :global(.card) {
    box-shadow: var(--shadow-md);
    border-radius: 3px;
    border-width: 1px;
  }

  .latest-grid > :first-child {
    grid-column: 1 / -1;
  }

  @media (max-width: 900px) {
    .latest-grid {
      grid-template-columns: 1fr;
    }
    .latest-grid > :first-child {
      grid-column: auto;
    }
    .section-head {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .section-head__titles {
      text-align: center;
    }
  }

  @media (max-width: 560px) {
    .editorial-intro .container,
    .pillars .container,
    .latest .container {
      width: min(1280px, calc(100% - 1.25rem));
    }
    .hero-proof--dark li {
      font-size: 0.65rem;
    }
  }
</style>
