---
import AdBanner from "./AdBanner.astro";
import ArticleCard from "./ArticleCard.astro";
import { categoryMap, categorySlugs } from "../data/site";
import { swapLangPrefix } from "../utils/lang-paths";
import type { BlogEntry } from "../utils/blog";

interface Props {
  lang: "fr" | "en" | "de";
  latestPosts: BlogEntry[];
  totalPosts: number;
  postsByCategory?: Partial<Record<(typeof categorySlugs)[number], number>>;
}

const { lang, latestPosts, totalPosts, postsByCategory = {} } = Astro.props;
const sectionsId = lang === "en" ? "sections" : "rubriques";
const blogHref = `/${lang}/blog/`;

type HomeCopy = {
  siteName: string;
  signatureTagline: string;
  eyebrow: string;
  titleHtml: string;
  lead: string;
  startReading: string;
  seeSections: string;
  proofListLabel: string;
  proof1: string;
  proof2: string;
  proof3: string;
  editorialNote: string;
  sectionsEyebrow: string;
  sectionsTitle: string;
  recentEyebrow: string;
  latestTitle: string;
  seeAll: string;
};

const homeByLang : Record<typeof lang, HomeCopy> = {
  fr: {
    siteName: "Blog d'un Gaucher",
    signatureTagline: "Science du jeu, esprit compétitif, échecs dans le monde réel.",
    eyebrow: "Éditorial indépendant",
    titleHtml:
      'Comprendre les <span class="hero__accent display-serif">échecs</span><br/>sans simplifier le jeu.',
    lead:
      "Deux articles par semaine : des analyses claires sur la science du jeu, le mental compétitif et l'impact des échecs dans la société, avec une approche humaine et exigeante.",
    startReading: "Commencer la lecture",
    seeSections: "Voir les rubriques",
    proofListLabel: "Repères éditoriaux",
    proof1: `${totalPosts}+ analyses publiées`,
    proof2: "2 articles / semaine",
    proof3: "Sources citées, 0 clickbait",
    editorialNote: "",
    sectionsEyebrow: "4 rubriques",
    sectionsTitle: "Ce dont on parle ici",
    recentEyebrow: "Récents",
    latestTitle: "Derniers articles",
    seeAll: "Tout voir →",
  },
  en: {
    siteName: "A Left-Hander's Blog",
    signatureTagline: "Game science, competitive mindset, chess in the real world.",
    eyebrow: "Independent editorial",
    titleHtml:
      'Understanding <span class="hero__accent display-serif">chess</span><br/>without oversimplifying.',
    lead:
      "Two articles every week : clear analyses on the science of the game, the competitive mindset and the impact of chess on society, with a human and demanding approach.",
    startReading: "Start reading",
    seeSections: "See sections",
    proofListLabel: "Editorial markers",
    proof1: `${totalPosts}+ analyses published`,
    proof2: "2 articles / week",
    proof3: "Cited sources, 0 clickbait",
    editorialNote: "",
    sectionsEyebrow: "4 sections",
    sectionsTitle: "What we cover here",
    recentEyebrow: "Recent",
    latestTitle: "Latest articles",
    seeAll: "See all →",
  },
  de: {
    siteName: "Blog d'un Gaucher",
    signatureTagline: "Spielwissenschaft, Wettkampfgeist, Schach in der realen Welt.",
    eyebrow: "Unabhängiges Editorial",
    titleHtml:
      '<span class="hero__accent display-serif">Schach</span> verstehen<br/>ohne das Spiel zu vereinfachen.',
    lead:
      "Zwei Artikel pro Woche : klare Analysen zur Spielwissenschaft, zum Wettkampfgeist und zur Rolle des Schachs in der Gesellschaft, mit einem menschlichen und anspruchsvollen Ansatz.",
    startReading: "Zur Lektüre",
    seeSections: "Rubriken ansehen",
    proofListLabel: "Redaktionelle Merkmale",
    proof1: `${totalPosts}+ Analysen veröffentlicht`,
    proof2: "2 Artikel / Woche",
    proof3: "Quellen zitiert, 0 Clickbait",
    editorialNote: "",
    sectionsEyebrow: "4 Rubriken",
    sectionsTitle: "Darum geht es hier",
    recentEyebrow: "Neu",
    latestTitle: "Neueste Artikel",
    seeAll: "Alle anzeigen →",
  },
};

const c = homeByLang[lang];

/** Icônes stroke (24) alignées sur la couleur d’accent de chaque rubrique. */
const pillarIcons : Record<(typeof categorySlugs)[number], string> = {
  science: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="2.25"/><path d="M12 3v2.5M12 18.5V21M4.5 12H7m10 0h2.5"/><path d="M6.4 6.4l1.75 1.75m7.7 7.7l1.75 1.75M6.4 17.6l1.75-1.75m7.7-7.7l1.75-1.75"/></svg>`,
  esprit: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21c-4.5-3.2-7.5-6.4-7.5-10.2A4.5 4.5 0 0 1 12 6.5a4.5 4.5 0 0 1 7.5 4.3C19.5 14.6 16.5 17.8 12 21z"/></svg>`,
  societe: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="3.25"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  "grand-oral": `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><path d="M8 7h8M8 11h6"/></svg>`,
};

/** Glyphes pièces d'échecs en filigrane derrière les pillars : donne une signature visuelle au site. */
const pillarGlyphs : Record<(typeof categorySlugs)[number], string> = {
  science: "♞",
  esprit: "♛",
  societe: "♜",
  "grand-oral" : "♚",
};

/** Libellé i18n pour le compteur d'articles par rubrique.
   Allemand : "Artikel" est invariant en pluriel : pas de risque d'erreur. */
const articleCountLabel = (n : number): string => {
  if (lang === "en") return `${n} ${n > 1 ? "articles" : "article"}`;
  if (lang === "de") return `${n} Artikel`;
  return `${n} ${n > 1 ? "articles" : "article"}`;
};
---

<div class="home-landing">
  <section class="hero hero--classic" aria-labelledby="home-hero-heading">
    <!-- Décoration : mini échiquier pixel art, aria-hidden -->
    <div class="hero-deco" aria-hidden="true">
      <svg width="120" height="120" viewBox="0 0 8 8" xmlns="http://www.w3.org/2000/svg" shape-rendering="crispEdges">
        {[...Array(8)].map((_, r) =>
          [...Array(8)].map((_, c) => (
            <rect
              x={c}
              y={r}
              width="1"
              height="1"
              fill={(r + c) % 2 === 0 ? "currentColor" : "transparent"}
            />
          ))
        )}
      </svg>
    </div>
    <div class="container hero--classic__inner">
      <p class="hero__sig fade-up" style="--motion-delay: 30ms;" data-t="home.signatureTagline">
        {c.signatureTagline}
      </p>

      <p class="eyebrow hero__eyebrow fade-up" style="--motion-delay: 70ms;" data-t="home.eyebrow">
        {c.eyebrow}
      </p>

      <h1
        id="home-hero-heading"
        class="hero__title--classic fade-up"
        style="--motion-delay: 120ms;"
        data-t-html="home.titleHtml"
        set:html={c.titleHtml}
      ></h1>

      <p class="hero__lead--classic fade-up" style="--motion-delay: 170ms;" data-t="home.lead">
        {c.lead}
      </p>

      <div class="hero__actions--classic fade-up" style="--motion-delay: 220ms;">
        <a href={blogHref} class="button-primary" data-t="home.startReading">
          {c.startReading}
        </a>
        <a href={`#${sectionsId}`} class="button-secondary" data-t="home.seeSections">
          {c.seeSections}
        </a>
      </div>

      <ul
        class="hero-proof--classic fade-up"
        style="--motion-delay: 280ms;"
        aria-label={c.proofListLabel}
      >
        <li data-t="home.proof1">{c.proof1}</li>
        <li data-t="home.proof2">{c.proof2}</li>
        <li data-t="home.proof3">{c.proof3}</li>
      </ul>
    </div>
  </section>

  <section class="pillars" id={sectionsId}>
    <div class="container">
      <span class="eyebrow reveal" data-t="home.sectionsEyebrow">
        {c.sectionsEyebrow}
      </span>
      <h2 class="drop-heading section-title reveal" data-t="home.sectionsTitle">
        {c.sectionsTitle}
      </h2>
      <div class="pillar-grid reveal-group">
        {
          categorySlugs.map((slug) => {
            const cat = categoryMap[slug];
            const href = lang === "fr" ? cat.href : swapLangPrefix(cat.href, lang);
            const count = postsByCategory[slug] ?? 0;
            return (
              <a href={href} class="pillar" style={`--p:${cat.accent};--pillar-surface:${cat.surface};`}>
                <span class="pillar__glyph" aria-hidden="true">{pillarGlyphs[slug]}</span>
                <span class="pillar__icon" set:html={pillarIcons[slug]} />
                <div>
                  <span class="pillar__kicker" data-t={`categories.${slug}.shortLabel`}>
                    {cat.shortLabel}
                  </span>
                  <strong data-t={`categories.${slug}.label`}>{cat.label}</strong>
                  <p data-t={`categories.${slug}.tagline`}>{cat.tagline}</p>
                  {count > 0 && (
                    <span class="pillar__count">
                      <span class="pillar__count-num">{count}</span>
                      <span class="pillar__count-label">{articleCountLabel(count).replace(`${count} `, "")}</span>
                    </span>
                  )}
                </div>
                <svg
                  class="pillar__arrow"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M5 12h14" />
                  <path d="M12 5l7 7-7 7" />
                </svg>
              </a>
            );
          })
        }
      </div>
    </div>
  </section>

  <div class="container">
    <AdBanner format="leaderboard" />
  </div>

  <section class="latest">
    <div class="container">
      <div class="section-head reveal">
        <div class="section-head__titles">
          <span class="eyebrow" data-t="home.recentEyebrow">
            {c.recentEyebrow}
          </span>
          <h2 class="drop-heading section-title" data-t="home.latestTitle">
            {c.latestTitle}
          </h2>
        </div>
        <a href={blogHref} class="see-all link-underline" data-t="home.seeAll">
          {c.seeAll}
        </a>
      </div>
      <div class="latest-grid reveal-group">
        {latestPosts.map((post) => (
          <ArticleCard post={post} featured={false} lang={lang} />
        ))}
      </div>
    </div>
  </section>
</div>

<style>
  .home-landing {
    overflow-x: clip;
    position: relative;
    background:
      radial-gradient(ellipse 100% 70% at 50% -15%, color-mix(in srgb, var(--green) 9%, transparent), transparent 52%),
      var(--bg);
  }

  /* Grain texture éditorial : SVG noise inline, ultra-discret, limité au hero.
     Évite la sur-texture du body et préserve la lisibilité des cartes articles. */
  .hero--classic::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.22;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='160' height='160' viewBox='0 0 160 160'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.13  0 0 0 0 0.10  0 0 0 0 0.04  0 0 0 0.55 0'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
    mix-blend-mode: multiply;
  }

  [data-theme="dark"] .hero--classic::before {
    opacity: 0.12;
    mix-blend-mode: screen;
  }

  .hero--classic > * {
    position: relative;
    z-index: 1;
  }

  [data-theme="dark"] .home-landing {
    background:
      radial-gradient(ellipse 100% 65% at 50% -12%, color-mix(in srgb, var(--green) 12%, transparent), transparent 50%),
      var(--bg);
  }

  /* Animation : trait d'accent qui se déploie au scroll-reveal sous le section-title. */
  .home-landing h2.drop-heading.section-title {
    position: relative;
    padding-bottom: 0.45rem;
  }

  .home-landing h2.drop-heading.section-title::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -2px;
    height: 3px;
    width: 0;
    background: linear-gradient(90deg, var(--green), color-mix(in srgb, var(--green) 30%, transparent));
    border-radius: 2px;
    transition: width 720ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .home-landing h2.drop-heading.section-title.is-visible::after,
  .home-landing .is-visible h2.drop-heading.section-title::after {
    width: clamp(2.5rem, 8vw, 5.5rem);
  }

  /* Fallback : si l'utilisateur préfère réduire les animations, on affiche le trait directement. */
  @media (prefers-reduced-motion : reduce) {
    .home-landing h2.drop-heading.section-title::after {
      width: clamp(2.5rem, 8vw, 5.5rem);
      transition: none;
    }
  }

  /* Sur mobile, garder le titre centré (le trait reste à gauche du bloc). */
  @media (max-width: 900px) {
    .pillars .container h2.drop-heading.section-title,
    .latest .container h2.drop-heading.section-title {
      display: inline-block;
    }
  }

  .editorial-intro .container,
  .pillars .container,
  .latest .container {
    width: min(1280px, calc(100% - 2rem));
    margin-inline: auto;
  }

  /* ── Décoration échiquier ── */
  .hero-deco {
    position: absolute;
    top: calc(var(--navbar-h) + 1.5rem);
    right: clamp(0.5rem, 4vw, 5rem);
    color: var(--green);
    opacity: 0.07;
    transform: rotate(12deg);
    pointer-events: none;
    user-select: none;
  }

  [data-theme="dark"] .hero-deco {
    opacity: 0.1;
  }

  /* ── Hero d’accueil : typo du site (Space Grotesk / Fraunces), fond = même grain que le body ── */
  .hero--classic {
    position: relative;
    padding: calc(var(--navbar-h) + 2.25rem) 0 3.25rem;
    text-align: center;
  }

  .hero--classic__inner {
    max-width: 42rem;
    margin-inline: auto;
  }

  .hero__sig {
    margin: 0 0 1rem;
    font-family: var(--font-display);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .hero__eyebrow {
    margin-bottom: 1rem;
  }

  .hero__title--classic {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.35rem, 8vw, 3.65rem);
    margin: 0 0 1rem;
    line-height: 1.08;
    letter-spacing: -0.035em;
    color: var(--text-main);
  }

  .hero__title--classic .hero__accent {
    color: var(--green);
    font-family: var(--font-serif);
    font-weight: 500;
    font-style: italic;
  }

  .hero__title--classic .hero__accent.display-serif {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 500;
  }

  .hero__lead--classic {
    margin: 0 auto;
    font-size: clamp(1rem, 2.4vw, 1.08rem);
    font-weight: 400;
    color: var(--text-muted);
    max-width: 38rem;
    line-height: 1.65;
  }

  .hero__actions--classic {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
    justify-content: center;
    margin-top: 1.5rem;
  }

  .hero-proof--classic {
    list-style: none;
    padding: 0;
    margin: 1.85rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    justify-content: center;
  }

  .hero-proof--classic li {
    padding: 0.38rem 0.78rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--border-soft);
    background: var(--surface);
    box-shadow: var(--shadow-xs);
    font-family: var(--font-display);
    font-size: 0.69rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--text-muted);
  }

  @media (max-width: 560px) {
    .hero__actions--classic {
      flex-direction: column;
      width: 100%;
      max-width: 20rem;
      margin-inline: auto;
      margin-top: 1.35rem;
    }

    .hero__actions--classic :global(.button-primary),
    .hero__actions--classic :global(.button-secondary) {
      width: 100%;
    }
  }

  .editorial-intro {
    padding: clamp(2.5rem, 6vw, 4rem) 0;
  }

  .editorial-intro__wrap {
    display: flex;
    justify-content: center;
  }

  .editorial-note--home {
    width: 100%;
    max-width: 40rem;
    margin-inline: auto;
    text-align: left;
    border: 1px solid var(--border-soft);
    border-radius: 3px;
    padding: 1.35rem 1.35rem 1.35rem 1.25rem;
    border-left: 4px solid var(--green);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
  }

  /* Titres type maquette : première lettre en vert (reste en noir via tokens). */
  .home-landing h2.drop-heading.section-title {
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 700;
    font-size: clamp(1.85rem, 4.8vw, 2.85rem);
    letter-spacing: -0.03em;
    line-height: 1.12;
    margin: 0 0 0.25rem;
    color: var(--text-main);
  }

  .home-landing h2.drop-heading.section-title::first-letter {
    color: var(--green);
    font-weight: 800;
    font-size: clamp(2.75rem, 9vw, 4.25rem);
    line-height: 0.85;
    margin-right: 0.02em;
  }

  .pillars {
    padding: clamp(2rem, 5vw, 3rem) 0 3.75rem;
  }

  .pillars .container {
    text-align: center;
  }

  .pillar-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(19rem, 1fr));
    gap: 1.35rem;
    margin-top: 2rem;
    align-items: stretch;
  }

  .pillar {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.55rem 1.45rem 1.5rem;
    min-height: 10.5rem;
    border-radius: 6px;
    border: 1px solid color-mix(in srgb, var(--p) 28%, var(--border-soft));
    background:
      linear-gradient(
        145deg,
        color-mix(in srgb, var(--p) 16%, var(--surface)) 0%,
        color-mix(in srgb, var(--pillar-surface, transparent) 55%, var(--surface)) 48%,
        var(--surface) 100%
      );
    box-shadow: var(--shadow-sm);
    transition:
      transform 240ms var(--ease-spring),
      border-color 180ms ease,
      box-shadow 240ms var(--ease-out);
    text-align: left;
    overflow: hidden;
  }

  /* Glyphe pièce d'échecs en filigrane derrière le contenu : signature visuelle. */
  .pillar__glyph {
    position: absolute;
    top: -0.6rem;
    right: 0.4rem;
    font-family: var(--font-serif);
    font-size: 6.5rem;
    line-height: 1;
    color: color-mix(in srgb, var(--p) 22%, transparent);
    pointer-events: none;
    user-select: none;
    transform: rotate(-6deg);
    transition: transform 380ms var(--ease-spring), color 240ms ease;
    z-index: 0;
  }

  .pillar > *:not(.pillar__glyph) {
    position: relative;
    z-index: 1;
  }

  .pillar:hover .pillar__glyph {
    transform: rotate(0deg) scale(1.08) translateY(-3px);
    color: color-mix(in srgb, var(--p) 36%, transparent);
  }

  .pillar:hover,
  .pillar:focus-visible {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--p) 55%, var(--border-soft));
    box-shadow: var(--shadow-md), 0 0 0 1px color-mix(in srgb, var(--p) 18%, transparent);
  }

  /* Anneau de focus net pour la navigation clavier (au-delà du décollement). */
  .pillar:focus-visible {
    outline: 2px solid var(--p);
    outline-offset: 3px;
  }

  /* prefers-reduced-motion : on coupe les transforms et transitions pour ce composant. */
  @media (prefers-reduced-motion : reduce) {
    .pillar,
    .pillar__glyph,
    .pillar__icon,
    .pillar__arrow {
      transition: none !important;
    }
    .pillar:hover,
    .pillar:focus-visible {
      transform: none;
    }
    .pillar:hover .pillar__glyph,
    .pillar:hover .pillar__icon,
    .pillar:hover .pillar__arrow {
      transform: none;
    }
  }

  /* Compteur d'articles : repère discret de la richesse de la rubrique. */
  .pillar__count {
    display: inline-flex;
    align-items: baseline;
    gap: 0.32rem;
    margin-top: 0.7rem;
    padding: 0.25rem 0.6rem 0.28rem;
    border-radius: var(--radius-pill);
    border: 1px solid color-mix(in srgb, var(--p) 30%, var(--border-soft));
    background: color-mix(in srgb, var(--p) 8%, var(--surface));
  }

  .pillar__count-num {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--p);
    line-height: 1;
  }

  .pillar__count-label {
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .pillar__icon {
    flex-shrink: 0;
    width: 2.85rem;
    height: 2.85rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    color: var(--p);
    background: color-mix(in srgb, var(--p) 14%, var(--surface));
    border: 1px solid color-mix(in srgb, var(--p) 22%, transparent);
    transition: transform 240ms var(--ease-spring), background 180ms ease;
  }

