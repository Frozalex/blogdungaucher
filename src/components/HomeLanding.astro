---
import AdBanner from "./AdBanner.astro";
import ArticleCard from "./ArticleCard.astro";
import { categoryMap, categorySlugs, siteConfig } from "../data/site";
import { swapLangPrefix } from "../utils/lang-paths";
import type { BlogEntry } from "../utils/blog";

interface Props {
  lang: "fr" | "en" | "de";
  latestPosts: BlogEntry[];
}

const { lang, latestPosts } = Astro.props;
const sectionsId = lang === "en" ? "sections" : "rubriques";
const blogHref = `/${lang}/blog/`;
const grandOralHref = `/${lang}/grand-oral/`;
const aboutHref = `/${lang}/about/`;
const analysesHref = `/${lang}/analyses/`;
const showAnalyses = siteConfig.features.analysesAvailable;

type HomeCopy = {
  siteName: string;
  signatureTagline: string;
  eyebrow: string;
  titleHtml: string;
  lead: string;
  startReading: string;
  seeSections: string;
  proofListLabel: string;
  proof1: string;
  proof2: string;
  proof3: string;
  quickNavLabel: string;
  quickEyebrow: string;
  blogLink: string;
  grandOralLink: string;
  analysesLink: string;
  aboutLink: string;
  editorialNote: string;
  editorialHeading: string;
  sectionsEyebrow: string;
  sectionsTitle: string;
  recentEyebrow: string;
  latestTitle: string;
  seeAll: string;
};

const homeByLang: Record<typeof lang, HomeCopy> = {
  fr: {
    siteName: "Blog d'un Gaucher",
    signatureTagline: "Science du jeu, esprit compétitif, échecs dans le monde réel.",
    eyebrow: "Éditorial indépendant",
    titleHtml:
      'Comprendre les <span class="hero__accent display-serif">échecs</span><br/>sans simplifier le jeu.',
    lead:
      "Chaque semaine, des analyses claires sur la science du jeu, le mental compétitif et l'impact des échecs dans la société, avec une approche humaine et exigeante.",
    startReading: "Commencer la lecture",
    seeSections: "Voir les rubriques",
    proofListLabel: "Repères éditoriaux",
    proof1: "Articles de fond",
    proof2: "Ton accessible",
    proof3: "Approche rigoureuse",
    quickNavLabel: "Raccourcis",
    quickEyebrow: "Raccourcis",
    blogLink: "Tous les articles",
    grandOralLink: "Grand oral",
    analysesLink: "Analyse Stockfish",
    aboutLink: "À propos",
    editorialNote:
      "Ici, on ne promet pas des progrès magiques en 7 jours. On propose des idées solides, des exemples concrets et des analyses que tu peux appliquer à ta pratique, que tu sois joueur de club, compétiteur ou simple passionné.",
    editorialHeading: "Notre ligne",
    sectionsEyebrow: "4 rubriques",
    sectionsTitle: "Ce dont on parle ici",
    recentEyebrow: "Récents",
    latestTitle: "Derniers articles",
    seeAll: "Tout voir →",
  },
  en: {
    siteName: "A Left-Hander's Blog",
    signatureTagline: "Game science, competitive mindset, chess in the real world.",
    eyebrow: "Independent editorial",
    titleHtml:
      'Understanding <span class="hero__accent display-serif">chess</span><br/>without oversimplifying.',
    lead:
      "Each week, clear analyses on the science of the game, the competitive mindset and the impact of chess on society, with a human and demanding approach.",
    startReading: "Start reading",
    seeSections: "See sections",
    proofListLabel: "Editorial markers",
    proof1: "In-depth articles",
    proof2: "Accessible tone",
    proof3: "Rigorous approach",
    quickNavLabel: "Shortcuts",
    quickEyebrow: "Shortcuts",
    blogLink: "All articles",
    grandOralLink: "Grand oral",
    analysesLink: "Stockfish Analysis",
    aboutLink: "About",
    editorialNote:
      "Here, we don't promise magical progress in 7 days. We offer solid ideas, concrete examples and analyses that you can apply to your practice, whether you're a club player, a competitor, or simply passionate about the game.",
    editorialHeading: "Our approach",
    sectionsEyebrow: "4 sections",
    sectionsTitle: "What we cover here",
    recentEyebrow: "Recent",
    latestTitle: "Latest articles",
    seeAll: "See all →",
  },
  de: {
    siteName: "Blog d'un Gaucher",
    signatureTagline: "Spielwissenschaft, Wettkampfgeist, Schach in der realen Welt.",
    eyebrow: "Unabhängiges Editorial",
    titleHtml:
      '<span class="hero__accent display-serif">Schach</span> verstehen<br/>ohne das Spiel zu vereinfachen.',
    lead:
      "Jede Woche klare Analysen zur Spielwissenschaft, zum Wettkampfgeist und zur Rolle des Schachs in der Gesellschaft, mit einem menschlichen und anspruchsvollen Ansatz.",
    startReading: "Zur Lektüre",
    seeSections: "Rubriken ansehen",
    proofListLabel: "Redaktionelle Merkmale",
    proof1: "Hintergrundartikel",
    proof2: "Zugänglicher Ton",
    proof3: "Rigoroser Ansatz",
    quickNavLabel: "Schnellzugriff",
    quickEyebrow: "Schnellzugriff",
    blogLink: "Alle Artikel",
    grandOralLink: "Grand oral",
    analysesLink: "Stockfish-Analyse",
    aboutLink: "Über die Seite",
    editorialNote:
      "Hier versprechen wir keinen magischen Fortschritt in 7 Tagen. Wir bieten solide Ideen, konkrete Beispiele und Analysen, die du in deine Praxis übernehmen kannst, egal ob Vereinsspieler, Turnierspieler oder begeisterter Amateur.",
    editorialHeading: "Unser Ansatz",
    sectionsEyebrow: "4 Rubriken",
    sectionsTitle: "Darum geht es hier",
    recentEyebrow: "Neu",
    latestTitle: "Neueste Artikel",
    seeAll: "Alle anzeigen →",
  },
};

const c = homeByLang[lang];
---

<div class="home-landing">
  <section class="hero hero--immersive" aria-labelledby="home-hero-heading">
    <div class="hero__backdrop" aria-hidden="true"></div>
    <div class="hero__noise" aria-hidden="true"></div>

    <div class="hero__shell">
      <header class="hero__top reveal scale-in">
        <p class="hero__brand hero__brand--dark">
          <span class="hero__brand-name" data-t="nav.siteName">{c.siteName}</span><span class="hero__brand-dot hero__brand-dot--glow" aria-hidden="true"></span>
        </p>
      </header>

      <div class="hero__center">
        <p class="hero__tagline hero__tagline--dark fade-up" style="--motion-delay: 30ms;" data-t="home.signatureTagline">
          {c.signatureTagline}
        </p>

        <p class="hero__kicker fade-up" style="--motion-delay: 55ms;" data-t="home.eyebrow">
          {c.eyebrow}
        </p>

        <h1
          id="home-hero-heading"
          class="hero__title hero__title--immersive fade-up"
          style="--motion-delay: 110ms;"
          data-t-html="home.titleHtml"
          set:html={c.titleHtml}
        ></h1>

        <p class="hero__lead hero__lead--dark fade-up" style="--motion-delay: 175ms;" data-t="home.lead">
          {c.lead}
        </p>

        <div class="hero__actions hero__actions--immersive fade-up" style="--motion-delay: 235ms;">
          <a href={blogHref} class="button-primary hero__cta-primary hero__cta--immersive" data-t="home.startReading">
            {c.startReading}
          </a>
          <a href={`#${sectionsId}`} class="hero__cta-ghost" data-t="home.seeSections">
            {c.seeSections}
          </a>
        </div>

        <ul
          class="hero-proof hero-proof--dark fade-up"
          style="--motion-delay: 300ms;"
          aria-label={c.proofListLabel}
        >
          <li data-t="home.proof1">{c.proof1}</li>
          <li data-t="home.proof2">{c.proof2}</li>
          <li data-t="home.proof3">{c.proof3}</li>
        </ul>
      </div>
    </div>
  </section>

  <nav class="home-quick container reveal" aria-label={c.quickNavLabel}>
    <span class="home-quick__label" data-t="home.quickEyebrow">{c.quickEyebrow}</span>
    <ul class="home-quick__list">
      <li>
        <a href={blogHref} class="home-quick__link" data-t="blog.title">
          {c.blogLink}
        </a>
      </li>
      <li>
        <a href={grandOralHref} class="home-quick__link" data-t="navLinks.grandOral">
          {c.grandOralLink}
        </a>
      </li>
      {showAnalyses && (
        <li>
          <a href={analysesHref} class="home-quick__link" data-t="categories.analyses.shortLabel">
            {c.analysesLink}
          </a>
        </li>
      )}
      <li>
        <a href={aboutHref} class="home-quick__link" data-t="navLinks.about">
          {c.aboutLink}
        </a>
      </li>
    </ul>
  </nav>

  <section class="editorial-intro">
    <div class="container editorial-intro__wrap">
      <h2 class="drop-heading section-title reveal" data-t="home.editorialHeading">
        {c.editorialHeading}
      </h2>
      <div class="editorial-note editorial-note--home reveal scale-in" data-t="home.editorialNote">
        {c.editorialNote}
      </div>
    </div>
  </section>

  <section class="pillars" id={sectionsId}>
    <div class="container">
      <span class="eyebrow reveal" data-t="home.sectionsEyebrow">
        {c.sectionsEyebrow}
      </span>
      <h2 class="drop-heading section-title reveal" data-t="home.sectionsTitle">
        {c.sectionsTitle}
      </h2>
      <div class="pillar-grid reveal-group">
        {
          categorySlugs.map((slug) => {
            const cat = categoryMap[slug];
            const href = lang === "fr" ? cat.href : swapLangPrefix(cat.href, lang);
            return (
              <a href={href} class="pillar" style={`--p:${cat.accent};`}>
                <span class="pillar__dot"></span>
                <div>
                  <span class="pillar__kicker" data-t={`categories.${slug}.shortLabel`}>
                    {cat.shortLabel}
                  </span>
                  <strong data-t={`categories.${slug}.label`}>{cat.label}</strong>
                  <p data-t={`categories.${slug}.tagline`}>{cat.tagline}</p>
                </div>
                <svg
                  class="pillar__arrow"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M5 12h14" />
                  <path d="M12 5l7 7-7 7" />
                </svg>
              </a>
            );
          })
        }
      </div>
    </div>
  </section>

  <div class="container">
    <AdBanner format="leaderboard" />
  </div>

  <section class="latest">
    <div class="container">
      <div class="section-head reveal">
        <div class="section-head__titles">
          <span class="eyebrow" data-t="home.recentEyebrow">
            {c.recentEyebrow}
          </span>
          <h2 class="drop-heading section-title" data-t="home.latestTitle">
            {c.latestTitle}
          </h2>
        </div>
        <a href={blogHref} class="see-all link-underline" data-t="home.seeAll">
          {c.seeAll}
        </a>
      </div>
      <div class="latest-grid reveal-group">
        {latestPosts.map((post, i) => <ArticleCard post={post} featured={i === 0} lang={lang} />)}
      </div>
    </div>
  </section>
</div>

<style>
  /* Hero plein écran sombre (réf. maquette) ; reste de page inchangé. */

  .home-landing {
    overflow-x: clip;
    background:
      radial-gradient(ellipse 100% 70% at 50% -15%, color-mix(in srgb, var(--green) 9%, transparent), transparent 52%),
      var(--bg);
  }

  [data-theme="dark"] .home-landing {
    background:
      radial-gradient(ellipse 100% 65% at 50% -12%, color-mix(in srgb, var(--green) 12%, transparent), transparent 50%),
      var(--bg);
  }

  .editorial-intro .container,
  .pillars .container,
  .latest .container,
  .home-quick.container {
    width: min(1280px, calc(100% - 2rem));
    margin-inline: auto;
  }

  /* ── Hero immersif (toujours sombre, indépendant du thème global) ── */
  .hero--immersive {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    max-width: none;
    color: #f2f5f2;
  }

  .hero__backdrop {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(ellipse 88% 62% at 50% 102%, rgba(61, 139, 55, 0.33), transparent 58%),
      radial-gradient(ellipse 52% 44% at 82% 18%, rgba(90, 178, 84, 0.16), transparent 52%),
      radial-gradient(ellipse 42% 38% at 10% 58%, rgba(56, 189, 248, 0.07), transparent 48%),
      radial-gradient(ellipse 65% 48% at 48% -8%, rgba(130, 220, 140, 0.09), transparent 46%),
      linear-gradient(168deg, #040705 0%, #070d0a 42%, #020302 100%);
  }

  .hero__backdrop::after {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 72% 58% at 50% 45%, transparent 28%, rgba(0, 0, 0, 0.78) 92%);
    pointer-events: none;
  }

  .hero__noise {
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: 0.09;
    pointer-events: none;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/></filter><rect width='100%25' height='100%25' filter='url(%23n)' opacity='0.55'/></svg>");
  }

  .hero__shell {
    position: relative;
    z-index: 2;
    width: min(1280px, calc(100% - 2rem));
    margin-inline: auto;
    min-height: min(92vh, 52rem);
    display: flex;
    flex-direction: column;
    padding: clamp(0.85rem, 2.5vw, 1.5rem) 0 clamp(2rem, 5vw, 3.25rem);
  }

  .hero__top {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }

  .hero__brand--dark {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.08rem, 2.6vw, 1.42rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: #fff;
    line-height: 1.2;
  }

  .hero__brand-name {
    display: inline;
  }

  .hero__brand-dot {
    display: inline-block;
    width: 0.38em;
    height: 0.38em;
    margin-left: 0.06em;
    border-radius: 50%;
    background: var(--green);
    vertical-align: 0.11em;
  }

  .hero__brand-dot--glow {
    box-shadow:
      0 0 14px color-mix(in srgb, var(--green) 75%, transparent),
      0 0 28px color-mix(in srgb, var(--green) 40%, transparent);
  }

  .hero__center {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: clamp(1.25rem, 4vw, 2.75rem) 0.75rem 0;
    max-width: 44rem;
    margin-inline: auto;
    width: 100%;
  }

  .hero__tagline--dark {
    margin: 0 0 1rem;
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(242, 245, 242, 0.45);
  }

  .hero__kicker {
    margin: 0 0 0.65rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(242, 245, 242, 0.38);
  }

  .hero__title--immersive {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2.4rem, 7.5vw, 4.15rem);
    margin: 0 0 1.05rem;
    line-height: 1.02;
    letter-spacing: -0.042em;
    color: #fff;
  }

  .hero__title--immersive .hero__accent {
    color: #8ddf86;
    font-weight: 800;
    font-style: normal;
    font-family: var(--font-display);
  }

  .hero__title--immersive .hero__accent.display-serif {
    font-family: var(--font-display);
    font-style: normal;
  }

  .hero__lead--dark {
    font-size: clamp(0.94rem, 2.2vw, 1.06rem);
    color: rgba(242, 245, 242, 0.74);
    max-width: 38rem;
    margin: 0 auto;
    line-height: 1.65;
  }

  .hero__actions--immersive {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    justify-content: center;
    margin-top: 1.9rem;
  }

  .hero__cta--immersive {
    border-radius: 2px;
    text-transform: uppercase;
    letter-spacing: 0.11em;
    font-size: 0.74rem;
    min-height: 2.8rem;
    padding-inline: 1.7rem;
    color: #fff !important;
    background: var(--green);
    border: none;
    box-shadow:
      0 0 26px color-mix(in srgb, var(--green) 42%, transparent),
      0 10px 32px rgba(0, 0, 0, 0.45);
  }

  .hero__cta--immersive:hover {
    background: var(--green-hover);
    color: #fff !important;
  }

  .hero__cta-ghost {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.8rem;
    padding: 0 1.35rem;
    border-radius: 2px;
    border: 1px solid rgba(255, 255, 255, 0.34);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.92);
    background: rgba(255, 255, 255, 0.05);
    transition:
      border-color 0.18s ease,
      background 0.18s ease,
      color 0.18s ease;
  }

  .hero__cta-ghost:hover {
    border-color: rgba(255, 255, 255, 0.52);
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
  }

  .hero-proof--dark {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    justify-content: center;
  }

  .hero-proof--dark li {
    padding: 0.32rem 0.72rem;
    border-radius: 2px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.06);
    color: rgba(242, 245, 242, 0.68);
    font-size: 0.69rem;
    font-weight: 600;
  }

  @media (max-width: 560px) {
    .hero__actions--immersive {
      flex-direction: column;
      width: 100%;
      max-width: 20rem;
    }

    .hero__cta--immersive,
    .hero__cta-ghost {
      width: 100%;
    }
  }

  .home-quick {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1.25rem;
    padding: 1.35rem 0 1.5rem;
    margin-bottom: 0.25rem;
    justify-content: center;
    border-bottom: 1px solid var(--border-soft);
  }

  .home-quick__label {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .home-quick__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.5rem;
    justify-content: center;
  }

  .home-quick__link {
    display: inline-flex;
    align-items: center;
    padding: 0.38rem 0.9rem;
    border-radius: 2px;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-muted);
    background: transparent;
    border: 1px solid transparent;
    transition:
      color 0.18s ease,
      border-color 0.18s ease,
      background 0.18s ease;
  }

  .home-quick__link:hover {
    color: var(--green-hover);
    border-color: var(--green-border);
    background: var(--green-light);
  }

  .editorial-intro {
    padding: clamp(2.5rem, 6vw, 4rem) 0;
  }

  .editorial-intro__wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
  }

  .editorial-note--home {
    width: 100%;
    max-width: 40rem;
    margin-inline: auto;
    text-align: left;
    border: 1px solid var(--border-soft);
    border-radius: 3px;
    padding: 1.35rem 1.35rem 1.35rem 1.25rem;
    border-left: 4px solid var(--green);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
  }

  /* Titres type maquette : première lettre massacrée en vert (reste en noir via tokens). */
  .home-landing h2.drop-heading.section-title {
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 700;
    font-size: clamp(1.85rem, 4.8vw, 2.85rem);
    letter-spacing: -0.03em;
    line-height: 1.12;
    margin: 0 0 0.25rem;
    color: var(--text-main);
  }

  .home-landing h2.drop-heading.section-title::first-letter {
    color: var(--green);
    font-weight: 800;
    font-size: clamp(2.75rem, 9vw, 4.25rem);
    line-height: 0.85;
    margin-right: 0.02em;
  }

  .pillars {
    padding: clamp(2rem, 5vw, 3rem) 0 3.75rem;
  }

  .pillars .container {
    text-align: center;
  }

  .pillar-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15.5rem, 1fr));
    gap: 1.15rem;
    margin-top: 1.75rem;
    align-items: stretch;
  }

  .pillar {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 1.35rem 1.25rem;
    border-radius: 3px;
    border: 1px solid var(--border-soft);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
    transition:
      transform 240ms var(--ease-spring),
      border-color 180ms ease,
      box-shadow 240ms var(--ease-out);
    text-align: left;
  }

  .pillar:hover {
    transform: translateY(-4px);
    border-color: var(--p);
    box-shadow: var(--shadow-md);
  }

  .pillar__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--p);
    flex-shrink: 0;
    margin-top: 0.4rem;
    transition: transform 240ms var(--ease-spring);
  }

  .pillar:hover .pillar__dot {
    transform: scale(1.45);
  }

  .pillar > div {
    flex: 1;
    min-width: 0;
  }

  .pillar__kicker {
    display: inline-flex;
    margin-bottom: 0.2rem;
    font-size: 0.64rem;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    color: var(--text-dim);
    font-weight: 700;
  }

  .pillar strong {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.94rem;
    color: var(--text-main);
    margin-bottom: 0.2rem;
  }

  .pillar p {
    font-size: 0.84rem;
    color: var(--text-muted);
