---
import AdBanner from "./AdBanner.astro";
import ArticleCard from "./ArticleCard.astro";
import { categoryMap, categorySlugs, siteConfig } from "../data/site";
import { swapLangPrefix } from "../utils/lang-paths";
import type { BlogEntry } from "../utils/blog";

interface Props {
  lang: "fr" | "en" | "de";
  latestPosts: BlogEntry[];
}

const { lang, latestPosts } = Astro.props;
const sectionsId = lang === "en" ? "sections" : "rubriques";
const blogHref = `/${lang}/blog/`;
const grandOralHref = `/${lang}/grand-oral/`;
const aboutHref = `/${lang}/about/`;
const analysesHref = `/${lang}/analyses/`;
const showAnalyses = siteConfig.features.analysesAvailable;

type HomeCopy = {
  siteName: string;
  signatureTagline: string;
  eyebrow: string;
  titleHtml: string;
  lead: string;
  startReading: string;
  seeSections: string;
  proofListLabel: string;
  proof1: string;
  proof2: string;
  proof3: string;
  quickNavLabel: string;
  quickEyebrow: string;
  blogLink: string;
  grandOralLink: string;
  analysesLink: string;
  aboutLink: string;
  editorialNote: string;
  editorialHeading: string;
  sectionsEyebrow: string;
  sectionsTitle: string;
  recentEyebrow: string;
  latestTitle: string;
  seeAll: string;
};

const homeByLang: Record<typeof lang, HomeCopy> = {
  fr: {
    siteName: "Blog d'un Gaucher",
    signatureTagline: "Science du jeu, esprit compétitif, échecs dans le monde réel.",
    eyebrow: "Éditorial indépendant",
    titleHtml:
      'Comprendre les <span class="hero__accent display-serif">échecs</span><br/>sans simplifier le jeu.',
    lead:
      "Chaque semaine, des analyses claires sur la science du jeu, le mental compétitif et l'impact des échecs dans la société, avec une approche humaine et exigeante.",
    startReading: "Commencer la lecture",
    seeSections: "Voir les rubriques",
    proofListLabel: "Repères éditoriaux",
    proof1: "Articles de fond",
    proof2: "Ton accessible",
    proof3: "Approche rigoureuse",
    quickNavLabel: "Raccourcis",
    quickEyebrow: "Raccourcis",
    blogLink: "Tous les articles",
    grandOralLink: "Grand oral",
    analysesLink: "Analyse Stockfish",
    aboutLink: "À propos",
    editorialNote:
      "Ici, on ne promet pas des progrès magiques en 7 jours. On propose des idées solides, des exemples concrets et des analyses que tu peux appliquer à ta pratique, que tu sois joueur de club, compétiteur ou simple passionné.",
    editorialHeading: "Notre ligne",
    sectionsEyebrow: "4 rubriques",
    sectionsTitle: "Ce dont on parle ici",
    recentEyebrow: "Récents",
    latestTitle: "Derniers articles",
    seeAll: "Tout voir →",
  },
  en: {
    siteName: "A Left-Hander's Blog",
    signatureTagline: "Game science, competitive mindset, chess in the real world.",
    eyebrow: "Independent editorial",
    titleHtml:
      'Understanding <span class="hero__accent display-serif">chess</span><br/>without oversimplifying.',
    lead:
      "Each week, clear analyses on the science of the game, the competitive mindset and the impact of chess on society, with a human and demanding approach.",
    startReading: "Start reading",
    seeSections: "See sections",
    proofListLabel: "Editorial markers",
    proof1: "In-depth articles",
    proof2: "Accessible tone",
    proof3: "Rigorous approach",
    quickNavLabel: "Shortcuts",
    quickEyebrow: "Shortcuts",
    blogLink: "All articles",
    grandOralLink: "Grand oral",
    analysesLink: "Stockfish Analysis",
    aboutLink: "About",
    editorialNote:
      "Here, we don't promise magical progress in 7 days. We offer solid ideas, concrete examples and analyses that you can apply to your practice, whether you're a club player, a competitor, or simply passionate about the game.",
    editorialHeading: "Our approach",
    sectionsEyebrow: "4 sections",
    sectionsTitle: "What we cover here",
    recentEyebrow: "Recent",
    latestTitle: "Latest articles",
    seeAll: "See all →",
  },
  de: {
    siteName: "Blog d'un Gaucher",
    signatureTagline: "Spielwissenschaft, Wettkampfgeist, Schach in der realen Welt.",
    eyebrow: "Unabhängiges Editorial",
    titleHtml:
      '<span class="hero__accent display-serif">Schach</span> verstehen<br/>ohne das Spiel zu vereinfachen.',
    lead:
      "Jede Woche klare Analysen zur Spielwissenschaft, zum Wettkampfgeist und zur Rolle des Schachs in der Gesellschaft, mit einem menschlichen und anspruchsvollen Ansatz.",
    startReading: "Zur Lektüre",
    seeSections: "Rubriken ansehen",
    proofListLabel: "Redaktionelle Merkmale",
    proof1: "Hintergrundartikel",
    proof2: "Zugänglicher Ton",
    proof3: "Rigoroser Ansatz",
    quickNavLabel: "Schnellzugriff",
    quickEyebrow: "Schnellzugriff",
    blogLink: "Alle Artikel",
    grandOralLink: "Grand oral",
    analysesLink: "Stockfish-Analyse",
    aboutLink: "Über die Seite",
    editorialNote:
      "Hier versprechen wir keinen magischen Fortschritt in 7 Tagen. Wir bieten solide Ideen, konkrete Beispiele und Analysen, die du in deine Praxis übernehmen kannst, egal ob Vereinsspieler, Turnierspieler oder begeisterter Amateur.",
    editorialHeading: "Unser Ansatz",
    sectionsEyebrow: "4 Rubriken",
    sectionsTitle: "Darum geht es hier",
    recentEyebrow: "Neu",
    latestTitle: "Neueste Artikel",
    seeAll: "Alle anzeigen →",
  },
};

const c = homeByLang[lang];
---

<div class="home-landing">
  <section class="hero" aria-labelledby="home-hero-heading">
    <div class="container hero__layout">
      <div class="hero__panel reveal scale-in">
        <div class="hero__panel-inner">
          <p class="hero__brand">
            <span class="hero__brand-name" data-t="nav.siteName">{c.siteName}</span><span class="hero__brand-dot" aria-hidden="true"></span>
          </p>
          <p class="hero__tagline" data-t="home.signatureTagline">
            {c.signatureTagline}
          </p>

          <span class="eyebrow hero__eyebrow fade-up" style="--motion-delay: 40ms;" data-t="home.eyebrow">
            {c.eyebrow}
          </span>

          <h1
            id="home-hero-heading"
            class="hero__title fade-up"
            style="--motion-delay: 120ms;"
            data-t-html="home.titleHtml"
            set:html={c.titleHtml}
          ></h1>

          <p class="hero__lead fade-up" style="--motion-delay: 190ms;" data-t="home.lead">
            {c.lead}
          </p>

          <div class="hero__actions fade-up" style="--motion-delay: 250ms;">
            <a href={blogHref} class="button-primary hero__cta-primary" data-t="home.startReading">
              {c.startReading}
            </a>
            <a href={`#${sectionsId}`} class="button-secondary hero__cta-secondary" data-t="home.seeSections">
              {c.seeSections}
            </a>
          </div>

          <ul
            class="hero-proof fade-up"
            style="--motion-delay: 320ms;"
            aria-label={c.proofListLabel}
          >
            <li data-t="home.proof1">{c.proof1}</li>
            <li data-t="home.proof2">{c.proof2}</li>
            <li data-t="home.proof3">{c.proof3}</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <nav class="home-quick container reveal" aria-label={c.quickNavLabel}>
    <span class="home-quick__label" data-t="home.quickEyebrow">{c.quickEyebrow}</span>
    <ul class="home-quick__list">
      <li>
        <a href={blogHref} class="home-quick__link" data-t="blog.title">
          {c.blogLink}
        </a>
      </li>
      <li>
        <a href={grandOralHref} class="home-quick__link" data-t="navLinks.grandOral">
          {c.grandOralLink}
        </a>
      </li>
      {showAnalyses && (
        <li>
          <a href={analysesHref} class="home-quick__link" data-t="categories.analyses.shortLabel">
            {c.analysesLink}
          </a>
        </li>
      )}
      <li>
        <a href={aboutHref} class="home-quick__link" data-t="navLinks.about">
          {c.aboutLink}
        </a>
      </li>
    </ul>
  </nav>

  <section class="editorial-intro">
    <div class="container editorial-intro__wrap">
      <h2 class="drop-heading section-title reveal" data-t="home.editorialHeading">
        {c.editorialHeading}
      </h2>
      <div class="editorial-note editorial-note--home reveal scale-in" data-t="home.editorialNote">
        {c.editorialNote}
      </div>
    </div>
  </section>

  <section class="pillars" id={sectionsId}>
    <div class="container">
      <span class="eyebrow reveal" data-t="home.sectionsEyebrow">
        {c.sectionsEyebrow}
      </span>
      <h2 class="drop-heading section-title reveal" data-t="home.sectionsTitle">
        {c.sectionsTitle}
      </h2>
      <div class="pillar-grid reveal-group">
        {
          categorySlugs.map((slug) => {
            const cat = categoryMap[slug];
            const href = lang === "fr" ? cat.href : swapLangPrefix(cat.href, lang);
            return (
              <a href={href} class="pillar" style={`--p:${cat.accent};`}>
                <span class="pillar__dot"></span>
                <div>
                  <span class="pillar__kicker" data-t={`categories.${slug}.shortLabel`}>
                    {cat.shortLabel}
                  </span>
                  <strong data-t={`categories.${slug}.label`}>{cat.label}</strong>
                  <p data-t={`categories.${slug}.tagline`}>{cat.tagline}</p>
                </div>
                <svg
                  class="pillar__arrow"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M5 12h14" />
                  <path d="M12 5l7 7-7 7" />
                </svg>
              </a>
            );
          })
        }
      </div>
    </div>
  </section>

  <div class="container">
    <AdBanner format="leaderboard" />
  </div>

  <section class="latest">
    <div class="container">
      <div class="section-head reveal">
        <div class="section-head__titles">
          <span class="eyebrow" data-t="home.recentEyebrow">
            {c.recentEyebrow}
          </span>
          <h2 class="drop-heading section-title" data-t="home.latestTitle">
            {c.latestTitle}
          </h2>
        </div>
        <a href={blogHref} class="see-all link-underline" data-t="home.seeAll">
          {c.seeAll}
        </a>
      </div>
      <div class="latest-grid reveal-group">
        {latestPosts.map((post, i) => <ArticleCard post={post} featured={i === 0} lang={lang} />)}
      </div>
    </div>
  </section>
</div>

<style>
  /* Fond page léger (sans canvas ciné) + panneau hero, lettrines, cartes nettes. */

  .home-landing {
    background:
      radial-gradient(ellipse 100% 70% at 50% -15%, color-mix(in srgb, var(--green) 9%, transparent), transparent 52%),
      var(--bg);
  }

  [data-theme="dark"] .home-landing {
    background:
      radial-gradient(ellipse 100% 65% at 50% -12%, color-mix(in srgb, var(--green) 12%, transparent), transparent 50%),
      var(--bg);
  }

  .hero {
    position: relative;
    min-height: min(88vh, 46rem);
    display: flex;
    align-items: center;
    padding: clamp(4rem, 10vw, 5.5rem) 0 2.5rem;
  }

  .hero .container,
  .editorial-intro .container,
  .pillars .container,
  .latest .container,
  .home-quick.container {
    width: min(1280px, calc(100% - 2rem));
    margin-inline: auto;
  }

  .hero__layout {
    display: flex;
    justify-content: center;
    width: 100%;
    max-width: min(1200px, 100%);
    margin-inline: auto;
  }

  .hero__panel {
    width: 100%;
    max-width: 28rem;
    border-radius: 3px;
    box-shadow:
      0 2px 0 color-mix(in srgb, var(--green) 18%, transparent),
      0 18px 44px rgba(24, 18, 12, 0.09);
  }

  [data-theme="dark"] .hero__panel {
    box-shadow:
      0 2px 0 color-mix(in srgb, var(--green) 30%, transparent),
      0 24px 56px rgba(0, 0, 0, 0.45);
  }

  .hero__panel-inner {
    border-radius: 3px;
    padding: clamp(1.85rem, 4.5vw, 2.75rem) clamp(1.4rem, 3.5vw, 2rem);
    background: var(--surface);
    border: 1px solid var(--border-soft);
    text-align: center;
    position: relative;
  }

  .hero__brand {
    margin: 0 0 0.35rem;
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 2.8vw, 1.45rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text-main);
    line-height: 1.2;
  }

  .hero__brand-name {
    display: inline;
  }

  .hero__brand-dot {
    display: inline-block;
    width: 0.38em;
    height: 0.38em;
    margin-left: 0.06em;
    border-radius: 50%;
    background: var(--green);
    vertical-align: 0.12em;
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--green) 25%, transparent);
  }

  .hero__tagline,
  .hero__eyebrow,
  .hero__title,
  .hero__lead,
  .hero__actions,
  .hero-proof {
    position: relative;
    z-index: 1;
  }

  .hero__tagline {
    margin: 0 0 1.35rem;
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .hero__eyebrow {
    margin-bottom: 0.4rem;
  }

  .hero__title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2rem, 5.2vw, 3.35rem);
    margin: 0.5rem 0 1rem;
    line-height: 1.05;
    letter-spacing: -0.035em;
  }

  .hero__accent {
    color: var(--green);
    font-size: 1.05em;
    font-weight: 800;
  }

  .hero__lead {
    font-size: 1rem;
    color: var(--text-muted);
    max-width: 26rem;
    margin-inline: auto;
    line-height: 1.7;
  }

  .hero__actions {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-top: 1.65rem;
    justify-content: center;
  }

  .hero__cta-primary {
    border-radius: 2px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
    min-height: 2.65rem;
    padding-inline: 1.5rem;
    box-shadow: 0 6px 20px rgba(61, 139, 55, 0.28);
  }

  .hero__cta-secondary {
    border-radius: 2px;
    font-size: 0.82rem;
  }

  .hero-proof {
    list-style: none;
    padding: 0;
    margin: 1.45rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    justify-content: center;
  }

  .hero-proof li {
    padding: 0.28rem 0.65rem;
    border-radius: 2px;
    border: 1px solid var(--border-soft);
    background: var(--surface-warm);
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 600;
  }

  @media (min-width: 960px) {
    .hero__layout {
      justify-content: flex-start;
      padding-inline: 0.25rem;
    }

    .hero__panel {
      max-width: min(28rem, 92vw);
    }

    .hero__panel-inner {
      text-align: left;
    }

    .hero__lead {
      margin-inline: 0;
    }

    .hero__actions {
      justify-content: flex-start;
    }

    .hero-proof {
      justify-content: flex-start;
    }
  }

  .home-quick {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1.25rem;
    padding: 1.35rem 0 1.5rem;
    margin-bottom: 0.25rem;
    justify-content: center;
    border-bottom: 1px solid var(--border-soft);
  }

  .home-quick__label {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .home-quick__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.5rem;
    justify-content: center;
  }

  .home-quick__link {
    display: inline-flex;
    align-items: center;
    padding: 0.38rem 0.9rem;
    border-radius: 2px;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-muted);
    background: transparent;
    border: 1px solid transparent;
    transition:
      color 0.18s ease,
      border-color 0.18s ease,
      background 0.18s ease;
  }

  .home-quick__link:hover {
    color: var(--green-hover);
    border-color: var(--green-border);
    background: var(--green-light);
  }

  .editorial-intro {
    padding: clamp(2.5rem, 6vw, 4rem) 0;
  }

  .editorial-intro__wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
  }

  .editorial-note--home {
    width: 100%;
    max-width: 40rem;
    margin-inline: auto;
    text-align: left;
    border: 1px solid var(--border-soft);
    border-radius: 3px;
    padding: 1.35rem 1.35rem 1.35rem 1.25rem;
    border-left: 4px solid var(--green);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
  }

  /* Titres type maquette : première lettre massacrée en vert (reste en noir via tokens). */
  .home-landing h2.drop-heading.section-title {
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 700;
    font-size: clamp(1.85rem, 4.8vw, 2.85rem);
    letter-spacing: -0.03em;
    line-height: 1.12;
    margin: 0 0 0.25rem;
    color: var(--text-main);
  }

  .home-landing h2.drop-heading.section-title::first-letter {
    color: var(--green);
    font-weight: 800;
    font-size: clamp(2.75rem, 9vw, 4.25rem);
    line-height: 0.85;
    margin-right: 0.02em;
  }

  .pillars {
    padding: clamp(2rem, 5vw, 3rem) 0 3.75rem;
  }

  .pillars .container {
    text-align: center;
  }

  .pillar-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15.5rem, 1fr));
    gap: 1.15rem;
    margin-top: 1.75rem;
    align-items: stretch;
  }

  .pillar {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 1.35rem 1.25rem;
    border-radius: 3px;
    border: 1px solid var(--border-soft);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
    transition:
      transform 240ms var(--ease-spring),
      border-color 180ms ease,
      box-shadow 240ms var(--ease-out);
    text-align: left;
  }

  .pillar:hover {
    transform: translateY(-4px);
    border-color: var(--p);
    box-shadow: var(--shadow-md);
  }

  .pillar__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--p);
    flex-shrink: 0;
    margin-top: 0.4rem;
    transition: transform 240ms var(--ease-spring);
  }

  .pillar:hover .pillar__dot {
    transform: scale(1.45);
  }

  .pillar > div {
    flex: 1;
    min-width: 0;
  }

  .pillar__kicker {
    display: inline-flex;
    margin-bottom: 0.2rem;
    font-size: 0.64rem;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    color: var(--text-dim);
    font-weight: 700;
  }

  .pillar strong {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.94rem;
    color: var(--text-main);
    margin-bottom: 0.2rem;
  }

  .pillar p {
    font-size: 0.84rem;
    color: var(--text-muted);
    line-height: 1.55;
    margin: 0;
  }

  .pillar__arrow {
    color: var(--text-dim);
    flex-shrink: 0;
    margin-top: 0.2rem;
    transition:
      color 180ms ease,
      transform 240ms var(--ease-spring);
  }

  .pillar:hover .pillar__arrow {
    color: var(--p);
    transform: translateX(3px);
  }

  .latest {
    padding: clamp(2rem, 5vw, 3rem) 0 5.5rem;
  }

  .latest .container {
    text-align: center;
  }

  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.65rem;
    max-width: 72rem;
    margin-inline: auto;
  }

  .section-head__titles {
    text-align: left;
  }

  .section-head .drop-heading {
    margin-bottom: 0;
  }

  .see-all {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-muted);
    transition: color 160ms ease;
  }

  .see-all:hover {
    color: var(--green);
  }

  .latest-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.15rem;
    text-align: left;
    max-width: 72rem;
    margin-inline: auto;
  }

  .latest-grid > :global(.card) {
    box-shadow: var(--shadow-md);
    border-radius: 3px;
    border-width: 1px;
  }

  .latest-grid > :first-child {
    grid-column: 1 / -1;
  }

  @media (max-width: 900px) {
    .latest-grid {
      grid-template-columns: 1fr;
    }
    .latest-grid > :first-child {
      grid-column: auto;
    }
    .section-head {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .section-head__titles {
      text-align: center;
    }
  }

  @media (max-width: 560px) {
    .hero {
      min-height: unset;
      padding: 3.5rem 0 2rem;
    }
    .hero .container,
    .editorial-intro .container,
    .pillars .container,
    .latest .container,
    .home-quick.container {
      width: min(1280px, calc(100% - 1.25rem));
    }
    .hero-proof li {
      font-size: 0.68rem;
    }
    .home-quick {
      flex-direction: column;
      gap: 0.65rem;
    }
    .hero__panel {
      max-width: 100%;
    }
  }
</style>
