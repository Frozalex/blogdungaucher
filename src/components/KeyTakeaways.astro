---
interface Props {
  items: string[];
  accentColor?: string;
}
const { items, accentColor } = Astro.props;
---

<aside
  class="key-takeaways"
  aria-label="Points essentiels de l'article"
  style={accentColor ? `--kt-c:${accentColor}` : ""}
>
  <header class="kt-header">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="20 6 9 17 4 12"/>
    </svg>
    L'essentiel
  </header>
  <ul class="kt-list">
    {items.map((item) => (
      <li class="kt-item">{item}</li>
    ))}
  </ul>
</aside>

<style>
  .key-takeaways {
    --kt-c: var(--green);
    margin: 1.5rem 0 1.75rem;
    padding: 1.1rem 1.3rem 1.15rem;
    border-radius: var(--radius-md);
    border: 1px solid color-mix(in srgb, var(--kt-c) 24%, var(--border-soft));
    border-left: 3px solid var(--kt-c);
    background: color-mix(in srgb, var(--kt-c) 5%, var(--surface));
  }

  .kt-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    color: var(--kt-c);
  }

  .kt-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.55rem;
  }

  .kt-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.55rem;
    font-size: 0.91rem;
    color: var(--text-muted);
    line-height: 1.58;
  }

  .kt-item::before {
    content: "→";
    color: var(--kt-c);
    font-size: 0.78em;
    font-weight: 700;
    margin-top: 0.28em;
    flex-shrink: 0;
  }
</style>
