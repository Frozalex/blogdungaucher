---
/**
 * Fond cinématique pleine page (sticky viewport) pour l’accueil uniquement.
 * Images locales CC0 / Unsplash — voir commentaires dans le script.
 */
---

<div class="home-cinematic">
  <div class="home-cinematic__pin" aria-hidden="true">
    <div class="cinematic-aurora">
      <span class="aurora-orb aurora-orb--a"></span>
      <span class="aurora-orb aurora-orb--b"></span>
      <span class="aurora-orb aurora-orb--c"></span>
    </div>
    <canvas class="cinematic-canvas" id="homeCinematicCanvas" width="800" height="600"></canvas>
  </div>
  <div class="home-cinematic__stack">
    <slot />
  </div>
</div>

<style>
  /* Grille : fond sticky derrière tout le contenu de la page d’accueil */
  .home-cinematic {
    display: grid;
    grid-template-columns: 1fr;
    isolation: isolate;
  }

  .home-cinematic__pin {
    grid-column: 1;
    grid-row: 1;
    position: sticky;
    top: 0;
    height: 100vh;
    height: 100dvh;
    width: 100%;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  /* Lisibilité : fond animé plus discret en mode clair */
  [data-theme="light"] .home-cinematic__pin {
    opacity: 0.42;
  }
  [data-theme="dark"] .home-cinematic__pin {
    opacity: 1;
  }

  .home-cinematic__stack {
    grid-column: 1;
    grid-row: 1;
    position: relative;
    z-index: 1;
  }

  .cinematic-aurora {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .aurora-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(72px);
    will-change: transform;
  }

  .aurora-orb--a {
    width: min(62vw, 680px);
    height: min(52vw, 540px);
    left: -15%;
    top: -25%;
    background: color-mix(in srgb, var(--green) 12%, transparent);
    animation: auroraA 18s ease-in-out infinite alternate;
  }

  .aurora-orb--b {
    width: min(48vw, 520px);
    height: min(42vw, 450px);
    right: -10%;
    bottom: -20%;
    background: color-mix(in srgb, var(--green) 8%, transparent);
    animation: auroraB 22s ease-in-out infinite alternate;
  }

  .aurora-orb--c {
    width: min(36vw, 380px);
    height: min(32vw, 340px);
    left: 30%;
    top: 55%;
    background: color-mix(in srgb, var(--green) 6%, transparent);
    animation: auroraA 15s ease-in-out 4s infinite alternate-reverse;
  }

  .cinematic-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    z-index: 1;
  }

  @keyframes auroraA {
    0% {
      transform: translate(0, 0) scale(1);
    }
    40% {
      transform: translate(6%, 10%) scale(1.07);
    }
    100% {
      transform: translate(-3%, 6%) scale(0.95);
    }
  }

  @keyframes auroraB {
    0% {
      transform: translate(0, 0) scale(1);
    }
    40% {
      transform: translate(-7%, -9%) scale(1.1);
    }
    100% {
      transform: translate(4%, -4%) scale(0.93);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .aurora-orb {
      animation: none;
    }
  }
</style>

<script>
  /* Images locales — dérivées de photos Unsplash (licence Unsplash) :
     scène 1 & 3 : https://unsplash.com/photos/1529699211952 (échiquier)
     scène 2 : https://unsplash.com/photos/1576610616656 (pièces / ambiance)
     — conserver les crédits sur la page Unsplash du photographe si republication. */
  ;(function () {
    const canvas = document.getElementById("homeCinematicCanvas");
    if (!(canvas instanceof HTMLCanvasElement)) return;
    const ctx = canvas.getContext("2d", { alpha: true });
    if (!ctx) return;

    const REDUCED = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let W = 0;
    let H = 0;

    type RGB = [number, number, number];
    interface Scene {
      bg: string;
      accent: RGB;
      imageSrc: string;
    }

    const SCENES: Scene[] = [
      {
        bg: "#070605",
        accent: [200, 162, 38],
        imageSrc: "/images/home-cinematic/scene-1-chess.jpg",
      },
      {
        bg: "#030a03",
        accent: [52, 140, 50],
        imageSrc: "/images/home-cinematic/scene-2-chess.jpg",
      },
      {
        bg: "#0a0303",
        accent: [190, 40, 35],
        imageSrc: "/images/home-cinematic/scene-3-chess.jpg",
      },
    ];

    const SCENE_DUR = 5.2;
    const WIPE_DUR = 0.9;
    const REV_START = 0.12;
    const REV_END = 0.76;
    const TAN35 = Math.tan((35 * Math.PI) / 180);

    const bokeh = Array.from({ length: 22 }, () => ({
      x: Math.random() * 1.2 - 0.1,
      y: Math.random() * 1.2 - 0.1,
      r: 5 + Math.random() * 16,
      vx: (Math.random() - 0.5) * 1.8e-4,
      vy: -(5e-5 + Math.random() * 1.5e-4),
      a: 0.06 + Math.random() * 0.14,
      ph: Math.random() * Math.PI * 2,
      ps: 0.4 + Math.random() * 0.9,
    }));

    const imgs: HTMLImageElement[] = [];
    let imagesReady = false;

    function loadImages(onDone: () => void) {
      let left = SCENES.length;
      for (let i = 0; i < SCENES.length; i++) {
        const im = new Image();
        im.decoding = "async";
        im.onload = im.onerror = () => {
          left--;
          if (left <= 0) onDone();
        };
        im.src = SCENES[i].imageSrc;
        imgs.push(im);
      }
    }

    function resize() {
      const pin = canvas.closest(".home-cinematic__pin") as HTMLElement | null;
      if (!pin) return;
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      W = pin.clientWidth;
      H = pin.clientHeight;
      canvas.width = Math.max(1, Math.floor(W * dpr));
      canvas.height = Math.max(1, Math.floor(H * dpr));
      canvas.style.width = `${W}px`;
      canvas.style.height = `${H}px`;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function isDark() {
      return document.documentElement.dataset.theme === "dark";
    }

    function drawImageCover(
      img: HTMLImageElement,
      grayStrength: number /* 0..1 */,
      zoom: number,
      panX: number,
      panY: number,
    ) {
      if (!img.naturalWidth) return;
      const iw = img.naturalWidth;
      const ih = img.naturalHeight;
      const scale = (Math.max(W / iw, H / ih) * zoom);
      const dw = iw * scale;
      const dh = ih * scale;
      const cx = (W - dw) / 2 + panX;
      const cy = (H - dh) / 2 + panY;
      if (grayStrength >= 0.99) {
        ctx.filter = isDark()
          ? "grayscale(1) brightness(0.42) contrast(1.05)"
          : "grayscale(1) brightness(0.72) contrast(1.02)";
      } else if (grayStrength > 0) {
        const g = grayStrength;
        ctx.filter = `grayscale(${g}) brightness(${isDark() ? 0.42 + 0.2 * (1 - g) : 0.72 + 0.15 * (1 - g)})`;
      } else {
        ctx.filter = "none";
      }
      ctx.drawImage(img, cx, cy, dw, dh);
      ctx.filter = "none";
    }

    function clipReveal(revFrac: number) {
      const span = W + H * TAN35;
      const front = Math.min(revFrac * span * 1.05, span + 2);
      const topX = Math.min(W, front);
      const bottomX = Math.max(0, front - H * TAN35);
      const rightY = front > W ? Math.min(H, (front - W) / TAN35) : 0;
      ctx.beginPath();
      ctx.moveTo(0, 0);
      ctx.lineTo(topX, 0);
      if (front > W) ctx.lineTo(W, rightY);
      if (front >= W + H * TAN35) ctx.lineTo(W, H);
      ctx.lineTo(bottomX, H);
      ctx.lineTo(0, H);
      ctx.closePath();
      ctx.clip();
    }

    function drawWipe(wipeFrac: number, nextIndex: number, dark: boolean) {
      const next = SCENES[nextIndex];
      const img = imgs[nextIndex];
      const leadX = W * (1 - wipeFrac) + W * 0.06;
      const slant = H * TAN35;
      const [nr, ng, nb] = next.accent;
      ctx.save();
      ctx.beginPath();
      ctx.moveTo(leadX - slant, H);
      ctx.lineTo(leadX, 0);
      ctx.lineTo(W + 12, 0);
      ctx.lineTo(W + 12, H);
      ctx.closePath();
      ctx.clip();
      if (dark) {
        ctx.fillStyle = next.bg;
        ctx.fillRect(0, 0, W, H);
      }
      if (img.naturalWidth) drawImageCover(img, 1, 1, 0, 0);
      const grd = ctx.createLinearGradient(leadX - slant - 64, 0, leadX + 4, 0);
      grd.addColorStop(0, `rgba(${nr},${ng},${nb},0)`);
      grd.addColorStop(1, `rgba(${nr},${ng},${nb},0.55)`);
      ctx.fillStyle = grd;
      ctx.fillRect(0, 0, W, H);
      ctx.restore();
      ctx.globalAlpha = 1;
    }

    function drawBokeh(scene: Scene, dark: boolean) {
      const [ar, ag, ab] = scene.accent;
      const scale = dark ? 1 : 0.45;
      for (const p of bokeh) {
        p.x += p.vx;
        p.y += p.vy;
        p.ph += p.ps * 0.016;
        if (p.y < -0.12) {
          p.y = 1.1;
          p.x = Math.random() * 1.2 - 0.1;
        }
        if (p.x < -0.12) p.x = 1.1;
        if (p.x > 1.12) p.x = -0.1;
        const px = p.x * W;
        const py = p.y * H;
        const pr = Math.max(1, p.r * (0.72 + 0.28 * Math.sin(p.ph)) * scale);
        const pa = p.a * (0.5 + 0.5 * Math.sin(p.ph * 0.7)) * scale;
        const grd = ctx.createRadialGradient(px, py, 0, px, py, pr);
        grd.addColorStop(0, `rgba(${ar},${ag},${ab},${pa.toFixed(3)})`);
        grd.addColorStop(0.45, `rgba(255,255,255,${(pa * 0.28).toFixed(3)})`);
        grd.addColorStop(1, "rgba(0,0,0,0)");
        ctx.beginPath();
        ctx.arc(px, py, pr, 0, Math.PI * 2);
        ctx.fillStyle = grd;
        ctx.fill();
      }
    }

    function drawVignette() {
      const grd = ctx.createRadialGradient(
        W * 0.5,
        H * 0.42,
        Math.min(W, H) * 0.05,
        W * 0.5,
        H * 0.52,
        Math.max(W, H) * 0.82,
      );
      grd.addColorStop(0, "rgba(0,0,0,0)");
      grd.addColorStop(1, "rgba(0,0,0,0.58)");
      ctx.fillStyle = grd;
      ctx.fillRect(0, 0, W, H);
    }

    let t0 = 0;
    function drawFrame(ts: number) {
      if (!t0) t0 = ts;
      const t = (ts - t0) / 1000;
      const dark = isDark();
      const cycle = SCENES.length * SCENE_DUR;
      const ct = t % cycle;
      const si = Math.floor(ct / SCENE_DUR) % SCENES.length;
      const st = ct % SCENE_DUR;
      const sf = st / SCENE_DUR;
      const scene = SCENES[si];
      const nextIndex = (si + 1) % SCENES.length;
      const img = imgs[si];

      ctx.clearRect(0, 0, W, H);
      if (!imagesReady || !img.naturalWidth) {
        ctx.fillStyle = scene.bg;
        ctx.fillRect(0, 0, W, H);
        requestAnimationFrame(drawFrame);
        return;
      }

      const kb = 1 + sf * 0.045;
      const panX = Math.sin(t * 0.31) * 14;
      const panY = Math.cos(t * 0.27) * 10;
      const revFrac = Math.max(0, Math.min(1, (sf - REV_START) / (REV_END - REV_START)));

      if (dark) {
        ctx.fillStyle = scene.bg;
        ctx.fillRect(0, 0, W, H);
      }

      drawImageCover(img, 1, kb, panX * 0.35, panY * 0.35);

      ctx.save();
      clipReveal(revFrac);
      drawImageCover(img, 0, kb, panX * 0.35, panY * 0.35);
      ctx.restore();

      const wipeStart = 1 - WIPE_DUR / SCENE_DUR;
      if (sf >= wipeStart) {
        const wf = Math.min(1, (sf - wipeStart) / (WIPE_DUR / SCENE_DUR));
        drawWipe(wf, nextIndex, dark);
      }

      drawBokeh(scene, dark);
      if (dark) drawVignette();

      requestAnimationFrame(drawFrame);
    }

    function init() {
      resize();
      const ro = new ResizeObserver(() => resize());
      const pin = canvas.closest(".home-cinematic__pin");
      if (pin) ro.observe(pin);

      window.addEventListener("resize", resize, { passive: true });
      new MutationObserver(resize).observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["data-theme"],
      });

      loadImages(() => {
        imagesReady = true;
        resize();
      });

      if (REDUCED) {
        resize();
        const dark = isDark();
        const s = SCENES[0];
        const im = imgs[0];
        const paintStill = () => {
          ctx.clearRect(0, 0, W, H);
          if (dark) {
            ctx.fillStyle = s.bg;
            ctx.fillRect(0, 0, W, H);
          }
          if (im.naturalWidth) {
            drawImageCover(im, 0.5, 1, 0, 0);
          }
          if (dark) drawVignette();
        };
        paintStill();
        window.addEventListener("resize", paintStill, { passive: true });
        return;
      }

      requestAnimationFrame(drawFrame);
    }

    init();
  })();
</script>
