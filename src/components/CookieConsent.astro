<!-- ── Backdrop ──────────────────────────────────────────────── -->
<div class="consent-backdrop" id="consent-backdrop" hidden aria-hidden="true"></div>

<!-- ── Modal de consentement ──────────────────────────────── -->
<div
  class="consent-panel"
  id="consent-panel"
  role="dialog"
  aria-modal="true"
  aria-labelledby="consent-title"
  hidden
>
  <div class="consent-header">
    <img
      src="/images/logo.svg"
      alt=""
      aria-hidden="true"
      class="consent-logo"
      width="20"
      height="28"
      loading="eager"
      decoding="sync"
    />
    <span class="consent-site">Blog d'un Gaucher</span>
  </div>

  <h2 class="consent-title" id="consent-title">Vos préférences de confidentialité</h2>

  <p class="consent-text">
    Ce site utilise des <strong>cookies</strong> pour mesurer l'audience (Google Analytics) et afficher des publicités (Google AdSense). Les <strong>notifications push</strong> sont indépendantes des cookies et entièrement optionnelles.
  </p>

  <div class="consent-quick">
    <button type="button" class="consent-btn consent-btn--primary" id="consent-accept">
      Accepter tout
    </button>
    <button type="button" class="consent-btn consent-btn--ghost" id="consent-reject">
      Tout refuser
    </button>
  </div>

  <details class="consent-details" id="consent-customize-details">
    <summary class="consent-summary">
      <span>Personnaliser mes choix</span>
      <svg
        class="consent-chevron"
        width="14" height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M6 9l6 6 6-6"/>
      </svg>
    </summary>

    <fieldset class="consent-fieldset">
      <legend class="consent-fieldset__legend">Choisir par catégorie</legend>

      <label class="consent-option">
        <input type="checkbox" id="cookie-analytics" class="consent-checkbox" />
        <span class="consent-option__body">
          <strong class="consent-option__name">Mesure d'audience</strong>
          <span class="consent-option__desc">Google Analytics — comprendre combien de personnes lisent le blog et quels articles intéressent le plus</span>
        </span>
      </label>

      <label class="consent-option">
        <input type="checkbox" id="cookie-marketing" class="consent-checkbox" />
        <span class="consent-option__body">
          <strong class="consent-option__name">Publicité</strong>
          <span class="consent-option__desc">Google AdSense — permet de financer la création de contenus gratuits</span>
        </span>
      </label>

      <label class="consent-option">
        <input type="checkbox" id="cookie-notifications" class="consent-checkbox" />
        <span class="consent-option__body">
          <strong class="consent-option__name">Notifications push</strong>
          <span class="consent-option__desc">Alerte navigateur à chaque nouvel article (2 par semaine). Le navigateur demandera confirmation. Révocable à tout moment.</span>
        </span>
      </label>
    </fieldset>

    <div class="consent-save-wrap">
      <button type="button" class="consent-btn consent-btn--save" id="consent-save">
        Enregistrer mes choix
      </button>
    </div>
  </details>

  <p class="consent-footer-note">
    Modifiable à tout moment via « Notifications et cookies » en bas de page.
    <a href="/fr/politique-confidentialite/" class="consent-privacy-link">Politique de confidentialité →</a>
  </p>
</div>

<!--
  Déclencheur programmatique (utilisé par le footer).
  Invisible et non-interactif pour l'utilisateur, mais .click() fonctionne via JS.
-->
<button
  type="button"
  id="cookie-manage"
  aria-hidden="true"
  tabindex="-1"
  style="position:absolute;width:1px;height:1px;overflow:hidden;opacity:0;pointer-events:none"
></button>

<script is:inline>
  (function () {
    var KEY = "blogdungaucher.cookieConsent.v1";
    var _isManageMode = false;
    var _prevFocus = null;

    /* ── Persistance ──────────────────────────────────────── */
    function readConsent() {
      try {
        var raw = localStorage.getItem(KEY);
        if (!raw) return null;
        var p = JSON.parse(raw);
        // Migration : anciens enregistrements sans "notifications"
        if (p && typeof p === "object" && !("notifications" in p)) {
          var migrated = {
            analytics: p.analytics,
            marketing: p.marketing,
            notifications: false,
            updatedAt: p.updatedAt || new Date().toISOString(),
          };
          localStorage.setItem(KEY, JSON.stringify(migrated));
          return migrated;
        }
        return p;
      } catch (_) {
        return null;
      }
    }

    function writeConsent(payload) {
      var normalized = {
        analytics: Boolean(payload.analytics),
        marketing: Boolean(payload.marketing),
        notifications: Boolean(payload.notifications),
        updatedAt: new Date().toISOString(),
      };
      localStorage.setItem(KEY, JSON.stringify(normalized));
      document.dispatchEvent(new CustomEvent("cookie:updated", { detail: normalized }));
      return normalized;
    }

    /* ── Formulaire ───────────────────────────────────────── */
    function syncForm(consent) {
      var a = document.getElementById("cookie-analytics");
      var m = document.getElementById("cookie-marketing");
      var n = document.getElementById("cookie-notifications");
      if (!a || !m || !n) return;
      a.checked = Boolean(consent && consent.analytics);
      m.checked = Boolean(consent && consent.marketing);
      n.checked = Boolean(consent && consent.notifications);
    }

    /* ── Affichage du modal ───────────────────────────────── */
    function showModal() {
      var backdrop = document.getElementById("consent-backdrop");
      var panel    = document.getElementById("consent-panel");
      if (!backdrop || !panel) return;
      _prevFocus = document.activeElement instanceof HTMLElement ? document.activeElement : null;
      backdrop.hidden = false;
      panel.hidden    = false;
      document.body.style.setProperty("overflow", "hidden");
      requestAnimationFrame(function () {
        var btn = panel.querySelector("button");
        if (btn) btn.focus();
      });
    }

    function hideModal() {
      var backdrop = document.getElementById("consent-backdrop");
      var panel    = document.getElementById("consent-panel");
      if (!backdrop || !panel) return;
      backdrop.hidden = true;
      panel.hidden    = true;
      document.body.style.removeProperty("overflow");
      _isManageMode = false;
      if (_prevFocus) { _prevFocus.focus(); _prevFocus = null; }
    }

    /* ── Init (appelé à chaque transition Astro) ─────────── */
    function initCookieConsent() {
      var panel    = document.getElementById("consent-panel");
      var backdrop = document.getElementById("consent-backdrop");
      if (!panel || !backdrop) return;

      var acceptBtn  = document.getElementById("consent-accept");
      var rejectBtn  = document.getElementById("consent-reject");
      var saveBtn    = document.getElementById("consent-save");
      var manageBtn  = document.getElementById("cookie-manage");
      var analyticsI = document.getElementById("cookie-analytics");
      var marketingI = document.getElementById("cookie-marketing");
      var notifI     = document.getElementById("cookie-notifications");

      var current = readConsent();

      if (!current) {
        // Premier passage : pas de consentement stocké → ouvrir le modal
        _isManageMode = false;
        syncForm(null);
        showModal();
      } else {
        // Déjà consenti : s'assurer que le modal est fermé
        syncForm(current);
        if (!panel.hidden) hideModal();
      }

      if (acceptBtn) {
        acceptBtn.onclick = function () {
          writeConsent({ analytics: true, marketing: true, notifications: true });
          hideModal();
        };
      }

      if (rejectBtn) {
        rejectBtn.onclick = function () {
          writeConsent({ analytics: false, marketing: false, notifications: false });
          hideModal();
        };
      }

      if (saveBtn) {
        saveBtn.onclick = function () {
          writeConsent({
            analytics:     analyticsI ? analyticsI.checked : false,
            marketing:     marketingI ? marketingI.checked : false,
            notifications: notifI     ? notifI.checked     : false,
          });
          hideModal();
        };
      }

      // Ouverture depuis le footer ("Notifications et cookies")
      if (manageBtn) {
        manageBtn.onclick = function () {
          _isManageMode = true;
          syncForm(readConsent());
          // Fermer le "Personnaliser" si déjà ouvert pour repartir proprement
          var details = document.getElementById("consent-customize-details");
          if (details) details.open = false;
          showModal();
        };
      }
    }

    /* ── Keyboard : focus trap + ESC ─────────────────────── */
    document.addEventListener("keydown", function (e) {
      var panel = document.getElementById("consent-panel");
      if (!panel || panel.hidden) return;

      // ESC ferme seulement si l'utilisateur a déjà un consentement stocké
      if (e.key === "Escape" && _isManageMode) {
        hideModal();
        return;
      }

      // Focus trap : garder le focus dans le modal
      if (e.key === "Tab") {
        var focusable = panel.querySelectorAll(
          'button:not([disabled]), input[type="checkbox"], a[href], summary'
        );
        var arr = Array.prototype.slice.call(focusable);
        if (!arr.length) return;
        var first = arr[0];
        var last  = arr[arr.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    /* ── Restaurer overflow avant transitions Astro ───────── */
    document.addEventListener("astro:before-swap", function () {
      document.body.style.removeProperty("overflow");
    });

    document.addEventListener("astro:page-load", initCookieConsent);
  })();
</script>

<style>
  /* ── Backdrop ──────────────────────────────────────────── */
  .consent-backdrop {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.52);
    -webkit-backdrop-filter: blur(3px);
    backdrop-filter: blur(3px);
  }

  .consent-backdrop:not([hidden]) {
    animation: consent-backdrop-in 220ms ease both;
  }

  @keyframes consent-backdrop-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* ── Panel ─────────────────────────────────────────────── */
  .consent-panel {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 201;
    width: min(500px, calc(100vw - 2rem));
    max-height: calc(100dvh - 2rem);
    overflow-y: auto;
    overscroll-behavior: contain;
    border-radius: var(--radius-xl);
    background: var(--surface);
    border: 1px solid var(--border-soft);
    box-shadow: var(--shadow-lg), 0 0 0 1px rgba(0, 0, 0, 0.04);
    padding: 1.6rem 1.6rem 1.3rem;
    display: flex;
    flex-direction: column;
    gap: 1.05rem;
  }

  .consent-panel:not([hidden]) {
    animation: consent-panel-in 300ms var(--ease-out) both;
  }

  @keyframes consent-panel-in {
    from { opacity: 0; transform: translate(-50%, calc(-50% + 20px)); }
    to   { opacity: 1; transform: translate(-50%, -50%); }
  }

  /* ── Header ────────────────────────────────────────────── */
  .consent-header {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }

  .consent-logo {
    width: 18px;
    height: 26px;
    object-fit: contain;
    flex-shrink: 0;
  }

  [data-theme="dark"] .consent-logo {
    filter: invert(1);
  }

  .consent-site {
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--text-dim);
    letter-spacing: 0.02em;
  }

  /* ── Title ─────────────────────────────────────────────── */
  .consent-title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text-main);
    margin: 0;
    line-height: 1.25;
  }

  /* ── Body text ─────────────────────────────────────────── */
  .consent-text {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.65;
    margin: 0;
  }

  .consent-text strong {
    color: var(--text-main);
    font-weight: 600;
  }

  /* ── Boutons rapides ───────────────────────────────────── */
  .consent-quick {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6rem;
  }

  /* ── Boutons ───────────────────────────────────────────── */
  .consent-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.6rem;
    padding: 0 1.1rem;
    border-radius: var(--radius-pill);
    font-family: var(--font-display);
    font-size: 0.88rem;
    font-weight: 700;
    cursor: pointer;
    border: 1.5px solid transparent;
    transition:
      background 160ms ease,
      border-color 160ms ease,
      color 160ms ease,
      transform 200ms var(--ease-spring),
      box-shadow 180ms ease;
    white-space: nowrap;
  }

  .consent-btn:hover  { transform: translateY(-1px); }
  .consent-btn:active { transform: translateY(0); }

  .consent-btn--primary {
    background: var(--green);
    color: #fff;
    border-color: var(--green);
  }
  .consent-btn--primary:hover {
    background: var(--green-hover);
    border-color: var(--green-hover);
    box-shadow: 0 4px 16px color-mix(in srgb, var(--green) 40%, transparent);
  }

  .consent-btn--ghost {
    background: transparent;
    color: var(--text-muted);
    border-color: var(--border-strong);
  }
  .consent-btn--ghost:hover {
    color: var(--text-main);
    border-color: var(--text-muted);
    background: var(--bg-warm);
  }

  .consent-btn--save {
    width: 100%;
    background: var(--bg-warm);
    color: var(--text-main);
    border-color: var(--border-strong);
  }
  .consent-btn--save:hover {
    background: color-mix(in srgb, var(--green) 8%, var(--bg-warm));
    border-color: var(--green-border);
    color: var(--green);
  }

  /* ── Personnaliser (details) ───────────────────────────── */
  .consent-details {
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .consent-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.7rem 0.9rem;
    background: var(--bg-warm);
    cursor: pointer;
    font-size: 0.84rem;
    font-weight: 600;
    color: var(--text-muted);
    list-style: none;
    -webkit-user-select: none;
    user-select: none;
    transition: color 140ms ease, background 140ms ease;
  }

  .consent-summary::-webkit-details-marker { display: none; }

  .consent-summary:hover {
    color: var(--text-main);
    background: color-mix(in srgb, var(--green) 6%, var(--bg-warm));
  }

  .consent-details[open] > .consent-summary {
    color: var(--text-main);
    border-bottom: 1px solid var(--border-soft);
  }

  .consent-chevron {
    flex-shrink: 0;
    transition: transform 220ms var(--ease-out);
  }

  .consent-details[open] .consent-chevron {
    transform: rotate(180deg);
  }

  /* ── Fieldset options ──────────────────────────────────── */
  .consent-fieldset {
    margin: 0;
    padding: 0 0.9rem;
    border: none;
    display: flex;
    flex-direction: column;
  }

  .consent-fieldset__legend {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
  }

  .consent-option {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border-soft);
    cursor: pointer;
  }

  .consent-option:last-of-type {
    border-bottom: none;
  }

  .consent-checkbox {
    flex-shrink: 0;
    width: 1rem;
    height: 1rem;
    margin-top: 0.18rem;
    accent-color: var(--green);
    cursor: pointer;
  }

  .consent-option__body {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .consent-option__name {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-main);
  }

  .consent-option__desc {
    font-size: 0.77rem;
    color: var(--text-dim);
    line-height: 1.45;
  }

  .consent-save-wrap {
    padding: 0.9rem;
    padding-top: 0.75rem;
  }

  /* ── Note de bas ───────────────────────────────────────── */
  .consent-footer-note {
    font-size: 0.76rem;
    color: var(--text-dim);
    line-height: 1.55;
    margin: 0;
    padding-top: 0.6rem;
    border-top: 1px solid var(--border-soft);
  }

  .consent-privacy-link {
    color: var(--green);
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
  }

  .consent-privacy-link:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  /* ── Mobile ────────────────────────────────────────────── */
  @media (max-width: 560px) {
    .consent-panel {
      width: calc(100vw - 1.25rem);
      max-height: calc(100dvh - 1.25rem);
      padding: 1.25rem 1.25rem 1rem;
      border-radius: var(--radius-lg);
      top: auto;
      bottom: 0.625rem;
      transform: translateX(-50%);
    }

    .consent-panel:not([hidden]) {
      animation: consent-panel-mobile-in 300ms var(--ease-out) both;
    }

    @keyframes consent-panel-mobile-in {
      from { opacity: 0; transform: translateX(-50%) translateY(20px); }
      to   { opacity: 1; transform: translateX(-50%) translateY(0); }
    }

    .consent-quick {
      grid-template-columns: 1fr;
    }
  }

  /* ── Accessibilité : réduction de mouvement ────────────── */
  @media (prefers-reduced-motion: reduce) {
    .consent-backdrop:not([hidden]),
    .consent-panel:not([hidden]) {
      animation: none;
    }
  }
</style>
