    inset: auto 1rem 1rem;
    z-index: 120;
    max-width: 32rem;
    padding: 1rem;
    border-radius: var(--radius-lg);
    background: var(--surface);
    border: 1px solid var(--border-soft);
    box-shadow: var(--shadow-lg);
  }

