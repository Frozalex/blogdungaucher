    font-size: 0.9rem;
    line-height: 1.5;
  }

  .cookie-push-hint {
    margin-top: 0.65rem;
    padding: 0.55rem 0.65rem;
    border-radius: var(--radius-md);
    border: 1px solid color-mix(in srgb, var(--green) 35%, var(--border-soft));
    background: color-mix(in srgb, var(--green-light) 40%, var(--surface));
    color: var(--text-main);
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .cookie-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 0.8rem;
  }
  .cookie-options {
    margin-top: 0.8rem;
    padding: 0.7rem;
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-md);
  }
  .cookie-options legend {
    font-size: 0.78rem;
    color: var(--text-muted);
    padding: 0 0.25rem;
  }
  .cookie-options label {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.86rem;
    color: var(--text-main);
  }
  .cookie-options label + label {
    margin-top: 0.45rem;
  }

  .cookie-btn {
    border: 1px solid var(--border-strong);
    background: var(--surface);
    color: var(--text-main);
    padding: 0.45rem 0.75rem;
    border-radius: var(--radius-pill);
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
  }

  .cookie-btn-primary {
    background: var(--green);
    color: #fff;
    border-color: var(--green);
  }

  .cookie-manage {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
