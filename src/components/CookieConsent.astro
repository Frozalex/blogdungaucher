<div class="cookie-banner" id="cookie-banner" hidden>
  <p>
    Ce site utilise des cookies pour la mesure d'audience et la publicité. Les <strong>notifications push</strong> servent
    uniquement à te prévenir des <strong>nouveaux articles</strong>, avec un rythme visé de deux par semaine. Elles sont
    <strong>séparées</strong> de la pub : tu peux les refuser tout en acceptant le reste, ou les activer plus tard.
    Tu modifies tout ça quand tu veux via « Paramètres cookies » en bas de page.
  </p>
  <p id="cookie-push-hint" class="cookie-push-hint" hidden aria-live="polite"></p>
  <fieldset class="cookie-options">
    <legend>Préférences : coche ce que tu veux</legend>
    <label>
      <input id="cookie-analytics" type="checkbox" />
      Mesure d'audience
    </label>
    <label>
      <input id="cookie-marketing" type="checkbox" />
      Publicité personnalisée
    </label>
    <label>
      <input id="cookie-notifications" type="checkbox" />
      Notifications push pour les nouveaux articles, optionnel : le navigateur demandera une confirmation
    </label>
  </fieldset>
  <div class="cookie-actions">
    <button type="button" class="cookie-btn cookie-btn-primary" data-cookie-action="accept">
      Accepter tout
    </button>
    <button type="button" class="cookie-btn" data-cookie-action="reject">
      Tout refuser
    </button>
    <button type="button" class="cookie-btn" data-cookie-action="save">
      Enregistrer mes choix
    </button>
  </div>
</div>

<button type="button" class="cookie-manage" id="cookie-manage" hidden>
  Paramètres cookies
</button>

<script is:inline>
  (function () {
    const KEY = "blogdungaucher.cookieConsent.v1";

    function readConsent() {
      try {
        const raw = localStorage.getItem(KEY);
        if (!raw) return null;
        const p = JSON.parse(raw);
        if (p && typeof p === "object" && !("notifications" in p)) {
          const migrated = {
            ...p,
            notifications: false,
            updatedAt: p.updatedAt || new Date().toISOString(),
          };
          localStorage.setItem(KEY, JSON.stringify(migrated));
          return migrated;
        }
        return p;
      } catch {
        return null;
      }
    }

    function writeConsent(payload) {
      const normalized = {
        analytics: Boolean(payload.analytics),
        marketing: Boolean(payload.marketing),
        notifications: Boolean(payload.notifications),
        updatedAt: new Date().toISOString(),
      };
      localStorage.setItem(KEY, JSON.stringify(normalized));
      document.dispatchEvent(new CustomEvent("cookie:updated", { detail: normalized }));
      return normalized;
    }

    function toggleUi(state, banner, manage) {
      const needsChoice = !state;
      banner.hidden = !needsChoice;
      manage.hidden = needsChoice;
    }

    function initCookieConsent() {
      const banner = document.getElementById("cookie-banner");
      const manage = document.getElementById("cookie-manage");
      const analyticsInput = document.getElementById("cookie-analytics");
      const marketingInput = document.getElementById("cookie-marketing");
      const notificationsInput = document.getElementById("cookie-notifications");
      if (!banner || !manage || !analyticsInput || !marketingInput || !notificationsInput) return;

      function syncForm(consent) {
        analyticsInput.checked = Boolean(consent?.analytics);
        marketingInput.checked = Boolean(consent?.marketing);
        notificationsInput.checked = Boolean(consent?.notifications);
      }

      const current = readConsent();
      syncForm(current);
      toggleUi(current, banner, manage);

      banner.querySelectorAll("[data-cookie-action]").forEach((el) => {
        el.onclick = () => {
          const action = el.getAttribute("data-cookie-action");
          if (action === "accept") {
            const next = writeConsent({
              analytics: true,
              marketing: true,
              notifications: true,
            });
            syncForm(next);
            toggleUi(next, banner, manage);
            const hint = document.getElementById("cookie-push-hint");
            if (hint) {
              hint.textContent =
                "Si le navigateur affiche une demande d'autorisation pour les notifications, accepte-la pour recevoir les alertes. Tu peux révoquer à tout moment dans les paramètres du navigateur ou via « Paramètres cookies ».";
              hint.hidden = false;
              window.clearTimeout(hint._hideT);
              hint._hideT = window.setTimeout(function () {
                hint.hidden = true;
              }, 14000);
            }
            return;
          }
          if (action === "reject") {
            const next = writeConsent({
              analytics: false,
              marketing: false,
              notifications: false,
            });
            syncForm(next);
            toggleUi(next, banner, manage);
            const hint = document.getElementById("cookie-push-hint");
            if (hint) {
              hint.hidden = true;
              hint.textContent = "";
              window.clearTimeout(hint._hideT);
            }
            return;
          }
          if (action === "save") {
            const next = writeConsent({
              analytics: analyticsInput.checked,
              marketing: marketingInput.checked,
              notifications: notificationsInput.checked,
            });
            syncForm(next);
            toggleUi(next, banner, manage);
            const hint = document.getElementById("cookie-push-hint");
            if (hint) {
              if (notificationsInput.checked) {
                hint.textContent =
                  "Si le navigateur affiche une demande d'autorisation pour les notifications, accepte-la pour recevoir les alertes. Tu peux révoquer à tout moment dans les paramètres du navigateur ou via « Paramètres cookies ».";
                hint.hidden = false;
                window.clearTimeout(hint._hideT);
                hint._hideT = window.setTimeout(function () {
                  hint.hidden = true;
                }, 14000);
              } else {
                hint.hidden = true;
                hint.textContent = "";
              }
            }
            return;
          }
          banner.hidden = false;
          manage.hidden = true;
        };
      });

      manage.onclick = () => {
        syncForm(readConsent());
        banner.hidden = false;
        manage.hidden = true;
      };
    }

    document.addEventListener("astro:page-load", initCookieConsent);
  })();
</script>

<style>
