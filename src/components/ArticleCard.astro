---
import type { BlogEntry } from "../utils/blog";
import { formatDate, getCategoryMeta, getPostUrl } from "../utils/blog";

const { post, featured = false } = Astro.props as {
  post: BlogEntry;
  featured?: boolean;
};

const category = getCategoryMeta(post.data.category);
---
<article
  class={`card scale-in ${featured ? "featured" : ""}`}
  style={`--motion-delay: 60ms; --accent:${category.accent};`}
>
  <a href={getPostUrl(post)} class="card-link">

    <div class="card-top">
      <span class="card-badge" data-t={`categories.${post.data.category}.label`}>{category.label}</span>
      <span class="card-time">{post.data.readingTime}</span>
    </div>

    <h3 class="card-title">{post.data.title}</h3>
    <p class="card-excerpt">{post.data.excerpt}</p>

    <div class="card-bottom">
      <time datetime={post.data.publishDate.toISOString()} class="card-date">
        {formatDate(post.data.publishDate)}
      </time>
      <span class="card-cta">
        <span data-t="card.read">Lire</span>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
      </span>
    </div>

  </a>
</article>

<style>
  .card {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
    border: 1.5px solid var(--border-soft);
    background: var(--surface);
    box-shadow: var(--shadow-xs);
    transition:
      transform    260ms var(--ease-spring),
      border-color 220ms ease,
      box-shadow   260ms var(--ease-out);
  }

  .card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
    box-shadow: var(--shadow-md), 0 0 0 1px var(--accent);
  }

  .card::before {
    content: "";
    position: absolute;
    inset: -18% -25% auto auto;
    width: 9rem;
    height: 9rem;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 16%, transparent), transparent 68%);
    opacity: 0;
    transform: translate3d(8px, -8px, 0);
    transition: opacity var(--motion-medium) var(--ease-soft), transform var(--motion-medium) var(--ease-soft);
    pointer-events: none;
  }
  .card:hover::before {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .card-link {
    display: grid;
    gap: 0.75rem;
    height: 100%;
    padding: 1.3rem 1.35rem 1.2rem;
  }

  /* badge + temps */
  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .card-badge {
    display: inline-flex;
    align-items: center;
    min-height: 1.5rem;
    padding: 0 0.55rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--accent);
    color: var(--accent);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .card-time {
    font-size: 0.78rem;
    color: var(--text-dim);
  }

  /* titre — serif éditorial */
  .card-title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(1.15rem, 1.95vw, 1.45rem);
    line-height: 1.22;
    letter-spacing: -0.01em;
    color: var(--text-main);
    font-optical-sizing: auto;
    transition: color 180ms ease;
  }
  .card:hover .card-title { color: var(--accent); }
  .featured .card-title { font-size: clamp(1.5rem, 2.7vw, 2rem); }

  /* excerpt */
  .card-excerpt {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .featured .card-excerpt { -webkit-line-clamp: 4; }

  /* bas de carte */
  .card-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 0.7rem;
    border-top: 1px solid var(--border-soft);
    font-size: 0.8rem;
  }

  .card-date { color: var(--text-dim); }

  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--green);
    font-weight: 600;
    font-size: 0.82rem;
  }
  .card-cta svg {
    transition: transform 220ms var(--ease-spring);
  }
  .card:hover .card-cta svg { transform: translateX(4px); }
</style>
