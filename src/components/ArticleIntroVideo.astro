---
interface Props {
  src: string;
  poster?: string;
  aspect?: "16:9" | "9:16";
  /** Titre court pour l’accessibilité (aria-label). */
  videoTitle: string;
}

const { src, poster, aspect = "16:9", videoTitle } = Astro.props;
const portrait = aspect === "9:16";
---

<figure
  class:list={["article-inline-video", "fade-up", portrait ? "is-portrait" : "is-landscape"]}
  style="--motion-delay: 55ms;"
>
  <video
    controls
    preload="metadata"
    playsinline
    poster={poster}
    aria-label={videoTitle}
  >
    <source src={src} type="video/mp4" />
  </video>
</figure>

<style>
  .article-inline-video {
    margin: 0 0 1.25rem;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border-soft);
    background: var(--surface);
    box-shadow: var(--shadow-xs);
  }

  .article-inline-video video {
    display: block;
    width: 100%;
    vertical-align: middle;
  }

  .article-inline-video.is-landscape video {
    aspect-ratio: 16 / 9;
    object-fit: cover;
    background: color-mix(in srgb, var(--surface-warm) 65%, transparent);
  }

  .article-inline-video.is-portrait {
    max-width: min(420px, 100%);
    margin-left: auto;
    margin-right: auto;
  }

  .article-inline-video.is-portrait video {
    aspect-ratio: 9 / 16;
    object-fit: cover;
    background: color-mix(in srgb, var(--surface-warm) 65%, transparent);
  }
</style>
