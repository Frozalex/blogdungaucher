---
import { siteConfig } from "../data/site";

const comments = siteConfig.comments;
const isGiscusConfigured =
  comments.enabled &&
  comments.provider === "giscus" &&
  comments.repo &&
  comments.repoId &&
  comments.category &&
  comments.categoryId;
---
<section class="comments" id="commentaires">
  <h2>Commentaires</h2>
  <p class="comments-lead">
    Tu as un avis, une nuance, ou une expérience perso à partager ? La discussion est ouverte.
  </p>

  {isGiscusConfigured ? (
    <div id="comments-thread" class="comments-thread"></div>
  ) : (
    <div class="comments-disabled" role="status">
      <p>
        Les commentaires ne sont pas encore actifs. Active Giscus dans
        <code>src/data/site.ts</code> pour afficher la discussion sous chaque article.
      </p>
    </div>
  )}
</section>

{isGiscusConfigured && (
  <script
    define:vars={{
      repo: comments.repo,
      repoId: comments.repoId,
      category: comments.category,
      categoryId: comments.categoryId,
    }}
  >
    let cleanupComments = window.__commentsCleanup;
    cleanupComments?.();

    function initComments() {
      const host = document.getElementById("comments-thread");
      if (!host) return;

      host.innerHTML = "";
      const script = document.createElement("script");
      script.src = "https://giscus.app/client.js";
      script.async = true;
      script.crossOrigin = "anonymous";
      script.setAttribute("data-repo", repo);
      script.setAttribute("data-repo-id", repoId);
      script.setAttribute("data-category", category);
      script.setAttribute("data-category-id", categoryId);
      script.setAttribute("data-mapping", "pathname");
      script.setAttribute("data-strict", "0");
      script.setAttribute("data-reactions-enabled", "1");
      script.setAttribute("data-emit-metadata", "0");
      script.setAttribute("data-input-position", "top");
      script.setAttribute("data-theme", "preferred_color_scheme");
      script.setAttribute("data-lang", "fr");
      script.setAttribute("data-loading", "lazy");
      host.appendChild(script);

      window.__commentsCleanup = () => {
        host.innerHTML = "";
      };
    }

    initComments();
    document.addEventListener("astro:page-load", initComments);
  </script>
)}

<style>
  .comments {
    margin-top: 1.1rem;
    padding: 1.35rem;
    border-radius: var(--radius-lg);
    background: var(--surface);
    border: 1px solid var(--border-soft);
    box-shadow: var(--shadow-xs);
  }

  .comments h2 {
    font-size: 1.12rem;
    margin: 0;
  }

  .comments-lead {
    margin-top: 0.45rem;
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .comments-thread {
    margin-top: 0.85rem;
  }

  .comments-disabled {
    margin-top: 0.85rem;
    padding: 0.9rem 1rem;
    border-radius: var(--radius-md);
    border: 1px dashed var(--border-strong);
    background: var(--bg-warm);
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .comments-disabled code {
    font-size: 0.88em;
    padding: 0.1em 0.35em;
    border-radius: 4px;
    background: color-mix(in srgb, var(--text-main) 8%, white);
    color: var(--text-main);
  }
</style>
