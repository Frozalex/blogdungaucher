---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getAllPosts, getPostUrl } from "../../../utils/blog";
import { categoryMap } from "../../../data/site";

const allPosts = await getAllPosts();
const searchIndex = allPosts.map((p) => ({
  title: p.data.title,
  excerpt: p.data.excerpt,
  url: getPostUrl(p),
  category: p.data.category,
  categoryLabel: categoryMap[p.data.category]?.shortLabel ?? p.data.category,
  categoryAccent: categoryMap[p.data.category]?.accent ?? "#000",
  tags: p.data.tags ?? [],
  readingTime: p.data.readingTime ?? "",
  publishDate: p.data.publishDate.toISOString().split("T")[0],
}));
---

<BaseLayout
  title="Rechercher, Blog d'un Gaucher"
  description="Cherchez parmi les analyses publiées : Alzheimer, TDAH, Elo, AlphaZero, Grand Oral..."
  canonicalPath="/fr/recherche/"
>
  <div class="search-page container">
    <header class="search-header">
      <h1 class="search-title">Rechercher</h1>
      <p class="search-subtitle">
        {allPosts.length} analyses disponibles : science, esprit, société, Grand Oral.
      </p>
    </header>

    <div class="search-box-wrap">
      <label for="search-input" class="sr-only">Rechercher un article</label>
      <div class="search-box">
        <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          id="search-input"
          type="search"
          placeholder="Alzheimer, TDAH, Elo, minimax, Grand Oral…"
          autocomplete="off"
          spellcheck="false"
          autofocus
        />
        <button id="search-clear" class="search-clear" type="button" aria-label="Effacer" hidden>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M18 6 6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>

    <div id="search-state" class="search-state" aria-live="polite" aria-atomic="true"></div>
    <ul id="search-results" class="search-results" role="list"></ul>
  </div>
</BaseLayout>

<!-- Index des articles (JSON statique généré au build) -->
<script type="application/json" id="search-index" set:html={JSON.stringify(searchIndex)}></script>

<script>
  type SearchEntry = {
    title: string;
    excerpt: string;
    url: string;
    category: string;
    categoryLabel: string;
    categoryAccent: string;
    tags: string[];
    readingTime: string;
    publishDate: string;
  };

  const raw = document.getElementById("search-index")?.textContent ?? "[]";
  const INDEX : SearchEntry[] = JSON.parse(raw);

  const inputEl  = document.getElementById("search-input")  as HTMLInputElement;
  const clearBtn = document.getElementById("search-clear")   as HTMLButtonElement;
  const stateEl  = document.getElementById("search-state")  as HTMLElement;
  const listEl   = document.getElementById("search-results") as HTMLUListElement;

  function normalize(s : string) {
    return s
      .toLowerCase()
      .normalize("NFD")
      .replace(/[̀-ͯ]/g, ""); // strip accents
  }

  function score(entry : SearchEntry, q : string): number {
    const nq = normalize(q);
    const title = normalize(entry.title);
    const excerpt = normalize(entry.excerpt);
    const tags = entry.tags.map(normalize).join(" ");
    if (title.startsWith(nq))  return 100;
    if (title.includes(nq))    return 80;
    if (tags.includes(nq))     return 60;
    if (excerpt.includes(nq))  return 40;
    return 0;
  }

  function render(results : SearchEntry[], q : string) {
    listEl.innerHTML = "";

    if (results.length === 0) {
      stateEl.textContent = `Aucun résultat pour « ${q} ».`;
      return;
    }

    stateEl.textContent = `${results.length} résultat${results.length > 1 ? "s" : ""} pour « ${q} »`;

    results.forEach((entry) => {
      const li = document.createElement("li");
      li.className = "search-result";
      li.innerHTML = `
        <a href="${entry.url}" class="search-result__link" style="--accent:${entry.categoryAccent}">
          <span class="search-result__cat">${entry.categoryLabel}</span>
          <strong class="search-result__title">${entry.title}</strong>
          <p class="search-result__excerpt">${entry.excerpt}</p>
          <span class="search-result__meta">${entry.readingTime}${entry.readingTime && entry.publishDate ? " · " : ""}${entry.publishDate}</span>
        </a>
      `;
      listEl.appendChild(li);
    });
  }

  function search(q : string) {
    q = q.trim();
    clearBtn.hidden = q.length === 0;

    if (q.length < 2) {
      stateEl.textContent = q.length === 1 ? "Continue à taper…" : "";
      listEl.innerHTML = "";
      return;
    }

    const results = INDEX
      .map((e) => ({ entry : e, s : score(e, q) }))
      .filter(({ s }) => s > 0)
      .sort((a, b) => b.s - a.s)
      .map(({ entry }) => entry);

    render(results, q);
  }

  // Auto-populate from URL ?q=
  const params = new URLSearchParams(window.location.search);
  const initialQ = params.get("q") ?? "";
  if (initialQ) {
    inputEl.value = initialQ;
    search(initialQ);
  }

  inputEl.addEventListener("input", () => search(inputEl.value));
  clearBtn.addEventListener("click", () => {
    inputEl.value = "";
    inputEl.focus();
    search("");
  });
</script>

<style>
  .search-page {
    padding: calc(var(--navbar-h) + 2.5rem) 0 5rem;
    max-width: 50rem;
  }

  .search-header {
    margin-bottom: 2rem;
  }

  .search-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    color: var(--text-main);
    margin: 0 0 0.4rem;
  }

  .search-subtitle {
    color: var(--text-muted);
    font-size: 1rem;
    margin: 0;
  }

  /* ── Search box ── */
  .search-box-wrap {
    margin-bottom: 1.5rem;
  }

  .search-box {
    position: relative;
    display: flex;
    align-items: center;
  }

  .search-icon {
    position: absolute;
    left: 0.85rem;
    color: var(--text-dim);
    pointer-events: none;
    flex-shrink: 0;
  }

  #search-input {
    width: 100%;
    padding: 0.85rem 2.75rem 0.85rem 2.75rem;
    border-radius: var(--radius-md);
    border: 1.5px solid var(--border-soft);
    background: var(--surface);
    color: var(--text-main);
    font-size: 1rem;
    font-family: inherit;
    transition: border-color 160ms ease, box-shadow 160ms ease;
    outline: none;
    box-shadow: var(--shadow-xs);
  }

  #search-input:focus {
    border-color: var(--green);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--green) 18%, transparent);
  }

  #search-input::placeholder {
    color: var(--text-dim);
  }

  .search-clear {
    position: absolute;
    right: 0.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.6rem;
    height: 1.6rem;
    border-radius: 50%;
    border: none;
    background: var(--border-soft);
    color: var(--text-muted);
    cursor: pointer;
    transition: background 140ms ease;
  }
  .search-clear:hover { background : var(--border-strong); }

  /* ── State ── */
  .search-state {
    font-size: 0.85rem;
    color: var(--text-dim);
    min-height: 1.4rem;
    margin-bottom: 0.75rem;
  }

  /* ── Results list ── */
  .search-results {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.75rem;
  }

  .search-result__link {
    display: block;
    padding: 1.1rem 1.25rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-soft);
    background: var(--surface);
    box-shadow: var(--shadow-xs);
    transition: border-color 160ms ease, box-shadow 160ms ease, transform 200ms var(--ease-spring);
    text-decoration: none;
  }

  .search-result__link:hover {
    border-color: var(--accent, var(--green));
    box-shadow: var(--shadow-sm);
    transform: translateY(-2px);
  }

  .search-result__cat {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent, var(--green));
    margin-bottom: 0.3rem;
  }

  .search-result__title {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1rem;
    color: var(--text-main);
    margin-bottom: 0.3rem;
    line-height: 1.35;
  }

  .search-result__excerpt {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0 0 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient : vertical;
    overflow: hidden;
  }

  .search-result__meta {
    font-size: 0.78rem;
    color: var(--text-dim);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
