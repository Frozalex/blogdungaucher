---
import { render } from "astro:content";

import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import TableOfContents from "../../../components/TableOfContents.astro";
import AdBanner from "../../../components/AdBanner.astro";
import ShareButtons from "../../../components/ShareButtons.astro";
import Comments from "../../../components/Comments.astro";

import { siteConfig } from "../../../data/site";
import { absoluteUrl, buildBreadcrumbJsonLd } from "../../../utils/blog";
import { formatPlayerDate, formatYear, getAllPlayers, getPlayerSlug, getPlayerUrl } from "../../../utils/players";

export async function getStaticPaths() {
  const players = await getAllPlayers();
  return players.map((player) => ({
    params: { slug: getPlayerSlug(player) },
    props: { player },
  }));
}

const { player } = Astro.props;
const { Content, headings } = await render(player);

const url = getPlayerUrl(player);
const fullName = `${player.data.firstName} ${player.data.lastName}`;
const years =
  `${formatYear(player.data.birthDate)}${
    player.data.deathDate ? `-${formatYear(player.data.deathDate)}` : ""
  }`;
const photo = player.data.photo;
const publishedLabel = formatPlayerDate(player.data.publishDate);
const updatedLabel = player.data.updatedDate ? formatPlayerDate(player.data.updatedDate) : null;

const structuredData = [
  buildBreadcrumbJsonLd([
    { name: "Accueil", path: "/fr/" },
    { name: "Joueurs", path: "/fr/joueurs/" },
    { name: fullName, path: url },
  ]),
];
---
<BaseLayout
  title={`${player.data.seoTitle ?? player.data.title} | Blog d'un Gaucher`}
  description={player.data.seoDescription ?? player.data.excerpt}
  canonicalPath={url}
  image={player.data.ogImage ?? siteConfig.defaultOgImage}
  type="article"
  structuredData={structuredData}
>
  <article class="player-page">
    <div class="container player-layout">
      <div class="player-main">
        <Breadcrumb items={[
          { label: "Accueil", href: "/fr/" },
          { label: "Joueurs", href: "/fr/joueurs/" },
          { label: fullName },
        ]} />

        <header class="player-header fade-up" style="--motion-delay: 40ms;">
          <div class="player-meta">
            <span class="meta-pill">{player.data.nationality}</span>
            <span class="meta-pill">{years}</span>
            <span class="meta-pill">{player.data.era}</span>
          </div>

          <h1>{player.data.title}</h1>
          <p class="player-excerpt">{player.data.excerpt}</p>

          <div class="player-hook">
            <p class="hook-fact">
              <strong>Fait surprenant.</strong> {player.data.surprisingFact}
            </p>
            <p class="hook-angle">
              <strong>Angle.</strong> {player.data.angleHook}
            </p>
          </div>
        </header>

        <div class="toc-mobile-wrap">
          <TableOfContents headings={headings} mode="mobile" />
        </div>

        <AdBanner format="inline" compact={true} />

        <div class="player-body fade-up" style="--motion-delay: 100ms;">
          <Content />
        </div>

        <div class="player-meta-footer fade-up" style="--motion-delay: 120ms;">
          <span>Publié le <time datetime={player.data.publishDate.toISOString()}>{publishedLabel}</time></span>
          {updatedLabel && (
            <span>Mis à jour le <time datetime={player.data.updatedDate!.toISOString()}>{updatedLabel}</time></span>
          )}
        </div>

        <ShareButtons title={player.data.title} url={absoluteUrl(url)} />
        <Comments />
      </div>

      <aside class="player-aside">
        <div class="profile-card fade-up" style="--motion-delay: 110ms;">
          {photo?.src ? (
            <figure class="profile-figure">
              <img
                class="profile-photo"
                src={photo.src}
                alt={photo.alt ?? fullName}
                loading="lazy"
                decoding="async"
              />
              {(photo.credit || photo.license || photo.sourceUrl) && (
                <figcaption class="profile-credit">
                  {photo.credit && <span class="credit-piece">Crédit: {photo.credit}</span>}
                  {photo.license && <span class="credit-piece">Licence: {photo.license}</span>}
                  {photo.sourceUrl && (
                    <a class="credit-link" href={photo.sourceUrl} target="_blank" rel="noreferrer">
                      Source
                    </a>
                  )}
                </figcaption>
              )}
            </figure>
          ) : (
            <div class="profile-photo-fallback" aria-hidden="true"></div>
          )}

          <div class="profile-body">
            <p class="profile-name">{fullName}</p>
            <dl class="profile-dl">
              <div class="profile-row">
                <dt>Dates</dt>
                <dd>{years}</dd>
              </div>
              <div class="profile-row">
                <dt>Nationalité</dt>
                <dd>{player.data.nationality}</dd>
              </div>
              <div class="profile-row">
                <dt>Époque</dt>
                <dd>{player.data.era}</dd>
              </div>
              <div class="profile-row">
                <dt>Style</dt>
                <dd>{(player.data.style ?? []).join(", ")}</dd>
              </div>
            </dl>
          </div>
        </div>

        <div class="toc-desktop-wrap">
          <TableOfContents headings={headings} mode="desktop" />
        </div>

        {player.data.iconicGame?.title && (
          <div class="aside-card fade-up" style="--motion-delay: 120ms;">
            <span class="aside-dot"></span>
            <h2>Partie emblématique</h2>
            <p>{player.data.iconicGame.title}</p>
          </div>
        )}

        <AdBanner format="rectangle" compact={true} />
      </aside>
    </div>
  </article>
</BaseLayout>

<style>
  .player-page { padding: 3rem 0 2rem; }

  .player-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 17rem;
    gap: 2rem;
    align-items: start;
  }

  .player-main { min-width: 0; }

  .player-header {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-soft);
    margin-bottom: 1.5rem;
  }

  .player-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 0.85rem;
    font-size: 0.82rem;
    color: var(--text-dim);
  }

  .meta-pill {
    display: inline-flex;
    align-items: center;
    min-height: 1.55rem;
    padding: 0 0.55rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--border-soft);
    background: color-mix(in srgb, var(--surface-warm) 72%, transparent);
  }

  .player-header h1 {
    font-family: var(--font-serif);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(2rem, 4.8vw, 3.2rem);
    letter-spacing: -0.015em;
    line-height: 1.1;
    max-width: 28ch;
    color: var(--text-main);
    font-optical-sizing: auto;
  }

  .player-excerpt {
    margin-top: 0.7rem;
    font-size: 1.05rem;
    color: var(--text-muted);
    max-width: 42rem;
  }

  .player-hook {
    margin-top: 1.1rem;
    display: grid;
    gap: 0.6rem;
    padding: 1rem 1.1rem;
    border-radius: var(--radius-lg);
    background: var(--surface);
    border: 1px solid var(--border-soft);
    box-shadow: var(--shadow-xs);
  }

  .hook-fact, .hook-angle { color: var(--text-muted); line-height: 1.7; margin: 0; }
  .hook-fact strong, .hook-angle strong { color: var(--text-main); }

  .player-body {
    padding: 1.75rem;
    border-radius: var(--radius-lg);
    background: var(--surface);
    border: 1px solid var(--border-soft);
    box-shadow: var(--shadow-xs);
  }

  .player-meta-footer {
    margin-top: 0.9rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1rem;
    padding: 0.9rem 1.1rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-soft);
    background: color-mix(in srgb, var(--surface-warm) 72%, transparent);
    color: var(--text-dim);
    font-size: 0.86rem;
    line-height: 1.5;
  }

  .player-meta-footer time {
    color: var(--text-muted);
    font-weight: 700;
  }

  .player-body :global(h2) {
    margin: 1.9rem 0 0.7rem;
    font-family: var(--font-serif);
    font-weight: 500;
    font-style: italic;
    font-size: 1.65rem;
    letter-spacing: -0.01em;
    color: var(--text-main);
    font-optical-sizing: auto;
  }
  .player-body :global(h3) {
    margin: 1.4rem 0 0.5rem;
    font-size: 1.18rem;
    color: var(--text-main);
  }
  .player-body :global(p),
  .player-body :global(li) { color: var(--text-muted); line-height: 1.75; }
  .player-body :global(p:first-of-type)::first-letter {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 500;
    font-size: 3.4em;
    line-height: 0.9;
    float: left;
    padding: 0.22rem 0.6rem 0 0;
    color: var(--green);
  }
  .player-body :global(li::marker) { color: var(--green); font-weight: bold; }

  .player-aside {
    position: sticky;
    top: 5rem;
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .profile-card {
    border-radius: var(--radius-lg);
    background: var(--surface);
    border: 1px solid var(--border-soft);
    box-shadow: var(--shadow-xs);
    overflow: hidden;
  }

  .profile-figure { margin: 0; }

  .profile-photo,
  .profile-photo-fallback {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    display: block;
    background: color-mix(in srgb, var(--surface-warm) 65%, transparent);
  }

  .profile-credit {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.6rem;
    align-items: baseline;
    padding: 0.6rem 0.8rem;
    border-top: 1px solid var(--border-soft);
    font-size: 0.75rem;
    color: var(--text-dim);
    background: color-mix(in srgb, var(--surface-warm) 70%, transparent);
  }

  .credit-piece { white-space: nowrap; }
  .credit-link {
    color: var(--green);
    font-weight: 700;
    text-decoration: none;
  }
  .credit-link:hover { text-decoration: underline; }

  .profile-body { padding: 0.9rem 1rem 1rem; }
  .profile-name {
    margin: 0 0 0.6rem;
    font-weight: 800;
    color: var(--text-main);
    letter-spacing: -0.01em;
  }

  .profile-dl { display: grid; gap: 0.55rem; margin: 0; }
  .profile-row {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    gap: 0.6rem;
  }
  .profile-row dt {
    color: var(--text-dim);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 800;
  }
  .profile-row dd { margin: 0; color: var(--text-muted); font-size: 0.9rem; line-height: 1.4; }

  .toc-mobile-wrap { display: none; }
  .toc-desktop-wrap {
    width: 100%;
    max-width: 15.5rem;
    margin-inline: auto;
  }

  .aside-card {
    padding: 1.3rem;
    border-radius: var(--radius-lg);
    background: var(--surface);
    border: 1px solid var(--border-soft);
    box-shadow: var(--shadow-xs);
  }
  .aside-dot {
    display: block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-bottom: 0.7rem;
    background: var(--green);
  }
  .aside-card h2 { font-size: 1rem; margin-bottom: 0.4rem; }
  .aside-card p  { color: var(--text-muted); font-size: 0.86rem; line-height: 1.6; }

  @media (max-width: 900px) {
    .player-layout { grid-template-columns: 1fr; }
    .player-aside  { position: static; }
    .toc-mobile-wrap { display: block; }
    .toc-desktop-wrap { display: none; }
  }
</style>

