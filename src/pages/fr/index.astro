---
import AdBanner from "../../components/AdBanner.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

import { categoryMap, categorySlugs } from "../../data/site";
import { buildWebsiteJsonLd, getLatestPosts } from "../../utils/blog";

const latestPosts = await getLatestPosts(5, "fr");
---
<BaseLayout
  title="Blog d'un Gaucher"
  description="Science du jeu, esprit compétitif et échecs dans la société. Un espace de partage et de réflexion."
  canonicalPath="/fr/"
  structuredData={buildWebsiteJsonLd()}
>

  <!-- ─── HERO ─── -->
  <section class="hero">
    <div class="hero-particles" aria-hidden="true">
      <span class="hero-particle hero-particle--knight p1">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M18 19H7.5a1.5 1.5 0 0 1-1.5-1.5V17l1-2 1-5.2c.2-1.1.8-2.1 1.7-2.8L13 4h-2l-.5-2h4L16 4l1.2.7c1.8 1 2.8 2.9 2.5 4.9L19 13l1 2v2.5A1.5 1.5 0 0 1 18.5 19H18Z"/>
          <circle cx="13.5" cy="8.2" r="0.8"/>
        </svg>
      </span>
      <span class="hero-particle hero-particle--knight p2">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M18 19H7.5a1.5 1.5 0 0 1-1.5-1.5V17l1-2 1-5.2c.2-1.1.8-2.1 1.7-2.8L13 4h-2l-.5-2h4L16 4l1.2.7c1.8 1 2.8 2.9 2.5 4.9L19 13l1 2v2.5A1.5 1.5 0 0 1 18.5 19H18Z"/>
          <circle cx="13.5" cy="8.2" r="0.8"/>
        </svg>
      </span>
      <span class="hero-particle hero-particle--knight p3">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M18 19H7.5a1.5 1.5 0 0 1-1.5-1.5V17l1-2 1-5.2c.2-1.1.8-2.1 1.7-2.8L13 4h-2l-.5-2h4L16 4l1.2.7c1.8 1 2.8 2.9 2.5 4.9L19 13l1 2v2.5A1.5 1.5 0 0 1 18.5 19H18Z"/>
          <circle cx="13.5" cy="8.2" r="0.8"/>
        </svg>
      </span>
      <span class="hero-particle hero-particle--knight p4">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M18 19H7.5a1.5 1.5 0 0 1-1.5-1.5V17l1-2 1-5.2c.2-1.1.8-2.1 1.7-2.8L13 4h-2l-.5-2h4L16 4l1.2.7c1.8 1 2.8 2.9 2.5 4.9L19 13l1 2v2.5A1.5 1.5 0 0 1 18.5 19H18Z"/>
          <circle cx="13.5" cy="8.2" r="0.8"/>
        </svg>
      </span>
      <span class="hero-particle hero-particle--plus p5">+</span>
      <span class="hero-particle hero-particle--plus p6">+</span>
      <span class="hero-particle hero-particle--plus p7">+</span>
      <span class="hero-particle hero-particle--plus p8">+</span>
    </div>
    <div class="container hero__inner">
      <span class="eyebrow fade-up" style="--motion-delay: 40ms;" data-t="home.eyebrow">Éditorial indépendant</span>
      <h1 class="hero__title fade-up" style="--motion-delay: 120ms;" data-t-html="home.titleHtml">
        Comprendre les <span class="hero__accent display-serif">échecs</span><br/>sans simplifier le jeu.
      </h1>
      <p class="hero__lead fade-up" style="--motion-delay: 190ms;" data-t="home.lead">
        Chaque semaine, des analyses claires sur la science du jeu, le mental compétitif
        et l'impact des échecs dans la société, avec une approche humaine et exigeante.
      </p>
      <div class="hero__actions fade-up" style="--motion-delay: 250ms;">
        <a href="/fr/blog/"      class="button-primary"   data-t="home.startReading">Commencer la lecture</a>
        <a href="#rubriques" class="button-secondary"  data-t="home.seeSections">Voir les rubriques</a>
      </div>
      <ul class="hero-proof fade-up" style="--motion-delay: 320ms;" aria-label="Repères éditoriaux">
        <li data-t="home.proof1">Articles de fond</li>
        <li data-t="home.proof2">Ton accessible</li>
        <li data-t="home.proof3">Approche rigoureuse</li>
      </ul>
    </div>
  </section>

  <section class="editorial-intro">
    <div class="container">
      <div class="editorial-note reveal scale-in" data-t="home.editorialNote">
        Ici, on ne promet pas des progrès magiques en 7 jours.
        On propose des idées solides, des exemples concrets et des analyses que tu peux appliquer
        à ta pratique, que tu sois joueur de club, compétiteur ou simple passionné.
      </div>
    </div>
  </section>

  <!-- ─── RUBRIQUES ─── -->
  <section class="pillars" id="rubriques">
    <div class="container">
      <span class="eyebrow reveal" data-t="home.sectionsEyebrow">4 rubriques</span>
      <h2 class="section-title reveal" data-t="home.sectionsTitle">Ce dont on parle ici</h2>
      <hr class="section-divider reveal" />
      <div class="pillar-grid reveal-group">
        {categorySlugs.map((slug) => {
          const cat = categoryMap[slug];
          return (
            <a href={cat.href} class="pillar" style={`--p:${cat.accent};`}>
              <span class="pillar__dot"></span>
              <div>
                <span class="pillar__kicker" data-t={`categories.${slug}.shortLabel`}>{cat.shortLabel}</span>
                <strong data-t={`categories.${slug}.label`}>{cat.label}</strong>
                <p data-t={`categories.${slug}.tagline`}>{cat.tagline}</p>
              </div>
              <svg class="pillar__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <div class="container">
    <AdBanner format="leaderboard" />
  </div>

  <!-- ─── ARTICLES RECENTS ─── -->
  <section class="latest">
    <div class="container">
      <div class="section-head reveal">
        <div>
          <span class="eyebrow" data-t="home.recentEyebrow">Récents</span>
          <h2 class="section-title" data-t="home.latestTitle">Derniers articles</h2>
        </div>
        <a href="/fr/blog/" class="see-all link-underline" data-t="home.seeAll">Tout voir →</a>
      </div>
      <div class="latest-grid reveal-group">
        {latestPosts.map((post, i) => (
          <ArticleCard post={post} featured={i === 0} />
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── HERO ─────────────────────────────────────────────── */
  .hero {
    position: relative;
    overflow: hidden;
    padding: 5.5rem 0 3.2rem;
  }

  .hero-particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .hero-particle {
    position: absolute;
    top: -1.5rem;
    right: -2rem;
    color: color-mix(in srgb, var(--green) 72%, #9fff92);
    opacity: 0;
    will-change: transform, opacity;
    animation: knightTrail 18s linear infinite;
  }

  .hero-particle--knight {
    width: clamp(0.95rem, 1.45vw, 1.4rem);
    height: clamp(0.95rem, 1.45vw, 1.4rem);
  }
  .hero-particle--knight svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
    filter: drop-shadow(0 0 10px color-mix(in srgb, var(--green) 30%, transparent));
  }

  .hero-particle--plus {
    font-size: clamp(0.65rem, 1.1vw, 1rem);
    font-weight: 700;
    color: color-mix(in srgb, var(--green) 92%, #fff);
    filter: drop-shadow(0 0 8px color-mix(in srgb, var(--green) 24%, transparent));
  }
  .hero-particle.p1 { top: 8%;  animation-delay: 0s;   animation-duration: 16s; }
  .hero-particle.p2 { top: 22%; animation-delay: 2.2s; animation-duration: 20s; }
  .hero-particle.p3 { top: 36%; animation-delay: 4.6s; animation-duration: 17s; }
  .hero-particle.p4 { top: 52%; animation-delay: 7s;   animation-duration: 19s; }
  .hero-particle.p5 { top: 14%; animation-delay: 1.2s; animation-duration: 13s; }
  .hero-particle.p6 { top: 29%; animation-delay: 3.5s; animation-duration: 14s; }
  .hero-particle.p7 { top: 44%; animation-delay: 6.2s; animation-duration: 15s; }
  .hero-particle.p8 { top: 61%; animation-delay: 8.6s; animation-duration: 14s; }

  .hero .container,
  .editorial-intro .container,
  .pillars .container,
  .latest .container {
    width: min(1280px, calc(100% - 2rem));
  }

  .hero__inner {
    max-width: 56rem;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .hero__title {
    position: relative;
    font-size: clamp(2.6rem, 6.5vw, 4.4rem);
    margin: 0.85rem 0 1.1rem;
  }
  .hero__title::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    width: min(520px, 70%);
    height: 180px;
    transform: translate(-50%, -50%);
    background: radial-gradient(
      closest-side,
      color-mix(in srgb, var(--green) 18%, transparent) 0%,
      transparent 75%
    );
    filter: blur(10px);
    z-index: -1;
    pointer-events: none;
  }

  .hero__accent {
    color: var(--green);
    font-size: 1.08em;
  }

  .hero__lead {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 44rem;
    margin-inline: auto;
    line-height: 1.75;
  }

  .hero__actions {
    display: flex;
    gap: 0.7rem;
    flex-wrap: wrap;
    margin-top: 1.75rem;
    justify-content: center;
  }

  .hero-proof {
    list-style: none;
    padding: 0;
    margin: 1.2rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    justify-content: center;
  }
  .hero-proof li {
    padding: 0.3rem 0.65rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--green-border);
    background: color-mix(in srgb, var(--green-light) 70%, #fff);
    color: var(--text-muted);
    font-size: 0.78rem;
    font-weight: 600;
  }

  .editorial-intro {
    padding: 0.5rem 0 1.6rem;
  }

  .editorial-intro .container {
    display: flex;
    justify-content: center;
  }

  @keyframes knightTrail {
    0% {
      transform: translate3d(0, 0, 0) rotate(-8deg);
      opacity: 0;
    }
    8% {
      opacity: 0.24;
    }
    82% {
      opacity: 0.24;
    }
    100% {
      transform: translate3d(-112vw, 88vh, 0) rotate(-20deg);
      opacity: 0;
    }
  }

  /* ── PILLARS ──────────────────────────────────────────── */
  .pillars {
    padding: 0.8rem 0 3.5rem;
  }

  .pillars .container {
    text-align: center;
  }

  .pillar-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.65rem;
    margin-top: 1.4rem;
    align-items: stretch;
  }

  .pillar {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 1.1rem 1.2rem;
    border-radius: var(--radius-lg);
    border: 1.5px solid var(--border-soft);
    background: var(--surface);
    transition:
      transform    240ms var(--ease-spring),
      border-color 180ms ease,
      box-shadow   240ms var(--ease-out);
  }

  .pillar:hover {
    transform: translateY(-3px);
    border-color: var(--p);
    box-shadow: var(--shadow-sm);
  }

  .pillar__dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--p);
    flex-shrink: 0;
    margin-top: 0.35rem;
    transition: transform 240ms var(--ease-spring);
  }
  .pillar:hover .pillar__dot { transform: scale(1.5); }

  .pillar > div { flex: 1; }
  .pillar__kicker {
    display: inline-flex;
    margin-bottom: 0.2rem;
    font-size: 0.66rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    font-weight: 700;
  }
  .pillar strong {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text-main);
    margin-bottom: 0.18rem;
  }
  .pillar p {
    font-size: 0.84rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .pillar__arrow {
    color: var(--text-dim);
    flex-shrink: 0;
    margin-top: 0.2rem;
    transition: color 180ms ease, transform 240ms var(--ease-spring);
  }
  .pillar:hover .pillar__arrow {
    color: var(--p);
    transform: translateX(3px);
  }

  /* ── LATEST ───────────────────────────────────────────── */
  .latest {
    padding: 1.5rem 0 5rem;
  }

  .latest .container {
    text-align: center;
  }

  .section-head {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.4rem;
  }

  .see-all {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-muted);
    transition: color 160ms ease;
  }
  .see-all:hover { color: var(--green); }

  .latest-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.85rem;
    text-align: left;
  }

  /* premier article en pleine largeur */
  .latest-grid > :first-child {
    grid-column: 1 / -1;
  }

  /* ── RESPONSIVE ─────────────────────────────────────── */
  @media (max-width: 1120px) {
    .pillar-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 860px) {
    .pillar-grid,
    .latest-grid {
      grid-template-columns: 1fr;
    }
    .latest-grid > :first-child {
      grid-column: auto;
    }
  }

  @media (max-width: 560px) {
    .hero { padding: 3.5rem 0 3rem; }
    .hero .container,
    .editorial-intro .container,
    .pillars .container,
    .latest .container {
      width: min(1280px, calc(100% - 1.25rem));
    }
    .section-head { flex-direction: column; align-items: center; }
    .hero-proof li { font-size: 0.74rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-particle {
      animation: none;
      opacity: 0.1;
      transform: none;
    }
  }
</style>
