---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HomeCinematicBackground from "../../components/HomeCinematicBackground.astro";
import HomeLanding from "../../components/HomeLanding.astro";

import { buildWebsiteJsonLd, getLatestPosts } from "../../utils/blog";

const latestPosts = await getLatestPosts(5, "fr");
---
<BaseLayout
  title="Blog d'un Gaucher"
  description="Science du jeu, esprit compétitif et échecs dans la société. Un espace de partage et de réflexion."
  canonicalPath="/fr/"
  structuredData={buildWebsiteJsonLd()}
>
  <HomeCinematicBackground>
    <HomeLanding lang="fr" latestPosts={latestPosts} />
  </HomeCinematicBackground>
</BaseLayout>
