---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HomeLanding from "../../components/HomeLanding.astro";

import { buildWebsiteJsonLd, getAllPosts, getLatestPosts } from "../../utils/blog";
import { categorySlugs } from "../../data/site";

const allPosts = await getAllPosts();
const totalPosts = allPosts.length;
const latestPosts = await getLatestPosts(6, "fr");

const postsByCategory = Object.fromEntries(
  categorySlugs.map((slug) => [slug, allPosts.filter((p) => p.data.category === slug).length]),
) as Partial<Record<(typeof categorySlugs)[number], number>>;
---
<BaseLayout
  title="Blog d'un Gaucher"
  description="Science du jeu, esprit compétitif et échecs dans la société. Deux articles par semaine. Un espace de partage et de réflexion."
  canonicalPath="/fr/"
  structuredData={buildWebsiteJsonLd()}
>
  <HomeLanding lang="fr" latestPosts={latestPosts} totalPosts={totalPosts} postsByCategory={postsByCategory} />
</BaseLayout>
