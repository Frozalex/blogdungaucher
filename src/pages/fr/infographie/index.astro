---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const articles = [
  {
    num: 1,
    slug: "les-echecs-et-les-mathematiques",
    title: "Les échecs rendent-ils meilleur en maths ?",
    subtitle: "La vérité scientifique",
    excerpt: "Jouer aux échecs te rend bon en maths ? La réponse n'est pas celle que tu attends, et elle change ce que tu devrais faire avec un échiquier.",
    category: "science",
    categoryLabel: "Science",
    pillar: "Cognition",
    date: "2 avr. 2026",
    isoDate: "2026-04-02",
    readingTime: "15 min",
    tags: ["mathématiques", "métacognition", "calcul", "cerveau"],
  },
  {
    num: 2,
    slug: "echecs-et-autisme",
    title: "Échecs et autisme : l'échiquier comme refuge",
    subtitle: "Ce que la recherche dit vraiment",
    excerpt: "Pour un cerveau qui supporte mal l'ambiguïté sociale, l'échiquier est l'un des rares espaces où les règles tiennent vraiment.",
    category: "societe",
    categoryLabel: "Société",
    pillar: "Inclusion",
    date: "2 avr. 2026",
    isoDate: "2026-04-02",
    readingTime: "22 min",
    tags: ["autisme", "TSA", "inclusion", "neurodiversité"],
  },
  {
    num: 3,
    slug: "echecs-et-femmes",
    title: "Échecs et femmes : pourquoi si peu de joueuses ?",
    subtitle: "40 femmes parmi 1 700 GMs",
    excerpt: "40 femmes parmi 1 700 Grands Maîtres. L'écart n'est pas biologique : il est mathématique, historique et psychologique.",
    category: "societe",
    categoryLabel: "Société",
    pillar: "Genre",
    date: "3 avr. 2026",
    isoDate: "2026-04-03",
    readingTime: "25 min",
    tags: ["genre", "Polgar", "Hou Yifan", "sociologie"],
  },
  {
    num: 4,
    slug: "les-echecs-et-l-addiction",
    title: "Les échecs et l'addiction : quand le jeu devient une drogue",
    subtitle: "Décryptage d'une dépendance silencieuse",
    excerpt: "Il est 3h du matin. Tu as promis que c'était la dernière partie, mais tu en lances une autre. Peut-on vraiment être accro aux échecs ?",
    category: "societe",
    categoryLabel: "Société",
    pillar: "Psychologie",
    date: "3 avr. 2026",
    isoDate: "2026-04-03",
    readingTime: "22 min",
    tags: ["addiction", "dopamine", "jeu en ligne", "santé mentale"],
  },
  {
    num: 5,
    slug: "les-echecs-et-le-cerveau",
    title: "Les échecs et le cerveau : ce que la science révèle",
    subtitle: "IRM, chronnectome, fonctions exécutives",
    excerpt: "Un grand maître ? Pas un génie né, un cerveau entraîné. Voici ce que la recherche en neurosciences mesure vraiment.",
    category: "science",
    categoryLabel: "Science",
    pillar: "Neurosciences",
    date: "3 avr. 2026",
    isoDate: "2026-04-03",
    readingTime: "22 min",
    tags: ["cerveau", "IRMf", "neuroplasticité", "Gobet"],
  },
  {
    num: 6,
    slug: "psychologie-du-joueur-d-echecs",
    title: "La psychologie du joueur d'échecs",
    subtitle: "Ce qui se passe vraiment dans ta tête",
    excerpt: "Les échecs ne se jouent pas que sur l'échiquier. Ils se jouent d'abord dans ta tête, avant même que ta main ne touche une pièce.",
    category: "esprit",
    categoryLabel: "Esprit",
    pillar: "Psychologie",
    date: "5 avr. 2026",
    isoDate: "2026-04-05",
    readingTime: "16 min",
    tags: ["ego", "tilt", "flow", "peur de perdre"],
  },
  {
    num: 7,
    slug: "pourquoi-echecs-probleme-mathematique-impossible-et-ia",
    title: "Les échecs : un problème mathématique (presque) impossible",
    subtitle: "Et comment l'IA s'en sort quand même",
    excerpt: "L'arbre des coups explose, le nombre de Shannon donne le vertige, et pourtant un moteur te corrige en quelques secondes.",
    category: "science",
    categoryLabel: "Science",
    pillar: "Informatique",
    date: "9 avr. 2026",
    isoDate: "2026-04-09",
    readingTime: "16 min",
    tags: ["IA", "Stockfish", "nombre de Shannon", "minimax"],
  },
  {
    num: 8,
    slug: "echecs-et-seniors",
    title: "Échecs et seniors : déclin cognitif et réserve cérébrale",
    subtitle: "L'étude du New England Journal of Medicine",
    excerpt: "Une étude du NEJM le montre : jouer aux échecs réduit le risque de démence. Mais le mécanisme est bien plus subtil.",
    category: "science",
    categoryLabel: "Science",
    pillar: "Neurosciences",
    date: "30 avr. 2026",
    isoDate: "2026-04-30",
    readingTime: "18 min",
    tags: ["démence", "Alzheimer", "réserve cognitive", "NEJM"],
  },
  {
    num: 9,
    slug: "regle-40-40-20-echecs",
    title: "La règle 40-40-20 : structurer son entraînement",
    subtitle: "Tactique, finales, ouvertures",
    excerpt: "La plupart des joueurs passent 80 % de leur temps sur les ouvertures. La règle 40-40-20 dit l'inverse — et elle a des arguments.",
    category: "esprit",
    categoryLabel: "Esprit",
    pillar: "Progression",
    date: "5 mai 2026",
    isoDate: "2026-05-05",
    readingTime: "20 min",
    tags: ["entraînement", "tactique", "finales", "méthode"],
  },
  {
    num: 10,
    slug: "theorie-des-jeux-aux-echecs",
    title: "Théorie des jeux aux échecs : chaque coup est une décision",
    subtitle: "Nash, minimax et stratégie optimale",
    excerpt: "Les échecs sont le terrain d'origine de la théorie des jeux. Minimax, équilibre de Nash, information parfaite : décryptage mathématique.",
    category: "science",
    categoryLabel: "Science",
    pillar: "Mathématiques",
    date: "5 mai 2026",
    isoDate: "2026-05-05",
    readingTime: "14 min",
    tags: ["Nash", "minimax", "stratégie", "mathématiques"],
  },
];

const totalMinutes = articles.reduce((acc, a) => acc + parseInt(a.readingTime), 0);
const hours = Math.floor(totalMinutes / 60);
const mins = totalMinutes % 60;
const totalReadingLabel = `${hours}h${mins < 10 ? "0" : ""}${mins}`;

const catCounts = articles.reduce((acc, a) => {
  acc[a.category] = (acc[a.category] || 0) + 1;
  return acc;
}, {} as Record<string, number>);
---

<BaseLayout
  title="Les 10 premiers articles — Infographie | Blog d'un Gaucher"
  description="Visualisation interactive des 10 premiers articles du Blog d'un Gaucher : timeline, catégories, thèmes et temps de lecture. De l'autisme aux mathématiques, du cerveau à l'addiction."
  canonicalPath="/fr/infographie/"
  omitEnDeAlternateLinks={true}
>
  <main class="infographic-page">

    <!-- ─────────────────── HERO ─────────────────── -->
    <section class="hero">
      <div class="hero-inner">
        <p class="hero-eyebrow">Blog d'un Gaucher</p>
        <h1 class="hero-title">Naissance d'un blog</h1>
        <p class="hero-subtitle">Les 10 premiers articles publiés — une plongée dans les thèmes fondateurs</p>

        <div class="stats-row">
          <div class="stat">
            <span class="stat-value">10</span>
            <span class="stat-label">articles</span>
          </div>
          <div class="stat-sep" aria-hidden="true">·</div>
          <div class="stat">
            <span class="stat-value">{totalReadingLabel}</span>
            <span class="stat-label">de lecture</span>
          </div>
          <div class="stat-sep" aria-hidden="true">·</div>
          <div class="stat">
            <span class="stat-value">33</span>
            <span class="stat-label">jours</span>
          </div>
          <div class="stat-sep" aria-hidden="true">·</div>
          <div class="stat">
            <span class="stat-value">3</span>
            <span class="stat-label">rubriques</span>
          </div>
        </div>

        <p class="hero-date-range">2 avril → 5 mai 2026</p>
      </div>
    </section>

    <!-- ─────────────────── CATEGORY BAR CHART ─────────────────── -->
    <section class="cat-section">
      <div class="cat-inner">
        <h2 class="cat-title">Répartition par rubrique</h2>
        <div class="cat-bars">
          <div class="cat-bar-item">
            <div class="cat-bar-label">
              <span class="cat-dot cat-dot--science" aria-hidden="true"></span>
              <span>Science</span>
            </div>
            <div class="cat-bar-track">
              <div class="cat-bar-fill cat-bar-fill--science" style={`width:${(catCounts.science / 10) * 100}%`}></div>
            </div>
            <span class="cat-bar-count">{catCounts.science} articles</span>
          </div>
          <div class="cat-bar-item">
            <div class="cat-bar-label">
              <span class="cat-dot cat-dot--societe" aria-hidden="true"></span>
              <span>Société</span>
            </div>
            <div class="cat-bar-track">
              <div class="cat-bar-fill cat-bar-fill--societe" style={`width:${(catCounts.societe / 10) * 100}%`}></div>
            </div>
            <span class="cat-bar-count">{catCounts.societe} articles</span>
          </div>
          <div class="cat-bar-item">
            <div class="cat-bar-label">
              <span class="cat-dot cat-dot--esprit" aria-hidden="true"></span>
              <span>Esprit</span>
            </div>
            <div class="cat-bar-track">
              <div class="cat-bar-fill cat-bar-fill--esprit" style={`width:${(catCounts.esprit / 10) * 100}%`}></div>
            </div>
            <span class="cat-bar-count">{catCounts.esprit} articles</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ─────────────────── FILTERS ─────────────────── -->
    <section class="filters-section">
      <div class="filters-inner">
        <button class="filter-btn filter-btn--active" data-filter="all">Tous</button>
        <button class="filter-btn" data-filter="science">Science</button>
        <button class="filter-btn" data-filter="esprit">Esprit</button>
        <button class="filter-btn" data-filter="societe">Société</button>
      </div>
    </section>

    <!-- ─────────────────── TIMELINE ─────────────────── -->
    <section class="timeline-section">
      <div class="timeline-inner">
        <div class="timeline-line" aria-hidden="true"></div>

        {articles.map((article, i) => (
          <article
            class={`tl-card tl-card--${article.category} ${i % 2 === 0 ? "tl-card--left" : "tl-card--right"}`}
            data-category={article.category}
          >
            <!-- Timeline dot -->
            <div class="tl-dot" aria-hidden="true">
              <span class="tl-dot-num">{article.num}</span>
            </div>

            <!-- Card content -->
            <div class="tl-card-body">
              <div class="tl-card-header">
                <span class={`tl-badge tl-badge--${article.category}`}>{article.categoryLabel}</span>
                <span class="tl-pillar">{article.pillar}</span>
              </div>

              <time class="tl-date" datetime={article.isoDate}>{article.date}</time>

              <h2 class="tl-title">
                <a href={`/fr/blog/${article.slug}/`} class="tl-title-link">
                  {article.title}
                </a>
              </h2>
              <p class="tl-subtitle">{article.subtitle}</p>

              <p class="tl-excerpt">{article.excerpt}</p>

              <div class="tl-footer">
                <span class="tl-time">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  {article.readingTime}
                </span>
                <div class="tl-tags">
                  {article.tags.slice(0, 3).map(tag => (
                    <span class="tl-tag">{tag}</span>
                  ))}
                </div>
              </div>

              <a href={`/fr/blog/${article.slug}/`} class="tl-cta" aria-label={`Lire : ${article.title}`}>
                Lire l'article
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </article>
        ))}

      </div>
    </section>

    <!-- ─────────────────── CLOSING ─────────────────── -->
    <section class="closing-section">
      <div class="closing-inner">
        <p class="closing-text">33 jours. 190 minutes de lecture. Le début d'un projet.</p>
        <a href="/fr/blog/" class="closing-btn">Voir tous les articles</a>
      </div>
    </section>

  </main>
</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const cards = document.querySelectorAll<HTMLElement>(".tl-card");

  filterBtns.forEach(btn => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter!;

      filterBtns.forEach(b => b.classList.remove("filter-btn--active"));
      btn.classList.add("filter-btn--active");

      cards.forEach(card => {
        const cat = card.dataset.category!;
        if (filter === "all" || cat === filter) {
          card.classList.remove("tl-card--dimmed");
          card.classList.add("tl-card--visible");
        } else {
          card.classList.remove("tl-card--visible");
          card.classList.add("tl-card--dimmed");
        }
      });
    });
  });

  // Scroll-triggered reveal
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          (entry.target as HTMLElement).classList.add("tl-card--revealed");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );

  cards.forEach(card => observer.observe(card));
</script>

<style>
  /* ── Page wrapper + CSS custom properties ── */
  .infographic-page {
    max-width: 100%;
    overflow-x: hidden;
    --c-science: #5b9fd4;
    --c-esprit: #f0a050;
    --c-societe: #5cc4b0;
    --c-science-s: rgba(91,159,212,0.12);
    --c-esprit-s: rgba(240,160,80,0.12);
    --c-societe-s: rgba(92,196,176,0.12);
  }

  /* ── Hero ── */
  .hero {
    padding: clamp(4rem, 10vw, 8rem) 1.5rem clamp(3rem, 6vw, 5rem);
    text-align: center;
    background: linear-gradient(160deg,
      color-mix(in srgb, var(--c-science) 6%, var(--surface)) 0%,
      var(--surface) 60%,
      color-mix(in srgb, var(--c-societe) 5%, var(--surface)) 100%
    );
    border-bottom: 1px solid var(--border-soft);
  }

  .hero-inner { max-width: 760px; margin: 0 auto; }

  .hero-eyebrow {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 0.75rem;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    font-weight: 500;
    font-style: italic;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--text-main);
    margin-bottom: 0.75rem;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--text-muted);
    line-height: 1.5;
    max-width: 540px;
    margin: 0 auto 2rem;
  }

  .stats-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.5rem 1.5rem;
    margin-bottom: 1rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
  }

  .stat-value {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 500;
    font-style: italic;
    color: var(--text-main);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .stat-sep {
    font-size: 1.5rem;
    color: var(--border-soft);
    font-weight: 300;
    align-self: center;
    margin-top: -0.5rem;
  }

  .hero-date-range {
    font-size: 0.88rem;
    color: var(--text-dim);
    font-style: italic;
    margin-top: 0.5rem;
  }

  /* ── Category bar chart ── */
  .cat-section {
    padding: 3rem 1.5rem;
    background: var(--surface-elevated, var(--surface));
    border-bottom: 1px solid var(--border-soft);
  }

  .cat-inner {
    max-width: 620px;
    margin: 0 auto;
  }

  .cat-title {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-style: italic;
    font-weight: 400;
    color: var(--text-main);
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .cat-bars { display: flex; flex-direction: column; gap: 1rem; }

  .cat-bar-item {
    display: grid;
    grid-template-columns: 120px 1fr 80px;
    align-items: center;
    gap: 0.75rem;
  }

  @media (max-width: 480px) {
    .cat-bar-item { grid-template-columns: 90px 1fr 60px; gap: 0.5rem; }
  }

  .cat-bar-label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-muted);
  }

  .cat-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .cat-dot--science { background: var(--c-science); }
  .cat-dot--esprit  { background: var(--c-esprit); }
  .cat-dot--societe { background: var(--c-societe); }

  .cat-bar-track {
    height: 10px;
    background: var(--border-soft);
    border-radius: 99px;
    overflow: hidden;
  }

  .cat-bar-fill {
    height: 100%;
    border-radius: 99px;
    transform-origin: left;
    animation: bar-grow 1s var(--ease-out) both;
    animation-delay: 0.2s;
  }
  .cat-bar-fill--science { background: var(--c-science); }
  .cat-bar-fill--esprit  { background: var(--c-esprit); }
  .cat-bar-fill--societe { background: var(--c-societe); }

  @keyframes bar-grow {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }

  .cat-bar-count {
    font-size: 0.78rem;
    color: var(--text-dim);
    text-align: right;
  }

  /* ── Filters ── */
  .filters-section {
    padding: 1.5rem 1.5rem 0;
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--surface);
    border-bottom: 1px solid var(--border-soft);
  }

  .filters-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding-bottom: 1rem;
  }

  .filter-btn {
    padding: 0.4rem 1rem;
    border-radius: var(--radius-pill);
    border: 1.5px solid var(--border-soft);
    background: transparent;
    color: var(--text-muted);
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 200ms ease;
  }

  .filter-btn:hover {
    border-color: var(--text-dim);
    color: var(--text-main);
  }

  .filter-btn--active {
    background: var(--text-main);
    border-color: var(--text-main);
    color: var(--surface);
  }

  /* ── Timeline ── */
  .timeline-section {
    padding: 4rem 1.5rem 5rem;
  }

  .timeline-inner {
    max-width: 900px;
    margin: 0 auto;
    position: relative;
  }

  .timeline-line {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    transform: translateX(-50%);
    background: linear-gradient(to bottom,
      transparent,
      var(--border-soft) 5%,
      var(--border-soft) 95%,
      transparent
    );
  }

  @media (max-width: 680px) {
    .timeline-line { left: 24px; }
  }

  /* ── Timeline Card ── */
  .tl-card {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 48px 1fr;
    gap: 0;
    margin-bottom: 3rem;
    opacity: 0;
    transition: opacity 500ms ease, transform 500ms ease;
  }

  .tl-card--revealed {
    opacity: 1;
    transform: none !important;
  }

  .tl-card--dimmed {
    opacity: 0.18;
    pointer-events: none;
  }

  /* Left cards: content in col 1, dot in col 2 */
  .tl-card--left { transform: translateX(-20px); }
  .tl-card--left .tl-dot { grid-column: 2; grid-row: 1; }
  .tl-card--left .tl-card-body {
    grid-column: 1;
    grid-row: 1;
    text-align: right;
    align-items: flex-end;
    padding-right: 2rem;
  }
  .tl-card--left .tl-footer { justify-content: flex-end; flex-direction: row-reverse; }
  .tl-card--left .tl-tags { justify-content: flex-end; }

  /* Right cards: dot in col 2, content in col 3 */
  .tl-card--right { transform: translateX(20px); }
  .tl-card--right .tl-dot { grid-column: 2; grid-row: 1; }
  .tl-card--right .tl-card-body {
    grid-column: 3;
    grid-row: 1;
    text-align: left;
    align-items: flex-start;
    padding-left: 2rem;
  }

  /* Mobile: all cards go right of the line */
  @media (max-width: 680px) {
    .tl-card {
      grid-template-columns: 48px 1fr;
      gap: 0;
    }
    .tl-card--left .tl-dot,
    .tl-card--right .tl-dot {
      grid-column: 1;
      grid-row: 1;
    }
    .tl-card--left .tl-card-body,
    .tl-card--right .tl-card-body {
      grid-column: 2;
      grid-row: 1;
      text-align: left;
      align-items: flex-start;
      padding-left: 1.25rem;
      padding-right: 0;
    }
    .tl-card--left .tl-footer { flex-direction: row; justify-content: flex-start; }
    .tl-card--left .tl-tags { justify-content: flex-start; }
    .tl-card--left { transform: translateX(-10px); }
  }

  /* Dot */
  .tl-dot {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 0.25rem;
    z-index: 1;
  }

  .tl-dot-num {
    display: flex;
    align-items: center;
