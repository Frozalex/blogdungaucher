const totalMin = articles.reduce((s, a) => s + parseInt(a.readingTime), 0);
const catBreakdown = [
  { label: "Science",  key: "science",  count: 5, color: "#5b9fd4" },
  { label: "Société",  key: "societe",  count: 3, color: "#5cc4b0" },
  { label: "Esprit",   key: "esprit",   count: 2, color: "#f0a050" },
];
---

<BaseLayout
  title="Les 10 premiers articles — Infographie | Blog d'un Gaucher"
  description="Visualisation interactive des 10 premières publications du Blog d'un Gaucher : timeline éditoriale, répartition par rubrique, 190 minutes de lecture."
  canonicalPath="/fr/infographie/"
  omitEnDeAlternateLinks={true}
>

<div class="igp">

  <!-- ════════════ HERO ════════════ -->
  <header class="hero">
    <div class="hero-grid">
      <!-- Background texture: faint chess squares -->
      <div class="chess-bg" aria-hidden="true">
        {Array.from({length:64}).map((_,i) => (
          <div class={`sq ${(Math.floor(i/8)+i)%2===0 ? "sq--dark" : ""}`}></div>
        ))}
      </div>

      <div class="hero-content">
        <p class="hero-label">Blog d'un Gaucher · 2026</p>
        <h1 class="hero-title">
          <span class="hero-title-line1">Naissance</span>
          <span class="hero-title-line2">d'un blog</span>
        </h1>
        <p class="hero-sub">Les 10 premières publications — une plongée dans les thèmes fondateurs</p>

        <div class="hero-stats">
          <div class="hstat">
            <span class="hstat-n">10</span>
            <span class="hstat-l">articles</span>
          </div>
          <div class="hstat-div" aria-hidden="true"></div>
          <div class="hstat">
            <span class="hstat-n">3<span class="hstat-unit">h</span>10</span>
            <span class="hstat-l">de lecture</span>
          </div>
          <div class="hstat-div" aria-hidden="true"></div>
          <div class="hstat">
            <span class="hstat-n">33</span>
            <span class="hstat-l">jours</span>
          </div>
          <div class="hstat-div" aria-hidden="true"></div>
          <div class="hstat">
            <span class="hstat-n">3</span>
            <span class="hstat-l">rubriques</span>
          </div>
        </div>

        <p class="hero-range">2 avril <span class="hero-arrow">→</span> 5 mai 2026</p>
      </div>
    </div>
  </header>

  <!-- ════════════ DISTRIBUTION ════════════ -->
  <section class="distrib">
    <div class="distrib-inner">
      <p class="section-label">Répartition par rubrique</p>
      <div class="distrib-grid">
        {catBreakdown.map(cat => (
          <div class="dcat" style={`--acc:${cat.color}`}>
            <span class="dcat-n">{cat.count}<span class="dcat-of">/10</span></span>
            <span class="dcat-name">{cat.label}</span>
            <div class="dcat-bar">
              <div class="dcat-fill" style={`width:${cat.count*10}%`}></div>
            </div>
            <span class="dcat-pct">{cat.count * 10} %</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════ FILTERS ════════════ -->
  <div class="filters-wrap">
    <div class="filters">
      <button class="fbtn fbtn--on" data-f="all">Tous</button>
      <button class="fbtn" data-f="science">Science</button>
      <button class="fbtn" data-f="esprit">Esprit</button>
      <button class="fbtn" data-f="societe">Société</button>
    </div>
  </div>

  <!-- ════════════ ARTICLE LIST ════════════ -->
  <section class="alist">
    {articles.map((a, i) => (
      <article
        class={`arow arow--${a.category}`}
        data-cat={a.category}
        style={`--delay:${i * 60}ms`}
      >
        <!-- Ghost number -->
        <span class="arow-ghost" aria-hidden="true">{a.num}</span>

        <div class="arow-inner">
          <!-- Left: number + meta -->
          <div class="arow-left">
            <span class="arow-num">{a.num}</span>
            <div class="arow-meta">
              <span class="arow-badge">{a.categoryLabel}</span>
              <span class="arow-pillar">{a.pillar}</span>
            </div>
          </div>

          <!-- Center: title + content -->
          <div class="arow-center">
            <time class="arow-date" datetime={a.isoDate}>{a.date}</time>
            <h2 class="arow-title">
              <a class="arow-link" href={`/fr/blog/${a.slug}/`}>{a.title}</a>
            </h2>
            <p class="arow-subtitle">{a.subtitle}</p>
            <p class="arow-excerpt">{a.excerpt}</p>
            <div class="arow-tags">
              {a.tags.map(t => <span class="arow-tag">{t}</span>)}
            </div>
          </div>

          <!-- Right: time + CTA -->
          <div class="arow-right">
            <div class="arow-time">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <span>{a.readingTime} min</span>
            </div>
            <a class="arow-cta" href={`/fr/blog/${a.slug}/`} aria-label={`Lire : ${a.title}`}>
              Lire
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </article>
    ))}
  </section>

  <!-- ════════════ CLOSING ════════════ -->
  <footer class="closing">
    <div class="closing-inner">
      <p class="closing-q">33 jours.</p>
      <p class="closing-q">{totalMin} minutes de lecture.</p>
      <p class="closing-q closing-q--dim">Le début d'un projet.</p>
      <a class="closing-btn" href="/fr/blog/">
        Voir tous les articles
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </footer>

</div>
</BaseLayout>

<!-- ════════════ SCRIPT ════════════ -->
<script>
  // Category filter
  const btns = document.querySelectorAll<HTMLButtonElement>(".fbtn");
  const rows = document.querySelectorAll<HTMLElement>(".arow");

  btns.forEach(btn => {
    btn.addEventListener("click", () => {
      btns.forEach(b => b.classList.remove("fbtn--on"));
      btn.classList.add("fbtn--on");
      const f = btn.dataset.f!;
      rows.forEach(r => {
        if (f === "all" || r.dataset.cat === f) {
          r.classList.remove("arow--fade");
        } else {
          r.classList.add("arow--fade");
        }
      });
    });
  });

  // Scroll reveal
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).classList.add("arow--in");
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });

  rows.forEach(r => io.observe(r));

  // Bar animation on load
  document.querySelectorAll<HTMLElement>(".dcat-fill").forEach(el => {
    const w = el.style.width;
    el.style.width = "0";
    requestAnimationFrame(() => {
      el.style.transition = "width 1.2s cubic-bezier(0.16,1,0.3,1)";
      el.style.width = w;
    });
  });
</script>

<!-- ════════════ STYLES ════════════ -->
<style>
  /* ── Forced editorial dark shell ── */
  .igp {
    --bg:   #0c0c0c;
    --bg2:  #111111;
    --bg3:  #161616;
    --fg:   #f0ede6;
    --fg2:  #8a8680;
    --fg3:  #3a3832;
    --line: #1e1e1c;
    --c-sci:#5b9fd4;
    --c-esp:#f0a050;
    --c-soc:#5cc4b0;
    --fw-display: 600;
    background: var(--bg);
    color: var(--fg);
    font-family: var(--font-sans, "Space Grotesk", sans-serif);
  }

  /* ── Hero ── */
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
  }

  .hero-grid {
    position: relative;
    min-height: 88vh;
    display: flex;
    align-items: center;
    padding: clamp(5rem, 12vw, 9rem) clamp(1.5rem, 6vw, 5rem);
  }

  /* Chess background */
  .chess-bg {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    grid-template-rows: repeat(8, 1fr);
    opacity: 0.028;
    pointer-events: none;
    user-select: none;
  }
  .sq { background: transparent; }
  .sq--dark { background: var(--fg); }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 780px;
  }

  .hero-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg2);
    margin-bottom: 2.5rem;
  }

  .hero-title {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 1.75rem;
    line-height: 0.88;
  }

  .hero-title-line1 {
    font-family: var(--font-serif, "Fraunces", Georgia, serif);
    font-size: clamp(4rem, 12vw, 9.5rem);
    font-weight: 300;
    font-style: italic;
    letter-spacing: -0.03em;
    color: var(--fg);
    display: block;
  }

  .hero-title-line2 {
    font-family: var(--font-serif, "Fraunces", Georgia, serif);
    font-size: clamp(4rem, 12vw, 9.5rem);
    font-weight: 300;
    font-style: italic;
    letter-spacing: -0.03em;
    /* Outlined / ghost text for second line */
    -webkit-text-stroke: 1px color-mix(in srgb, var(--fg) 35%, transparent);
    color: transparent;
    display: block;
  }

  .hero-sub {
    font-size: clamp(0.9rem, 1.6vw, 1.05rem);
    color: var(--fg2);
    line-height: 1.6;
    max-width: 440px;
    margin-bottom: 3rem;
  }

  /* Stats */
  .hero-stats {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0;
    margin-bottom: 2rem;
  }

  .hstat {
    display: flex;
    flex-direction: column;
    padding: 0 2rem 0 0;
  }
  .hstat:first-child { padding-left: 0; }

  .hstat-n {
    font-family: var(--font-serif, serif);
    font-size: clamp(2.2rem, 4.5vw, 3.5rem);
    font-weight: 300;
    font-style: italic;
    color: var(--fg);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .hstat-unit {
    font-size: 0.6em;
    font-style: italic;
  }

  .hstat-l {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg2);
    margin-top: 0.2rem;
  }

  .hstat-div {
    width: 1px;
    height: 2.5rem;
    background: var(--fg3);
    margin-right: 2rem;
    flex-shrink: 0;
    align-self: center;
  }

  .hero-range {
    font-size: 0.82rem;
    color: var(--fg2);
    letter-spacing: 0.06em;
  }

  .hero-arrow {
    display: inline-block;
    margin: 0 0.4em;
    opacity: 0.5;
  }

  /* ── Distribution ── */
  .distrib {
    background: var(--bg2);
    border-bottom: 1px solid var(--line);
    padding: clamp(3rem, 6vw, 5rem) clamp(1.5rem, 6vw, 5rem);
  }

  .distrib-inner { max-width: 860px; }

  .section-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg2);
    margin-bottom: 2.5rem;
  }

  .distrib-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
  }

  @media (max-width: 600px) {
    .distrib-grid { grid-template-columns: 1fr; gap: 2rem; }
  }

  .dcat {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .dcat-n {
    font-family: var(--font-serif, serif);
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 300;
    font-style: italic;
    color: var(--acc);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .dcat-of {
    font-size: 0.4em;
    color: var(--fg2);
    font-style: normal;
    font-weight: 400;
  }

  .dcat-name {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--acc);
  }

  .dcat-bar {
    height: 2px;
    background: var(--line);
    border-radius: 99px;
    overflow: hidden;
    margin-top: 0.75rem;
  }

  .dcat-fill {
    height: 100%;
    background: var(--acc);
    border-radius: 99px;
  }

  .dcat-pct {
    font-size: 0.72rem;
    color: var(--fg2);
    margin-top: 0.25rem;
  }

  /* ── Filters ── */
  .filters-wrap {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--bg2);
    border-bottom: 1px solid var(--line);
    padding: 0 clamp(1.5rem, 6vw, 5rem);
  }

  .filters {
    display: flex;
    gap: 0;
    max-width: 860px;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .filters::-webkit-scrollbar { display: none; }

  .fbtn {
    padding: 1rem 1.25rem;
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    color: var(--fg2);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: color 200ms ease, border-color 200ms ease;
    white-space: nowrap;
    margin-bottom: -1px;
  }

  .fbtn:hover { color: var(--fg); }
  .fbtn--on {
    color: var(--fg);
    border-bottom-color: var(--fg);
  }

  /* ── Article list ── */
  .alist {
    max-width: 100%;
  }

  .arow {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
    background: var(--bg);
    transition: background 250ms ease, opacity 350ms ease, transform 500ms cubic-bezier(0.16,1,0.3,1);
    opacity: 0;
    transform: translateY(16px);
  }

  .arow--in {
    opacity: 1;
    transform: none;
  }

  .arow--fade {
    opacity: 0.1;
    pointer-events: none;
  }

  /* Left accent line per category */
  .arow::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--acc-c);
    opacity: 0;
    transition: opacity 250ms ease;
  }
  .arow:hover::before { opacity: 1; }

  .arow--science { --acc-c: var(--c-sci); }
  .arow--esprit  { --acc-c: var(--c-esp); }
  .arow--societe { --acc-c: var(--c-soc); }

  /* Ghost big number */
  .arow-ghost {
    position: absolute;
    right: -0.1em;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-serif, serif);
    font-size: clamp(6rem, 16vw, 14rem);
    font-weight: 300;
    font-style: italic;
    color: var(--fg);
    opacity: 0.025;
    line-height: 1;
    pointer-events: none;
    user-select: none;
    letter-spacing: -0.06em;
  }

  .arow:hover .arow-ghost { opacity: 0.045; }

  /* Row inner layout */
  .arow-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 120px 1fr 120px;
    gap: 0 2rem;
    padding: clamp(1.75rem, 3vw, 2.5rem) clamp(1.5rem, 6vw, 5rem);
    align-items: start;
    transition: background 250ms ease;
  }

  .arow:hover .arow-inner {
    background: rgba(255,255,255,0.02);
  }

  @media (max-width: 740px) {
    .arow-inner {
      grid-template-columns: 64px 1fr;
      grid-template-rows: auto auto;
    }
