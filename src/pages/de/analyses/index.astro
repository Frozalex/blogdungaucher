---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import { categoryMap, siteConfig } from "../../../data/site";
import { buildBreadcrumbJsonLd } from "../../../utils/blog";

const category = categoryMap.analyses;
const analysesAvailable = siteConfig.features.analysesAvailable;

const structuredData = buildBreadcrumbJsonLd([
  { name: "Startseite", path: "/de/" },
  { name: "Analyse", path: "/de/analyses/" },
]);
---
<BaseLayout
  title="Stockfish-Analyse | Blog d'un Gaucher"
  description="Importiere PGN oder FEN, spiele Züge auf einem interaktiven Brett und erhalte die Stockfish-Bewertung live."
  canonicalPath="/de/analyses/"
  lang="de"
  structuredData={structuredData}
  accentColor={category.accent}
>
  <section class="analysis-page" style={`--c:${category.accent}`}>
    <div class="container">
      <Breadcrumb items={[
        { label: "Startseite", href: "/de/" },
        { label: "Analyse" },
      ]} />

      <header class="analysis-hero reveal">
        <span class="eyebrow">{category.shortLabel}</span>
        <h1>Analyse en direct avec Stockfish</h1>
        <p>
          Colle un <strong>FEN</strong> ou un <strong>PGN</strong>, puis laisse Stockfish
          évaluer la position. Tu peux aussi jouer des coups directement sur l'échiquier.
        </p>
      </header>

      <div class:list={["analysis-shell", analysesAvailable ? "is-live" : "is-disabled"]}>
        {!analysesAvailable && (
          <div class="analysis-overlay reveal" role="status" aria-live="polite">
            <span class="overlay-badge">Indisponible</span>
            <h2>La fonctionnalité d'analyse est temporairement hors ligne.</h2>
            <p>
              La page reste visible pour te montrer ce qui est prévu, mais l'outil Stockfish
              n'est pas accessible pour le moment. Il reviendra prochainement dans une version
              plus stable.
            </p>
            <p>
              Tu peux suivre les annonces sur le blog ou nous contacter via
              <a href="mailto:contact@blogdungaucher.com"> contact@blogdungaucher.com</a>.
            </p>
          </div>
        )}

        <div class="analysis-grid reveal-group" aria-hidden={!analysesAvailable}>
        <section class="panel panel-input">
          <h2>Importer une position</h2>
          <p class="panel-lead">
            Le détecteur choisit automatiquement FEN ou PGN selon le contenu.
          </p>
          <textarea
            id="position-input"
            spellcheck="false"
            placeholder="Colle ici ton FEN ou ton PGN..."
          ></textarea>

          <div class="input-actions">
            <button id="load-position" class="button-primary" type="button">
              Charger la position
            </button>
            <label class="file-btn" for="position-file">
              Importer un fichier .pgn/.fen
            </label>
            <input id="position-file" type="file" accept=".pgn,.fen,.txt" />
          </div>

          <p id="status-line" class="status">Prêt. Charge une position pour commencer.</p>
        </section>

        <section class="panel panel-board">
          <div class="board-wrap">
            <div class="eval-wrap" aria-hidden="true">
              <div class="eval-bar">
                <span id="eval-fill"></span>
              </div>
              <div id="eval-label" class="eval-label">0.0</div>
            </div>

            <div class="board-col">
              <div id="captured-black" class="captured-row captured-top"></div>
              <chess-board id="analysis-board" draggable-pieces position="start"></chess-board>
              <div id="captured-white" class="captured-row captured-bottom"></div>
            </div>
          </div>

          <div id="turn-indicator" class="turn-indicator">
            <span class="turn-dot"></span>
            <span class="turn-text">Trait aux Blancs</span>
          </div>

          <div class="engine-line">
            <p><strong>Profondeur :</strong> <span id="engine-depth">-</span></p>
            <p><strong>Meilleur coup :</strong> <span id="engine-bestmove">-</span></p>
            <p><strong>Variante :</strong> <span id="engine-pv">-</span></p>
            <div class="depth-control">
              <label for="engine-depth-range">Profondeur cible</label>
              <input id="engine-depth-range" type="range" min="8" max="22" step="1" value="14" />
              <span id="engine-depth-value">14</span>
            </div>
          </div>

          <div class="board-actions">
            <button id="undo-move" type="button" title="Annuler le dernier coup" aria-label="Annuler le dernier coup">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 14L4 9l5-5"/><path d="M20 20v-7a4 4 0 00-4-4H4"/></svg>
              Annuler
            </button>
            <button id="reset-board" type="button" title="Revenir à la position initiale" aria-label="Revenir à la position initiale">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 119 9"/><path d="M3 3v9h9"/></svg>
              Réinitialiser
            </button>
            <button id="flip-board" type="button" title="Tourner l'échiquier (F)" aria-label="Tourner l'échiquier">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 16V4m0 0L3 8m4-4l4 4"/><path d="M17 8v12m0 0l4-4m-4 4l-4-4"/></svg>
              Tourner
            </button>
            <button id="play-bestmove" type="button" title="Jouer le meilleur coup Stockfish" aria-label="Jouer le meilleur coup Stockfish">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              Meilleur coup
            </button>
          </div>
        </section>

        <section class="panel panel-moves">
          <h2>Notation des coups</h2>
          <div class="nav-controls">
            <button id="review-first" type="button" title="Première position (Home)" aria-label="Première position">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 19l-7-7 7-7"/><path d="M18 19l-7-7 7-7"/></svg>
            </button>
            <button id="review-prev" type="button" title="Coup précédent (←)" aria-label="Coup précédent">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
            </button>
            <button id="review-next" type="button" title="Coup suivant (→)" aria-label="Coup suivant">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
            </button>
            <button id="review-last" type="button" title="Dernière position (End)" aria-label="Dernière position">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 5l7 7-7 7"/><path d="M6 5l7 7-7 7"/></svg>
            </button>
          </div>
          <div id="moves-list" class="moves-list"></div>
          <p class="shortcuts-hint">
            <kbd>←</kbd> <kbd>→</kbd> naviguer &middot;
            <kbd>Home</kbd> <kbd>End</kbd> début/fin &middot;
            <kbd>F</kbd> tourner
          </p>
        </section>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .analysis-page {
    padding: 3rem 0 4rem;
  }

  .analysis-hero {
    margin: 0.4rem 0 1.4rem;
    max-width: 48rem;
  }

  .analysis-hero h1 {
    margin: 0.55rem 0 0.7rem;
    color: var(--c);
    font-size: clamp(2rem, 4.5vw, 3.2rem);
  }

  .analysis-hero p {
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 42rem;
  }

  .analysis-hero strong {
    color: var(--c);
  }

  .analysis-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr) minmax(0, 0.8fr);
    gap: 1rem;
    align-items: start;
  }

  .analysis-shell {
    position: relative;
  }

  .analysis-shell.is-disabled .analysis-grid {
    filter: grayscale(1) blur(1.2px);
    opacity: 0.45;
    pointer-events: none;
    user-select: none;
  }

  .analysis-overlay {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: grid;
    place-items: center;
    padding: 1rem;
  }

  .analysis-overlay > * {
    max-width: 36rem;
  }

  .analysis-overlay::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: var(--radius-xl);
    background:
      linear-gradient(180deg, rgba(235, 235, 235, 0.58), rgba(214, 214, 214, 0.72)),
      rgba(255, 255, 255, 0.24);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(130, 130, 130, 0.18);
    box-shadow: var(--shadow-sm);
  }

  .analysis-overlay h2,
  .analysis-overlay p,
  .overlay-badge {
    position: relative;
    z-index: 1;
  }

  .overlay-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.9rem;
    padding: 0 0.85rem;
    border-radius: var(--radius-pill);
    background: rgba(84, 84, 84, 0.11);
    border: 1px solid rgba(84, 84, 84, 0.16);
    color: rgba(50, 50, 50, 0.88);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    justify-self: center;
    margin-bottom: 0.85rem;
  }

  .analysis-overlay h2 {
    text-align: center;
    font-size: clamp(1.25rem, 3vw, 2rem);
    margin-bottom: 0.7rem;
    color: #2e2e2e;
  }

  .analysis-overlay p {
    text-align: center;
    color: rgba(46, 46, 46, 0.78);
    line-height: 1.75;
    max-width: 34rem;
  }

  .panel {
    border: 1px solid var(--border-soft);
    background: var(--surface);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xs);
    padding: 1rem;
  }

  .panel h2 {
    font-size: 1.03rem;
    margin-bottom: 0.45rem;
  }

  .panel-lead {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 0.6rem;
  }

  textarea {
    width: 100%;
    min-height: 11rem;
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-md);
    background: var(--bg-warm);
    padding: 0.75rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    font-size: 0.82rem;
    color: var(--text-main);
    resize: vertical;
  }

  .input-actions {
    margin-top: 0.7rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .file-btn,
  .board-actions button {
    border: 1px solid var(--border-soft);
    background: var(--surface-warm);
    color: var(--text-main);
    border-radius: var(--radius-pill);
    padding: 0.52rem 0.9rem;
    font-size: 0.84rem;
    font-weight: 600;
    cursor: pointer;
    transition: transform 180ms var(--ease-spring), border-color 180ms ease;
  }

  .file-btn:hover,
  .board-actions button:hover {
    transform: translateY(-1px);
    border-color: var(--c);
  }

  #position-file {
    display: none;
  }

  .status {
    margin-top: 0.7rem;
    font-size: 0.83rem;
    color: var(--text-dim);
  }

  .board-wrap {
    display: grid;
    grid-template-columns: 0.5rem minmax(0, 1fr);
    gap: 0.7rem;
    align-items: stretch;
  }

  .board-col {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .eval-wrap {
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    align-items: stretch;
    gap: 0.4rem;
  }

  .eval-bar {
    border: 1px solid var(--border-soft);
    border-radius: 999px;
    overflow: hidden;
    background: #111;
    min-height: 22rem;
    position: relative;
  }

  .eval-bar span {
    display: block;
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 50%;
    background: #f3f3f1;
    transition: height 280ms ease;
  }

  .eval-label {
    font-size: 0.8rem;
    color: var(--text-muted);
    text-align: center;
    font-weight: 700;
  }

  /* -- Captured pieces -- */
  .captured-row {
    min-height: 1.4rem;
    padding: 0.15rem 0.2rem;
    display: flex;
    align-items: center;
    gap: 0.15rem;
    font-size: 0.95rem;
    line-height: 1;
  }

  :global(.captured-pieces) {
    letter-spacing: -0.05em;
    opacity: 0.85;
  }

  :global(.mat-diff) {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--c);
    margin-left: 0.3rem;
  }

  /* -- Turn indicator -- */
  .turn-indicator {
    margin-top: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-main);
  }

  .turn-dot {
    display: inline-block;
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 50%;
    background: #fff;
    border: 1.5px solid var(--border-soft);
    transition: background 150ms ease;
  }

  chess-board {
    width: 100%;
    max-width: 36rem;
    margin: 0 auto;
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .engine-line {
    margin-top: 0.7rem;
    display: grid;
    gap: 0.3rem;
    font-size: 0.84rem;
    color: var(--text-muted);
  }

  .engine-line strong {
    color: var(--text-main);
  }

  .depth-control {
    margin-top: 0.2rem;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.5rem;
    align-items: center;
  }

  .depth-control label {
    color: var(--text-main);
    font-weight: 600;
    font-size: 0.8rem;
  }

  .depth-control input[type="range"] {
    accent-color: var(--c);
  }

  .depth-control span {
    min-width: 1.8rem;
    text-align: right;
    color: var(--text-main);
    font-weight: 700;
    font-size: 0.82rem;
  }

  .board-actions {
    margin-top: 0.8rem;
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .board-actions button {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  /* -- Navigation controls (chess.com style bar) -- */
  .nav-controls {
    display: flex;
    gap: 0;
    margin-top: 0.25rem;
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--surface-warm);
  }

  .nav-controls button {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.55rem 0;
    border: none;
    background: transparent;
    color: var(--text-main);
    cursor: pointer;
    transition: background 120ms ease, color 120ms ease;
  }

  .nav-controls button:hover {
    background: var(--c);
    color: #fff;
  }

  .nav-controls button:active {
    opacity: 0.8;
  }

  .nav-controls button + button {
    border-left: 1px solid var(--border-soft);
  }

  /* -- Move list (chess.com style) -- */
  .moves-list {
    margin-top: 0.55rem;
    max-height: 28rem;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--border-soft) transparent;
  }

  :global(.moves-empty) {
    padding: 1rem;
    text-align: center;
    color: var(--text-dim);
    font-size: 0.85rem;
  }

  :global(.move-row) {
    display: grid;
    grid-template-columns: 2.2rem 1fr 1fr;
    align-items: center;
    border-bottom: 1px solid color-mix(in srgb, var(--border-soft) 50%, transparent);
  }

  :global(.move-row:nth-child(odd)) {
    background: color-mix(in srgb, var(--surface-warm) 60%, transparent);
  }

  :global(.move-num) {
    font-size: 0.78rem;
    color: var(--text-dim);
    text-align: right;
    padding-right: 0.4rem;
    font-weight: 600;
    user-select: none;
  }

  :global(.move-btn) {
    border: none;
    background: transparent;
    color: var(--text-main);
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.38rem 0.5rem;
    cursor: pointer;
    text-align: left;
    transition: background 100ms ease, color 100ms ease;
    font-family: inherit;
  }

  :global(.move-btn:hover) {
    background: color-mix(in srgb, var(--c) 15%, transparent);
  }

  :global(.move-btn.active) {
    background: var(--c);
    color: #fff;
    font-weight: 700;
  }

  /* -- Keyboard shortcuts hint -- */
  .shortcuts-hint {
    margin-top: 0.6rem;
    font-size: 0.72rem;
    color: var(--text-dim);
    text-align: center;
    line-height: 1.6;
  }

  .shortcuts-hint kbd {
    display: inline-block;
    padding: 0.08rem 0.35rem;
    border: 1px solid var(--border-soft);
    border-radius: 3px;
    background: var(--surface-warm);
    font-family: inherit;
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--text-muted);
    box-shadow: 0 1px 0 var(--border-soft);
  }

  @media (max-width: 1120px) {
    .analysis-grid {
      grid-template-columns: 1fr;
    }
    .eval-bar {
      min-height: 14rem;
    }
  }
</style>

{analysesAvailable && (
  <script>
    import "../../../scripts/analysis";
  </script>
)}
