---
import type { GetStaticPathsOptions, Page } from "astro";
import type { BlogEntry } from "../../../utils/blog";

import AdBanner from "../../../components/AdBanner.astro";
import ArticleCard from "../../../components/ArticleCard.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";

import { categoryMap, categorySlugs } from "../../../data/site";
import {
  buildBreadcrumbJsonLd,
  buildWebsiteJsonLd,
  filterPostsForLang,
  getAllPosts,
  getBlogIndexPagePath,
} from "../../../utils/blog";

const listingCategorySlugs = categorySlugs.filter((s) => s !== "grand-oral");

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = filterPostsForLang(await getAllPosts(), "de");
  return paginate(posts, { pageSize: 9 });
}

const { page } = Astro.props as { page: Page<BlogEntry> };
const isFirstPage = page.currentPage === 1;

const MAX_PAGINATION_LINKS = 7;
function buildPageLinks(current: number, total: number) {
  if (total <= MAX_PAGINATION_LINKS) {
    return Array.from({ length: total }, (_, index) => index + 1);
  }

  const pages = new Set<number>([1, total, current, current - 1, current + 1]);
  if (current <= 3) [2, 3, 4].forEach((n) => pages.add(n));
  if (current >= total - 2) [total - 1, total - 2, total - 3].forEach((n) => pages.add(n));

  return [...pages]
    .filter((n) => n >= 1 && n <= total)
    .sort((a, b) => a - b);
}

const paginationPages = buildPageLinks(page.currentPage, page.lastPage);

const prevPageHref =
  page.currentPage > 1
    ? getBlogIndexPagePath("de", page.currentPage - 1)
    : undefined;
const nextPageHref =
  page.currentPage < page.lastPage
    ? getBlogIndexPagePath("de", page.currentPage + 1)
    : undefined;

const structuredData = isFirstPage
  ? [buildWebsiteJsonLd(), buildBreadcrumbJsonLd([{ name: "Startseite", path: "/de/" }, { name: "Artikel", path: "/de/blog/" }])]
  : undefined;
---
<BaseLayout
  title={isFirstPage ? "Alle Artikel | Blog d'un Gaucher" : `Artikel - Seite ${page.currentPage} | Blog d'un Gaucher`}
  description="Die vollständige Bibliothek : Wissenschaft, Geist, Gesellschaft und Analysen."
  canonicalPath={isFirstPage ? "/de/blog/" : `/de/blog/${page.currentPage}/`}
  lang="de"
  noindex={!isFirstPage}
  structuredData={structuredData}
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow reveal" data-t="blog.eyebrow">Bibliothek</span>
      <h1 class="reveal" data-t="blog.title">Alle Artikel</h1>
      <p class="page-lead reveal" data-t="blog.lead">
        Spielwissenschaft, Wettkampfgeist, Schach und Gesellschaft, persönliche Analysen.
      </p>
      <div class="chips reveal" id="category-chips">
        <button class="chip is-active" type="button" data-filter-category="all" data-t="blog.filterAll">
          Alle
        </button>
        {listingCategorySlugs.map((slug) => (
          <button type="button" class="chip" data-filter-category={slug} style={`--c:${categoryMap[slug].accent}`} data-t={`categories.${slug}.label`}>
            {categoryMap[slug].label}
          </button>
        ))}
      </div>
      <div class="search-wrap reveal">
        <label for="blog-search" class="search-label" data-t="blog.searchLabel">Artikel suchen</label>
        <input id="blog-search" class="search-input" type="search" placeholder="Titel, Auszug oder Stichwort…" data-t-placeholder="blog.searchPlaceholder" />
      </div>
    </div>
  </section>

  <div class="container">
    <AdBanner format="leaderboard" />
  </div>

  <section class="listing">
    <div class="container">
      <div class="post-grid reveal-group">
        {page.data.map((post) => (
          <article
            class="post-item"
            data-category={post.data.category}
            data-search={`${post.data.title} ${post.data.excerpt} ${post.data.tags?.join(" ") ?? ""}`.toLowerCase()}
          >
            <ArticleCard post={post} lang="de" />
          </article>
        ))}
      </div>
      <p id="listing-empty" class="listing-empty" hidden data-t="blog.noResults">
        Kein Artikel entspricht deiner Suche auf dieser Seite.
      </p>

      <!-- Pagination -->
      {page.lastPage > 1 && (
        <nav class="pagination" aria-label="Seitennavigation">
          {prevPageHref ? (
            <a href={prevPageHref} class="pag-arrow" rel="prev" aria-label="Vorherige Seite">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
              <span data-t="blog.prev">Zurück</span>
            </a>
          ) : (
            <span class="pag-arrow is-disabled" aria-hidden="true"></span>
          )}

          <div class="pag-center">
            <span class="pag-label">Seite</span>
            <span class="pag-current">{String(page.currentPage).padStart(2, "0")}</span>
            <span class="pag-sep" aria-hidden="true">·</span>
            <span class="pag-total">{String(page.lastPage).padStart(2, "0")}</span>
          </div>

          {nextPageHref ? (
            <a href={nextPageHref} class="pag-arrow" rel="next" aria-label="Nächste Seite">
              <span data-t="blog.next">Weiter</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
            </a>
          ) : (
            <span class="pag-arrow is-disabled" aria-hidden="true"></span>
          )}
        </nav>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { padding: 4.5rem 0 2rem; }
  .page-hero h1 { font-size: clamp(2.4rem, 6vw, 4rem); margin: 0.5rem 0 0.75rem; }
  .page-lead { color: var(--text-muted); font-size: 1.05rem; max-width: 32rem; }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.25rem;
  }
  .search-wrap {
    margin-top: 0.9rem;
    max-width: 28rem;
  }
  .search-label {
    display: block;
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-bottom: 0.35rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }
  .search-input {
    width: 100%;
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-md);
    background: var(--surface);
    color: var(--text-main);
    min-height: 2.5rem;
    padding: 0 0.75rem;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    min-height: 1.8rem;
    padding: 0 0.75rem;
    border-radius: var(--radius-pill);
    border: 1.5px solid var(--c);
    color: var(--c);
    font-size: 0.8rem;
    font-weight: 600;
    transition: background 160ms ease, color 160ms ease, transform 200ms var(--ease-spring);
    cursor: pointer;
    background: transparent;
  }
  .chip:hover {
    background: var(--c);
    color: #fff;
    transform: translateY(-2px);
  }
  .chip.is-active {
    background: var(--c, var(--text-main));
    color: #fff;
    border-color: var(--c, var(--text-main));
  }

  .listing { padding: 1.5rem 0 5rem; }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: 0.85rem;
  }
  .post-item[hidden] {
    display: none;
  }
  .listing-empty {
    margin-top: 1rem;
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  /* ── Pagination éditoriale ── */
  .pagination {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-soft);
  }
  .pag-arrow {
    display: inline-flex; align-items: center; gap: 0.45rem;
    padding: 0.55rem 0.95rem; border-radius: var(--radius-pill);
    color: var(--text-muted);
    font-family: var(--font-display);
    font-size: 0.82rem; font-weight: 600; letter-spacing: 0.02em;
    transition: color 160ms ease, background 160ms ease, transform 240ms var(--ease-spring);
    width: max-content;
  }
  .pag-arrow:first-child { justify-self: start; }
  .pag-arrow:last-child  { justify-self: end; }
  .pag-arrow:not(.is-disabled):hover { color: var(--green); background: var(--green-light); }
  .pag-arrow svg { transition: transform 240ms var(--ease-spring); }
  .pag-arrow:first-child:not(.is-disabled):hover svg { transform: translateX(-3px); }
  .pag-arrow:last-child:not(.is-disabled):hover svg  { transform: translateX(3px); }
  .pag-arrow.is-disabled { visibility: hidden; }

  .pag-center {
    display: inline-flex; align-items: baseline; gap: 0.55rem;
    color: var(--text-muted); white-space: nowrap;
  }
  .pag-label {
    font-family: var(--font-display); font-size: 0.7rem;
    font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--text-dim);
  }
  .pag-current {
    font-family: var(--font-serif); font-style: italic; font-weight: 500;
    font-size: clamp(1.7rem, 3.4vw, 2.1rem); line-height: 1;
    color: var(--green); letter-spacing: -0.01em; font-optical-sizing: auto;
  }
  .pag-sep { color: var(--border-strong); font-size: 1rem; }
  .pag-total {
    font-family: var(--font-serif); font-weight: 500;
    font-size: clamp(1rem, 1.8vw, 1.2rem);
    color: var(--text-dim); letter-spacing: -0.005em;
  }
  @media (max-width: 540px) {
    .pagination { grid-template-columns: auto 1fr auto; gap: 0.5rem; }
    .pag-arrow span { display: none; }
    .pag-arrow { padding: 0.5rem 0.7rem; }
  }
</style>

<script>
  function initBlogFilters() {
    const items = Array.from(document.querySelectorAll(".post-item"));
    const searchInput = document.getElementById("blog-search");
    const chips = Array.from(document.querySelectorAll("[data-filter-category]"));
    const empty = document.getElementById("listing-empty");
    if (!items.length || !searchInput || !chips.length || !empty) return;

    let activeCategory = "all";

    function applyFilters() {
      const query = searchInput.value.trim().toLowerCase();
      let visible = 0;

      items.forEach((item) => {
        const matchesCategory =
          activeCategory === "all" || item.dataset.category === activeCategory;
        const haystack = item.dataset.search ?? "";
        const matchesQuery = !query || haystack.includes(query);
        const show = matchesCategory && matchesQuery;
        item.hidden = !show;
        if (show) visible += 1;
      });

      empty.hidden = visible > 0;
    }

    chips.forEach((chip) => {
      chip.addEventListener("click", () => {
        activeCategory = chip.dataset.filterCategory ?? "all";
        chips.forEach((el) => el.classList.toggle("is-active", el === chip));
        applyFilters();
      });
    });

    searchInput.addEventListener("input", applyFilters);
    applyFilters();
  }

  document.addEventListener("astro:page-load", initBlogFilters);
</script>
