---
import AdBanner from "../../components/AdBanner.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import HomeCinematicBackground from "../../components/HomeCinematicBackground.astro";

import { categoryMap, categorySlugs } from "../../data/site";
import { buildWebsiteJsonLd, getLatestPosts } from "../../utils/blog";
import { swapLangPrefix } from "../../utils/lang-paths";

const latestPosts = await getLatestPosts(5, "de");
---
<BaseLayout
  title="Blog d'un Gaucher"
  description="Spielwissenschaft, Wettkampfgeist und Schach in der Gesellschaft. Ein Raum zum Teilen und Nachdenken."
  canonicalPath="/de/"
  lang="de"
  structuredData={buildWebsiteJsonLd()}
>
<HomeCinematicBackground>
  <!-- ─── HERO ─── -->
  <section class="hero">
    <div class="container hero__inner">
      <span class="eyebrow fade-up" style="--motion-delay: 40ms;" data-t="home.eyebrow">Éditorial indépendant</span>
      <h1 class="hero__title fade-up" style="--motion-delay: 120ms;" data-t-html="home.titleHtml">
        Comprendre les <span class="hero__accent display-serif">échecs</span><br/>sans simplifier le jeu.
      </h1>
      <p class="hero__lead fade-up" style="--motion-delay: 190ms;" data-t="home.lead">
        Chaque semaine, des analyses claires sur la science du jeu, le mental compétitif
        et l'impact des échecs dans la société, avec une approche humaine et exigeante.
      </p>
      <div class="hero__actions fade-up" style="--motion-delay: 250ms;">
        <a href="/de/blog/"      class="button-primary"   data-t="home.startReading">Zur Lektüre</a>
        <a href="#rubriques" class="button-secondary"  data-t="home.seeSections">Voir les rubriques</a>
      </div>
      <ul class="hero-proof fade-up" style="--motion-delay: 320ms;" aria-label="Repères éditoriaux">
        <li data-t="home.proof1">Articles de fond</li>
        <li data-t="home.proof2">Ton accessible</li>
        <li data-t="home.proof3">Approche rigoureuse</li>
      </ul>
    </div>
  </section>

  <section class="editorial-intro">
    <div class="container">
      <div class="editorial-note reveal scale-in" data-t="home.editorialNote">
        Ici, on ne promet pas des progrès magiques en 7 jours.
        On propose des idées solides, des exemples concrets et des analyses que tu peux appliquer
        à ta pratique, que tu sois joueur de club, compétiteur ou simple passionné.
      </div>
    </div>
  </section>

  <!-- ─── RUBRIQUES ─── -->
  <section class="pillars" id="rubriques">
    <div class="container">
      <span class="eyebrow reveal" data-t="home.sectionsEyebrow">4 Rubriken</span>
      <h2 class="section-title reveal" data-t="home.sectionsTitle">Ce dont on parle ici</h2>
      <hr class="section-divider reveal" />
      <div class="pillar-grid reveal-group">
        {categorySlugs.map((slug) => {
          const cat = categoryMap[slug];
          return (
            <a href={swapLangPrefix(cat.href, "de")} class="pillar" style={`--p:${cat.accent};`}>
              <span class="pillar__dot"></span>
              <div>
                <span class="pillar__kicker" data-t={`categories.${slug}.shortLabel`}>{cat.shortLabel}</span>
                <strong data-t={`categories.${slug}.label`}>{cat.label}</strong>
                <p data-t={`categories.${slug}.tagline`}>{cat.tagline}</p>
              </div>
              <svg class="pillar__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <div class="container">
    <AdBanner format="leaderboard" />
  </div>

  <!-- ─── ARTICLES RECENTS ─── -->
  <section class="latest">
    <div class="container">
      <div class="section-head reveal">
        <div>
          <span class="eyebrow" data-t="home.recentEyebrow">Récents</span>
          <h2 class="section-title" data-t="home.latestTitle">Derniers articles</h2>
        </div>
        <a href="/de/blog/" class="see-all link-underline" data-t="home.seeAll">Alle anzeigen →</a>
      </div>
      <div class="latest-grid reveal-group">
        {latestPosts.map((post, i) => (
          <ArticleCard post={post} featured={i === 0} lang="de" />
        ))}
      </div>
    </div>
  </section>
</HomeCinematicBackground>

</BaseLayout>

<style>
  /* ── HERO ─────────────────────────────────────────────── */
  .hero {
    position: relative;
    padding: 5.5rem 0 3.2rem;
  }

  .hero .container,
  .editorial-intro .container,
  .pillars .container,
  .latest .container {
    width: min(1280px, calc(100% - 2rem));
  }

  .hero__inner {
    max-width: 56rem;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .hero__title {
    position: relative;
    font-size: clamp(2.6rem, 6.5vw, 4.4rem);
    margin: 0.85rem 0 1.1rem;
  }
  .hero__title::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    width: min(520px, 70%);
    height: 180px;
    transform: translate(-50%, -50%);
    background: radial-gradient(
      closest-side,
      color-mix(in srgb, var(--green) 18%, transparent) 0%,
      transparent 75%
    );
    filter: blur(10px);
    z-index: -1;
    pointer-events: none;
  }

  .hero__accent {
    color: var(--green);
    font-size: 1.08em;
  }

  .hero__lead {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 44rem;
    margin-inline: auto;
    line-height: 1.75;
  }

  .hero__actions {
    display: flex;
    gap: 0.7rem;
    flex-wrap: wrap;
    margin-top: 1.75rem;
    justify-content: center;
  }

  .hero-proof {
    list-style: none;
    padding: 0;
    margin: 1.2rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    justify-content: center;
  }
  .hero-proof li {
    padding: 0.3rem 0.65rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--green-border);
    background: color-mix(in srgb, var(--green-light) 70%, #fff);
    color: var(--text-muted);
    font-size: 0.78rem;
    font-weight: 600;
  }

  .editorial-intro {
    padding: 0.5rem 0 1.6rem;
  }

  .editorial-intro .container {
    display: flex;
    justify-content: center;
  }

  /* ── PILLARS ──────────────────────────────────────────── */
  .pillars {
    padding: 0.8rem 0 3.5rem;
  }

  .pillars .container {
    text-align: center;
  }

  .pillar-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.65rem;
    margin-top: 1.4rem;
    align-items: stretch;
  }

  .pillar {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 1.1rem 1.2rem;
    border-radius: var(--radius-lg);
    border: 1.5px solid var(--border-soft);
    background: var(--surface);
    transition:
      transform    240ms var(--ease-spring),
      border-color 180ms ease,
      box-shadow   240ms var(--ease-out);
  }

  .pillar:hover {
    transform: translateY(-3px);
    border-color: var(--p);
    box-shadow: var(--shadow-sm);
  }

  .pillar__dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--p);
    flex-shrink: 0;
    margin-top: 0.35rem;
    transition: transform 240ms var(--ease-spring);
  }
  .pillar:hover .pillar__dot { transform: scale(1.5); }

  .pillar > div { flex: 1; }
  .pillar__kicker {
    display: inline-flex;
    margin-bottom: 0.2rem;
    font-size: 0.66rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    font-weight: 700;
  }
  .pillar strong {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text-main);
    margin-bottom: 0.18rem;
  }
  .pillar p {
    font-size: 0.84rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .pillar__arrow {
    color: var(--text-dim);
    flex-shrink: 0;
    margin-top: 0.2rem;
    transition: color 180ms ease, transform 240ms var(--ease-spring);
  }
  .pillar:hover .pillar__arrow {
    color: var(--p);
    transform: translateX(3px);
  }

  /* ── LATEST ───────────────────────────────────────────── */
  .latest {
    padding: 1.5rem 0 5rem;
  }

  .latest .container {
    text-align: center;
  }

  .section-head {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.4rem;
  }

  .see-all {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-muted);
    transition: color 160ms ease;
  }
  .see-all:hover { color: var(--green); }

  .latest-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.85rem;
    text-align: left;
  }

  /* premier article en pleine largeur */
  .latest-grid > :first-child {
    grid-column: 1 / -1;
  }

  /* ── RESPONSIVE ─────────────────────────────────────── */
  @media (max-width: 1120px) {
    .pillar-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 860px) {
    .pillar-grid,
    .latest-grid {
      grid-template-columns: 1fr;
    }
    .latest-grid > :first-child {
      grid-column: auto;
    }
  }

  @media (max-width: 560px) {
    .hero { padding: 3.5rem 0 3rem; }
    .hero .container,
    .editorial-intro .container,
    .pillars .container,
    .latest .container {
      width: min(1280px, calc(100% - 1.25rem));
    }
    .section-head { flex-direction: column; align-items: center; }
    .hero-proof li { font-size: 0.74rem; }
  }

</style>
