---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HomeLanding from "../../components/HomeLanding.astro";

import { buildWebsiteJsonLd, getLatestPosts } from "../../utils/blog";

const latestPosts = await getLatestPosts(5, "de");
---
<BaseLayout
  title="Blog d'un Gaucher"
  description="Spielwissenschaft, Wettkampfgeist und Schach in der Gesellschaft. Ein Raum zum Teilen und Nachdenken."
  canonicalPath="/de/"
  lang="de"
  structuredData={buildWebsiteJsonLd()}
>
  <HomeLanding lang="de" latestPosts={latestPosts} />
</BaseLayout>
