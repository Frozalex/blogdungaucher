---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HomeLanding from "../../components/HomeLanding.astro";

import { buildWebsiteJsonLd, getAllPosts, getLatestPosts, isFrenchOnlyPost } from "../../utils/blog";
import { categorySlugs } from "../../data/site";

const allPosts = await getAllPosts();
const totalPosts = allPosts.length;
const latestPosts = await getLatestPosts(6, "de");

const postsByCategory = Object.fromEntries(
  categorySlugs.map((slug) => [
    slug,
    allPosts.filter((p) => p.data.category === slug && !isFrenchOnlyPost(p)).length,
  ]),
) as Partial<Record<(typeof categorySlugs)[number], number>>;
---
<BaseLayout
  title="Blog d'un Gaucher"
  description="Spielwissenschaft, Wettkampfgeist und Schach in der Gesellschaft. Zwei Artikel pro Woche. Ein Raum zum Teilen und Nachdenken."
  canonicalPath="/de/"
  lang="de"
  structuredData={buildWebsiteJsonLd()}
>
  <HomeLanding lang="de" latestPosts={latestPosts} totalPosts={totalPosts} postsByCategory={postsByCategory} />
</BaseLayout>
