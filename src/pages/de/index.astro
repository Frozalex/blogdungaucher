---
import AdBanner from "../../components/AdBanner.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

import { categoryMap, categorySlugs } from "../../data/site";
import { buildWebsiteJsonLd, getLatestPosts } from "../../utils/blog";
import { swapLangPrefix } from "../../utils/lang-paths";

const latestPosts = await getLatestPosts(5, "de");
---
<BaseLayout
  title="Blog d'un Gaucher"
  description="Spielwissenschaft, Wettkampfgeist und Schach in der Gesellschaft. Ein Raum zum Teilen und Nachdenken."
  canonicalPath="/de/"
  lang="de"
  structuredData={buildWebsiteJsonLd()}
>

  <!-- в”Җв”Җв”Җ HERO в”Җв”Җв”Җ -->
  <section class="hero">
    <div class="hero-aurora" aria-hidden="true">
      <span class="aurora-orb aurora-orb--a"></span>
      <span class="aurora-orb aurora-orb--b"></span>
      <span class="aurora-orb aurora-orb--c"></span>
    </div>
    <canvas class="hero-canvas" id="heroCanvas" aria-hidden="true"></canvas>
    <div class="container hero__inner">
      <span class="eyebrow fade-up" style="--motion-delay: 40ms;" data-t="home.eyebrow">Гүditorial indГ©pendant</span>
      <h1 class="hero__title fade-up" style="--motion-delay: 120ms;" data-t-html="home.titleHtml">
        Comprendre les <span class="hero__accent display-serif">Г©checs</span><br/>sans simplifier le jeu.
      </h1>
      <p class="hero__lead fade-up" style="--motion-delay: 190ms;" data-t="home.lead">
        Chaque semaine, des analyses claires sur la science du jeu, le mental compГ©titif
        et l'impact des Г©checs dans la sociГ©tГ©, avec une approche humaine et exigeante.
      </p>
      <div class="hero__actions fade-up" style="--motion-delay: 250ms;">
        <a href="/de/blog/"      class="button-primary"   data-t="home.startReading">Zur LektГјre</a>
        <a href="#rubriques" class="button-secondary"  data-t="home.seeSections">Voir les rubriques</a>
      </div>
      <ul class="hero-proof fade-up" style="--motion-delay: 320ms;" aria-label="RepГЁres Г©ditoriaux">
        <li data-t="home.proof1">Articles de fond</li>
        <li data-t="home.proof2">Ton accessible</li>
        <li data-t="home.proof3">Approche rigoureuse</li>
      </ul>
    </div>
  </section>

  <section class="editorial-intro">
    <div class="container">
      <div class="editorial-note reveal scale-in" data-t="home.editorialNote">
        Ici, on ne promet pas des progrГЁs magiques en 7 jours.
        On propose des idГ©es solides, des exemples concrets et des analyses que tu peux appliquer
        Г  ta pratique, que tu sois joueur de club, compГ©titeur ou simple passionnГ©.
      </div>
    </div>
  </section>

  <!-- в”Җв”Җв”Җ RUBRIQUES в”Җв”Җв”Җ -->
  <section class="pillars" id="rubriques">
    <div class="container">
      <span class="eyebrow reveal" data-t="home.sectionsEyebrow">4 Rubriken</span>
      <h2 class="section-title reveal" data-t="home.sectionsTitle">Ce dont on parle ici</h2>
      <hr class="section-divider reveal" />
      <div class="pillar-grid reveal-group">
        {categorySlugs.map((slug) => {
          const cat = categoryMap[slug];
          return (
            <a href={swapLangPrefix(cat.href, "de")} class="pillar" style={`--p:${cat.accent};`}>
              <span class="pillar__dot"></span>
              <div>
                <span class="pillar__kicker" data-t={`categories.${slug}.shortLabel`}>{cat.shortLabel}</span>
                <strong data-t={`categories.${slug}.label`}>{cat.label}</strong>
                <p data-t={`categories.${slug}.tagline`}>{cat.tagline}</p>
              </div>
              <svg class="pillar__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <div class="container">
    <AdBanner format="leaderboard" />
  </div>

  <!-- в”Җв”Җв”Җ ARTICLES RECENTS в”Җв”Җв”Җ -->
  <section class="latest">
    <div class="container">
      <div class="section-head reveal">
        <div>
          <span class="eyebrow" data-t="home.recentEyebrow">RГ©cents</span>
          <h2 class="section-title" data-t="home.latestTitle">Derniers articles</h2>
        </div>
        <a href="/de/blog/" class="see-all link-underline" data-t="home.seeAll">Alle anzeigen вҶ’</a>
      </div>
      <div class="latest-grid reveal-group">
        {latestPosts.map((post, i) => (
          <ArticleCard post={post} featured={i === 0} lang="de" />
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* в”Җв”Җ HERO в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
  .hero {
    position: relative;
    overflow: hidden;
    padding: 5.5rem 0 3.2rem;
  }

  /* в”Җв”Җ AURORA BACKGROUND в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
  .hero-aurora {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .aurora-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(72px);
    will-change: transform;
  }

  .aurora-orb--a {
    width: min(62vw, 680px);
    height: min(52vw, 540px);
    left: -15%;
    top: -25%;
    background: color-mix(in srgb, var(--green) 12%, transparent);
    animation: auroraA 18s ease-in-out infinite alternate;
  }

  .aurora-orb--b {
    width: min(48vw, 520px);
    height: min(42vw, 450px);
    right: -10%;
    bottom: -20%;
    background: color-mix(in srgb, var(--green) 8%, transparent);
    animation: auroraB 22s ease-in-out infinite alternate;
  }

  .aurora-orb--c {
    width: min(36vw, 380px);
    height: min(32vw, 340px);
    left: 30%;
    top: 55%;
    background: color-mix(in srgb, var(--green) 6%, transparent);
    animation: auroraA 15s ease-in-out 4s infinite alternate-reverse;
  }

  /* в”Җв”Җ CANVAS PARTICLES в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
  .hero-canvas {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .hero .container,
  .editorial-intro .container,
  .pillars .container,
  .latest .container {
    width: min(1280px, calc(100% - 2rem));
  }

  .hero__inner {
    max-width: 56rem;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .hero__title {
    position: relative;
    font-size: clamp(2.6rem, 6.5vw, 4.4rem);
    margin: 0.85rem 0 1.1rem;
  }
  .hero__title::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    width: min(520px, 70%);
    height: 180px;
    transform: translate(-50%, -50%);
    background: radial-gradient(
      closest-side,
      color-mix(in srgb, var(--green) 18%, transparent) 0%,
      transparent 75%
    );
    filter: blur(10px);
    z-index: -1;
    pointer-events: none;
  }

  .hero__accent {
    color: var(--green);
    font-size: 1.08em;
  }

  .hero__lead {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 44rem;
    margin-inline: auto;
    line-height: 1.75;
  }

  .hero__actions {
    display: flex;
    gap: 0.7rem;
    flex-wrap: wrap;
    margin-top: 1.75rem;
    justify-content: center;
  }

  .hero-proof {
    list-style: none;
    padding: 0;
    margin: 1.2rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    justify-content: center;
  }
  .hero-proof li {
    padding: 0.3rem 0.65rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--green-border);
    background: color-mix(in srgb, var(--green-light) 70%, #fff);
    color: var(--text-muted);
    font-size: 0.78rem;
    font-weight: 600;
  }

  .editorial-intro {
    padding: 0.5rem 0 1.6rem;
  }

  .editorial-intro .container {
    display: flex;
    justify-content: center;
  }

  @keyframes auroraA {
    0%   { transform: translate(0, 0) scale(1); }
    40%  { transform: translate(6%, 10%) scale(1.07); }
    100% { transform: translate(-3%, 6%) scale(0.95); }
  }

  @keyframes auroraB {
    0%   { transform: translate(0, 0) scale(1); }
    40%  { transform: translate(-7%, -9%) scale(1.10); }
    100% { transform: translate(4%, -4%) scale(0.93); }
  }

  /* в”Җв”Җ PILLARS в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
  .pillars {
    padding: 0.8rem 0 3.5rem;
  }

  .pillars .container {
    text-align: center;
  }

  .pillar-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.65rem;
    margin-top: 1.4rem;
    align-items: stretch;
  }

  .pillar {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 1.1rem 1.2rem;
    border-radius: var(--radius-lg);
    border: 1.5px solid var(--border-soft);
    background: var(--surface);
    transition:
      transform    240ms var(--ease-spring),
      border-color 180ms ease,
      box-shadow   240ms var(--ease-out);
  }

  .pillar:hover {
    transform: translateY(-3px);
    border-color: var(--p);
    box-shadow: var(--shadow-sm);
  }

  .pillar__dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--p);
    flex-shrink: 0;
    margin-top: 0.35rem;
    transition: transform 240ms var(--ease-spring);
  }
  .pillar:hover .pillar__dot { transform: scale(1.5); }

  .pillar > div { flex: 1; }
  .pillar__kicker {
    display: inline-flex;
    margin-bottom: 0.2rem;
    font-size: 0.66rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    font-weight: 700;
  }
  .pillar strong {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text-main);
    margin-bottom: 0.18rem;
  }
  .pillar p {
    font-size: 0.84rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .pillar__arrow {
    color: var(--text-dim);
    flex-shrink: 0;
    margin-top: 0.2rem;
    transition: color 180ms ease, transform 240ms var(--ease-spring);
  }
  .pillar:hover .pillar__arrow {
    color: var(--p);
    transform: translateX(3px);
  }

  /* в”Җв”Җ LATEST в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
  .latest {
    padding: 1.5rem 0 5rem;
  }

  .latest .container {
    text-align: center;
  }

  .section-head {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.4rem;
  }

  .see-all {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-muted);
    transition: color 160ms ease;
  }
  .see-all:hover { color: var(--green); }

  .latest-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.85rem;
    text-align: left;
  }

  /* premier article en pleine largeur */
  .latest-grid > :first-child {
    grid-column: 1 / -1;
  }

  /* в”Җв”Җ RESPONSIVE в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
  @media (max-width: 1120px) {
    .pillar-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 860px) {
    .pillar-grid,
    .latest-grid {
      grid-template-columns: 1fr;
    }
    .latest-grid > :first-child {
      grid-column: auto;
    }
  }

  @media (max-width: 560px) {
    .hero { padding: 3.5rem 0 3rem; }
    .hero .container,
    .editorial-intro .container,
    .pillars .container,
    .latest .container {
      width: min(1280px, calc(100% - 1.25rem));
    }
    .section-head { flex-direction: column; align-items: center; }
    .hero-proof li { font-size: 0.74rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .aurora-orb { animation: none; }
  }
</style>

<script>
(function () {
  const canvas = document.getElementById('heroCanvas') as HTMLCanvasElement | null;
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  if (!ctx) return;

  const PIECES = ['вҷҹ', 'вҷһ', 'вҷқ', 'вҷң', 'вҷӣ', 'вҷҡ', 'вҷҷ', 'вҷҳ', 'вҷ—', 'вҷ–', 'вҷ•', 'вҷ”'];
  const COUNT = 28;
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let W = 0, H = 0;
  const pts: {x:number;y:number;size:number;char:string;vx:number;vy:number;phase:number;baseAlpha:number}[] = [];

  function hexToRgb(hex: string): [number,number,number] {
    hex = hex.replace(/^#/, '');
    if (hex.length === 3) hex = hex.split('').map(c => c + c).join('');
    const n = parseInt(hex, 16);
    return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
  }
  function getGreenRgb(): [number,number,number] {
    const v = getComputedStyle(document.documentElement).getPropertyValue('--green').trim();
    return hexToRgb(v);
  }
  function rand(a: number, b: number) { return a + Math.random() * (b - a); }
  function spawn(startY?: number) {
    return {
      x: rand(-20, W + 20),
      y: startY !== undefined ? startY : rand(0, H + 20),
      size: rand(11, 23),
      char: PIECES[Math.floor(Math.random() * PIECES.length)],
      vx: rand(-0.13, 0.13),
      vy: rand(-0.38, -0.12),
      phase: rand(0, Math.PI * 2),
      baseAlpha: rand(0.04, 0.12),
    };
  }
  function resize() {
    const section = canvas!.closest('.hero') as HTMLElement;
    W = canvas!.width = section.offsetWidth;
    H = canvas!.height = section.offsetHeight;
  }

  resize();
  for (let i = 0; i < COUNT; i++) pts.push(spawn());
  window.addEventListener('resize', resize, { passive: true });

  let rgb = getGreenRgb();
  new MutationObserver(() => { rgb = getGreenRgb(); })
    .observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

  if (reduced) {
    for (const p of pts) {
      ctx.globalAlpha = p.baseAlpha * 0.5;
      ctx.fillStyle = `rgb(${rgb.join(',')})`;
      ctx.font = `${p.size}px sans-serif`;
      ctx.fillText(p.char, p.x, p.y);
    }
    ctx.globalAlpha = 1;
    return;
  }

  function draw() {
    ctx!.clearRect(0, 0, W, H);
    for (let i = 0; i < pts.length; i++) {
      const p = pts[i];
      p.x += p.vx;
      p.y += p.vy;
      p.phase += 0.009;
      if (p.y < -35) Object.assign(p, spawn(H + 20));
      if (p.x < -35) p.x = W + 20;
      if (p.x > W + 35) p.x = -20;
      const alpha = p.baseAlpha * (0.6 + 0.4 * Math.sin(p.phase));
      for (let j = i + 1; j < pts.length; j++) {
        const q = pts[j];
        const dx = q.x - p.x, dy = q.y - p.y;
        const d = Math.hypot(dx, dy);
        if (d < 155) {
          const la = ((1 - d / 155) * 0.06 * alpha).toFixed(4);
          ctx!.beginPath();
          ctx!.strokeStyle = `rgba(${rgb.join(',')},${la})`;
          ctx!.lineWidth = 0.55;
          ctx!.moveTo(p.x, p.y);
          ctx!.lineTo(q.x, q.y);
          ctx!.stroke();
        }
      }
      ctx!.globalAlpha = alpha;
      ctx!.fillStyle = `rgb(${rgb.join(',')})`;
      ctx!.font = `${p.size}px sans-serif`;
      ctx!.fillText(p.char, p.x, p.y);
    }
    ctx!.globalAlpha = 1;
    requestAnimationFrame(draw);
  }
  draw();
})();
</script>
