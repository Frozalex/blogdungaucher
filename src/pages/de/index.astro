---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HomeLanding from "../../components/HomeLanding.astro";

import { buildWebsiteJsonLd, getAllPosts, getLatestPosts } from "../../utils/blog";

const allPosts = await getAllPosts();
const totalPosts = allPosts.length;
const latestPosts = await getLatestPosts(6, "de");
---
<BaseLayout
  title="Blog d'un Gaucher"
  description="Spielwissenschaft, Wettkampfgeist und Schach in der Gesellschaft. Zwei Artikel pro Woche. Ein Raum zum Teilen und Nachdenken."
  canonicalPath="/de/"
  lang="de"
  structuredData={buildWebsiteJsonLd()}
>
  <HomeLanding lang="de" latestPosts={latestPosts} totalPosts={totalPosts} />
</BaseLayout>
