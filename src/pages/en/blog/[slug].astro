---
import { render } from "astro:content";

import AdBanner from "../../../components/AdBanner.astro";
import ArticleCard from "../../../components/ArticleCard.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import TableOfContents from "../../../components/TableOfContents.astro";
import ShareButtons from "../../../components/ShareButtons.astro";
import Comments from "../../../components/Comments.astro";

import { categoryMap, categorySlugs, siteConfig } from "../../../data/site";
import {
  absoluteUrl,
  buildArticleJsonLd,
  buildBreadcrumbJsonLd,
  buildFaqJsonLd,
  calculateReadingTime,
  formatDateEn,
  filterPostsForLang,
  getAllPosts,
  getPostSlug,
  getPostUrl,
  getPostUrlEn,
  getPostUrlDe,
} from "../../../utils/blog";
import { getEnglishArticleMarkdown, renderEnglishMarkdown } from "../../../utils/english-article";
import { swapLangPrefix } from "../../../utils/lang-paths";
import FAQ from "../../../components/FAQ.astro";

export async function getStaticPaths() {
  const posts = filterPostsForLang(await getAllPosts(), "en");
  return posts.map((post) => ({ params: { slug: getPostSlug(post) }, props: { post } }));
}

const { post } = Astro.props;
const slug = getPostSlug(post);
const englishMarkdown = getEnglishArticleMarkdown(slug);

let Content: Awaited<ReturnType<typeof render>>["Content"] | undefined;
let headings: Awaited<ReturnType<typeof render>>["headings"];
let englishHtml: string | undefined;

if (englishMarkdown) {
  const rendered = renderEnglishMarkdown(englishMarkdown);
  englishHtml = rendered.html;
  headings = rendered.headings;
} else {
  const r = await render(post);
  Content = r.Content;
  headings = r.headings;
}

const category = categoryMap[post.data.category];

const readingTime =
  post.data.readingTime ??
  (englishMarkdown ? calculateReadingTime(englishMarkdown) : calculateReadingTime(post.body));

const allPosts = await getAllPosts();
const related = filterPostsForLang(
  allPosts.filter((e) => e.id !== post.id && e.data.category === post.data.category),
  "en",
).slice(0, 3);

const postUrlEn = getPostUrlEn(post);
const postUrlFr = getPostUrl(post);
const absolutePostUrl = absoluteUrl(postUrlEn);

const enTitle   = post.data.seoTitleEn ?? post.data.titleEn ?? post.data.seoTitle ?? post.data.title;
const enDesc    = post.data.seoDescriptionEn ?? post.data.excerptEn ?? post.data.seoDescription ?? post.data.excerpt;
const displayTitle   = post.data.titleEn   ?? post.data.title;
const displayExcerpt = post.data.excerptEn ?? post.data.excerpt;
const hasEnTranslation = !!englishMarkdown && !!(post.data.titleEn);

const faqsForDisplay = post.data.faqEn ?? post.data.faq ?? [];

const enCategoryLabels: Record<string, string> = {
  science: "Science",
  esprit: "Mind",
  societe: "Society",
};
const enCategoryLabel = enCategoryLabels[post.data.category] ?? category.label;
const enCategoryHref = swapLangPrefix(category.href, "en");

const heroImage = post.data.heroImage;

const structuredData = [
  buildArticleJsonLd(post, { lang: "en" }),
  buildBreadcrumbJsonLd([
    { name: "Home", path: "/en/" },
    { name: "Articles", path: "/en/blog/" },
    { name: displayTitle, path: postUrlEn },
  ]),
  ...(faqsForDisplay.length > 0 ? [buildFaqJsonLd(faqsForDisplay)] : []),
];

const enCategoryShortLabels: Record<string, string> = {
  science: "Science",
  esprit: "Mind & Focus",
  societe: "Chess & Society",
};

const otherPillars = categorySlugs
  .filter((s) => s !== post.data.category)
  .map((s) => ({ ...categoryMap[s], enShort: enCategoryShortLabels[s] ?? categoryMap[s].shortLabel }));
---
<BaseLayout
  title={`${enTitle} | A Left-Hander's Blog`}
  description={enDesc}
  canonicalPath={postUrlEn}
  lang="en"
  frPath={postUrlFr}
  enPath={postUrlEn}
  dePath={getPostUrlDe(post)}
  image={post.data.ogImage ?? siteConfig.defaultOgImage}
  type="article"
  publishDate={post.data.publishDate}
  modifiedDate={post.data.updatedDate ?? post.data.publishDate}
  section={enCategoryLabel}
  structuredData={structuredData}
  accentColor={category.accent}
  tags={post.data.tags}
>
  <article class="article-page" style={`--c:${category.accent}`}>
    <div class="reading-progress" aria-hidden="true">
      <span id="reading-progress-fill"></span>
    </div>
    <div class="container article-layout">
      <div class="article-main">

        <Breadcrumb items={[
          { label: "Home", href: "/en/" },
          { label: "Articles", href: "/en/blog/" },
          { label: enCategoryLabel, href: enCategoryHref },
          { label: displayTitle },
        ]} />

        <header class="article-header fade-up" style="--motion-delay: 40ms;">
          <div class="article-meta">
            <a href={enCategoryHref} class="meta-cat" style={`--c:${category.accent}`}>
              {enCategoryLabel}
            </a>
            <span>{readingTime}</span>
            <time datetime={post.data.publishDate.toISOString()}>
              {formatDateEn(post.data.publishDate)}
            </time>
          </div>
          <h1>{displayTitle}</h1>
          <p class="article-excerpt">{displayExcerpt}</p>
        </header>

        {heroImage?.src && (
          <figure class="hero-media fade-up" style="--motion-delay: 70ms;">
            <img class="hero-img" src={heroImage.src} alt={heroImage.alt} loading="lazy" decoding="async" />
            {(heroImage.credit || heroImage.license || heroImage.sourceUrl) && (
              <figcaption class="hero-credit">
                {heroImage.credit && <span class="credit-piece">Credit: {heroImage.credit}</span>}
                {heroImage.license && <span class="credit-piece">License: {heroImage.license}</span>}
                {heroImage.sourceUrl && (
                  <a class="credit-link" href={heroImage.sourceUrl} target="_blank" rel="noreferrer">
                    Source
                  </a>
                )}
              </figcaption>
            )}
          </figure>
        )}

        {!hasEnTranslation && (
          <div class="translation-notice" role="note">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
            <span>The full English translation of this article is in progress. The content below is currently in French.</span>
          </div>
        )}

        <div class="toc-mobile-wrap">
          <TableOfContents headings={headings} mode="mobile" lang="en" />
        </div>

        <AdBanner format="inline" compact={true} />

        <div class="article-body fade-up" style="--motion-delay: 100ms;">
          {englishHtml ? (
            <div set:html={englishHtml} />
          ) : (
            Content && <Content />
          )}
        </div>

        {faqsForDisplay.length > 0 && <FAQ items={faqsForDisplay} lang="en" />}

        {otherPillars.length > 0 && (
          <nav class="pillar-links fade-up" style="--motion-delay: 130ms;" aria-label="Other blog sections">
            <span class="pillar-links__eyebrow">Continue exploring</span>
            <div class="pillar-links__grid">
              {otherPillars.map((p) => (
                <a href={swapLangPrefix(p.href, "en")} class="pillar-link" style={`--pc:${p.accent}`}>
                  <span class="pillar-link__dot"></span>
                  <div>
                    <strong>{p.enShort}</strong>
                    <span>{p.tagline}</span>
                  </div>
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
                </a>
              ))}
            </div>
          </nav>
        )}

        <ShareButtons title={displayTitle} url={absolutePostUrl} />
        <Comments />

      </div>

      <aside class="article-aside">
        <div class="toc-desktop-wrap">
          <TableOfContents headings={headings} mode="desktop" lang="en" />
        </div>

        <div class="aside-card fade-up" style="--motion-delay: 120ms;">
          <span class="aside-dot" style={`background:${category.accent}`}></span>
          <h2>{enCategoryLabel}</h2>
          <p data-t={`categories.${post.data.category}.tagline`}>{category.tagline}</p>
          <a href={enCategoryHref} class="aside-link">
            Explore this section
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
          </a>
        </div>

        <AdBanner format="rectangle" />
      </aside>
    </div>

    {related.length > 0 && (
      <section class="related">
        <div class="container">
          <span class="eyebrow">Related articles</span>
          <div class="related-grid">
            {related.map((p) => <ArticleCard post={p} lang="en" />)}
          </div>
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .translation-notice {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    padding: 0.85rem 1rem;
    border-radius: var(--radius-sm);
    border: 1px solid color-mix(in srgb, var(--green) 30%, var(--border-soft));
    background: color-mix(in srgb, var(--green) 6%, var(--surface));
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.5;
    margin-bottom: 1.5rem;
  }
  .translation-notice svg { flex-shrink: 0; margin-top: 0.1rem; color: var(--green); }

  .reading-progress {
    position: fixed; top: 0; left: 0; right: 0; height: 3px;
    background: var(--border-soft); z-index: 200;
  }
  #reading-progress-fill {
    display: block; height: 100%; width: 0%;
    background: var(--green); transition: width 100ms linear;
    border-radius: 0 2px 2px 0;
  }

  .article-page { padding-bottom: 4rem; }

  .article-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 280px;
    gap: 3rem;
    padding-top: 2.5rem;
    align-items: start;
  }

  .article-header { margin-bottom: 2rem; }

  .hero-media {
    margin: 0 0 1.25rem;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border-soft);
    background: var(--surface);
    box-shadow: var(--shadow-xs);
  }

  .hero-img {
    width: 100%;
    display: block;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    background: color-mix(in srgb, var(--surface-warm) 65%, transparent);
  }

  .hero-credit {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.6rem;
    align-items: baseline;
    padding: 0.6rem 0.8rem;
    border-top: 1px solid var(--border-soft);
    font-size: 0.75rem;
    color: var(--text-dim);
    background: color-mix(in srgb, var(--surface-warm) 70%, transparent);
  }

  .credit-piece { white-space: nowrap; }
  .credit-link { color: var(--green); font-weight: 700; text-decoration: none; }
  .credit-link:hover { text-decoration: underline; }

  .article-meta {
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.6rem;
    font-size: 0.82rem; color: var(--text-dim);
    margin-bottom: 1rem;
  }
  .meta-cat {
    padding: 0.18rem 0.55rem; border-radius: var(--radius-pill);
    border: 1px solid var(--c, var(--green)); color: var(--c, var(--green));
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
  }

  .article-header h1 {
    font-family: var(--font-serif);
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    font-weight: 500; font-style: italic;
    line-height: 1.15; letter-spacing: -0.02em;
    margin: 0 0 0.9rem;
  }

  .article-excerpt {
    color: var(--text-muted); font-size: 1.05rem;
    line-height: 1.7; max-width: 48rem;
  }

  .article-body { line-height: 1.8; font-size: 1.02rem; color: var(--text-muted); }
  .article-body :global(h2) { font-family: var(--font-display); font-size: 1.35rem; font-weight: 700; color: var(--text-main); margin: 2.2rem 0 0.7rem; }
  .article-body :global(h3) { font-family: var(--font-display); font-size: 1.1rem; font-weight: 700; color: var(--text-main); margin: 1.8rem 0 0.5rem; }
  .article-body :global(p) { margin-bottom: 1.1rem; }
  .article-body :global(a) { color: var(--green); text-decoration: underline; text-underline-offset: 2px; }
  .article-body :global(ul), .article-body :global(ol) { padding-left: 1.4rem; margin-bottom: 1.1rem; }
  .article-body :global(li) { margin-bottom: 0.3rem; }
  .article-body :global(blockquote) { border-left: 3px solid var(--c, var(--green)); padding: 0.6rem 1rem; margin: 1.4rem 0; color: var(--text-muted); font-style: italic; background: color-mix(in srgb, var(--c, var(--green)) 6%, var(--surface)); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; }
  .article-body :global(pre) { border-radius: var(--radius-sm); padding: 1rem 1.2rem; overflow-x: auto; font-size: 0.9rem; margin: 1.2rem 0; background: var(--surface-warm); border: 1px solid var(--border-soft); }
  .article-body :global(code:not(pre code)) { font-size: 0.88em; padding: 0.1em 0.35em; border-radius: 3px; background: var(--surface-warm); border: 1px solid var(--border-soft); }
  .article-body :global(img) { max-width: 100%; border-radius: var(--radius-sm); margin: 1rem 0; }
  .article-body :global(table) { width: 100%; border-collapse: collapse; margin: 1.4rem 0; font-size: 0.9rem; }
  .article-body :global(th), .article-body :global(td) { padding: 0.55rem 0.8rem; border: 1px solid var(--border-soft); text-align: left; }
  .article-body :global(th) { background: var(--surface-warm); font-weight: 700; }

  .article-aside { position: sticky; top: 5rem; display: grid; gap: 1.5rem; }
  .toc-mobile-wrap { display: none; }

  .aside-card {
    padding: 1.1rem 1.2rem; border-radius: var(--radius-lg);
    border: 1.5px solid var(--border-soft); background: var(--surface);
    display: grid; gap: 0.4rem;
  }
  .aside-dot { width: 8px; height: 8px; border-radius: 50%; display: block; }
  .aside-card h2 { font-family: var(--font-display); font-size: 0.95rem; font-weight: 700; color: var(--text-main); }
  .aside-card p { font-size: 0.85rem; color: var(--text-muted); line-height: 1.5; }
  .aside-link { display: inline-flex; align-items: center; gap: 0.3rem; margin-top: 0.3rem; font-size: 0.82rem; font-weight: 600; color: var(--green); transition: gap 180ms var(--ease-spring); }
  .aside-link:hover { gap: 0.5rem; }

  /* pillar maillage */
  .pillar-links { margin-top: 2rem; padding: 1.5rem; border-radius: var(--radius-lg); background: var(--surface); border: 1px solid var(--border-soft); box-shadow: var(--shadow-xs); }
  .pillar-links__eyebrow { display: block; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-dim); margin-bottom: 0.9rem; }
  .pillar-links__grid { display: grid; gap: 0.7rem; }
  .pillar-link { display: flex; align-items: flex-start; gap: 0.75rem; padding: 0.85rem 1rem; border-radius: var(--radius-md); border: 1px solid var(--border-soft); background: color-mix(in srgb, var(--pc) 4%, var(--bg-warm)); transition: border-color 180ms ease, background 180ms ease; text-decoration: none; }
  .pillar-link:hover { border-color: var(--pc); background: color-mix(in srgb, var(--pc) 8%, var(--bg-warm)); }
  .pillar-link__dot { flex-shrink: 0; width: 8px; height: 8px; border-radius: 50%; background: var(--pc); margin-top: 0.35rem; }
  .pillar-link div { flex: 1; display: flex; flex-direction: column; gap: 0.15rem; }
  .pillar-link strong { font-size: 0.9rem; color: var(--text-main); }
  .pillar-link span { font-size: 0.8rem; color: var(--text-dim); line-height: 1.5; }
  .pillar-link svg { flex-shrink: 0; color: var(--pc); margin-top: 0.25rem; }

  .related { padding: 3rem 0 2rem; border-top: 1px solid var(--border-soft); margin-top: 3rem; }
  .related .eyebrow { display: block; margin-bottom: 0.8rem; }
  .related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.85rem; }

  @media (max-width: 1024px) {
    .article-layout { grid-template-columns: 1fr; }
    .article-aside { position: static; }
    .toc-mobile-wrap { display: block; }
    .toc-desktop-wrap { display: none; }
    .related-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 620px) { .related-grid { grid-template-columns: 1fr; } }
</style>

<script>
  function initReadingProgress() {
    const fill = document.getElementById("reading-progress-fill");
    const body = document.querySelector(".article-body") as HTMLElement | null;
    if (!fill || !body) return;

    function update() {
      const rect  = body!.getBoundingClientRect();
      const total = body!.offsetHeight;
      const read  = Math.max(0, -rect.top);
      const pct   = Math.min(100, (read / total) * 100);
      fill.style.width = `${pct}%`;
    }

    window.addEventListener("scroll", update, { passive: true });
    update();
  }

  document.addEventListener("astro:page-load", initReadingProgress);
</script>
