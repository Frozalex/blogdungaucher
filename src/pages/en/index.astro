---
import AdBanner from "../../components/AdBanner.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

import { categoryMap, categorySlugs } from "../../data/site";
import { swapLangPrefix } from "../../utils/lang-paths";
import { buildWebsiteJsonLd, getLatestPosts } from "../../utils/blog";

const latestPosts = await getLatestPosts(5, "en");
---
<BaseLayout
  title="A Left-Hander's Blog - Chess Without Oversimplifying"
  description="Weekly analyses on chess science, the competitive mindset, and chess in society. A rigorous and human editorial space."
  canonicalPath="/en/"
  lang="en"
  frPath="/"
  enPath="/en/"
  structuredData={buildWebsiteJsonLd()}
>

  <!-- ─── HERO ─── -->
  <section class="hero">
    <div class="hero-aurora" aria-hidden="true">
      <span class="aurora-orb aurora-orb--a"></span>
      <span class="aurora-orb aurora-orb--b"></span>
      <span class="aurora-orb aurora-orb--c"></span>
    </div>
    <canvas class="hero-canvas" id="heroCanvas" aria-hidden="true"></canvas>
    <span class="lb-bar lb-bar--top" aria-hidden="true"></span>
    <span class="lb-bar lb-bar--btm" aria-hidden="true"></span>
    <div class="container hero__inner">
      <span class="eyebrow fade-up" style="--motion-delay: 40ms;" data-t="home.eyebrow">Independent editorial</span>
      <h1 class="hero__title fade-up" style="--motion-delay: 120ms;" data-t-html="home.titleHtml">
        Understanding <span class="hero__accent display-serif">chess</span><br/>without oversimplifying.
      </h1>
      <p class="hero__lead fade-up" style="--motion-delay: 190ms;" data-t="home.lead">
        Each week, clear analyses on the science of the game, the competitive mindset
        and the impact of chess on society, with a human and demanding approach.
      </p>
      <div class="hero__actions fade-up" style="--motion-delay: 250ms;">
        <a href="/en/blog/"    class="button-primary"   data-t="home.startReading">Start reading</a>
        <a href="#sections"    class="button-secondary"  data-t="home.seeSections">See sections</a>
      </div>
      <ul class="hero-proof fade-up" style="--motion-delay: 320ms;" aria-label="Editorial markers">
        <li data-t="home.proof1">In-depth articles</li>
        <li data-t="home.proof2">Accessible tone</li>
        <li data-t="home.proof3">Rigorous approach</li>
      </ul>
    </div>
  </section>

  <section class="editorial-intro">
    <div class="container">
      <div class="editorial-note reveal scale-in" data-t="home.editorialNote">
        Here, we don't promise magical progress in 7 days.
        We offer solid ideas, concrete examples and analyses that you can apply
        to your practice, whether you're a club player, a competitor, or simply passionate about the game.
      </div>
    </div>
  </section>

  <!-- ─── SECTIONS ─── -->
  <section class="pillars" id="sections">
    <div class="container">
      <span class="eyebrow reveal" data-t="home.sectionsEyebrow">4 sections</span>
      <h2 class="section-title reveal" data-t="home.sectionsTitle">What we cover here</h2>
      <hr class="section-divider reveal" />
      <div class="pillar-grid reveal-group">
        {categorySlugs.map((slug) => {
          const cat = categoryMap[slug];
          return (
            <a href={swapLangPrefix(cat.href, "en")} class="pillar" style={`--p:${cat.accent};`}>
              <span class="pillar__dot"></span>
              <div>
                <span class="pillar__kicker" data-t={`categories.${slug}.shortLabel`}>{cat.shortLabel}</span>
                <strong data-t={`categories.${slug}.label`}>{cat.label}</strong>
                <p data-t={`categories.${slug}.tagline`}>{cat.tagline}</p>
              </div>
              <svg class="pillar__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <div class="container">
    <AdBanner format="leaderboard" />
  </div>

  <!-- ─── LATEST ARTICLES ─── -->
  <section class="latest">
    <div class="container">
      <div class="section-head reveal">
        <div>
          <span class="eyebrow" data-t="home.recentEyebrow">Recent</span>
          <h2 class="section-title" data-t="home.latestTitle">Latest articles</h2>
        </div>
        <a href="/en/blog/" class="see-all link-underline" data-t="home.seeAll">See all →</a>
      </div>
      <div class="latest-grid reveal-group">
        {latestPosts.map((post, i) => (
          <ArticleCard post={post} featured={i === 0} lang="en" />
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: 5.5rem 0 3.2rem;
  }

  /* ── AURORA BACKGROUND ──────────────────────────────────── */
  .hero-aurora {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .aurora-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(72px);
    will-change: transform;
  }

  .aurora-orb--a {
    width: min(62vw, 680px);
    height: min(52vw, 540px);
    left: -15%;
    top: -25%;
    background: color-mix(in srgb, var(--green) 12%, transparent);
    animation: auroraA 18s ease-in-out infinite alternate;
  }

  .aurora-orb--b {
    width: min(48vw, 520px);
    height: min(42vw, 450px);
    right: -10%;
    bottom: -20%;
    background: color-mix(in srgb, var(--green) 8%, transparent);
    animation: auroraB 22s ease-in-out infinite alternate;
  }

  .aurora-orb--c {
    width: min(36vw, 380px);
    height: min(32vw, 340px);
    left: 30%;
    top: 55%;
    background: color-mix(in srgb, var(--green) 6%, transparent);
    animation: auroraA 15s ease-in-out 4s infinite alternate-reverse;
  }

  /* ── CANVAS ──────────────────────────────────────────── */
  .hero-canvas {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  /* ── LETTERBOX BARS ──────────────────────────────────── */
  .lb-bar {
    position: absolute;
    left: 0; right: 0;
    height: clamp(5px, 1.6%, 13px);
    background: #000;
    opacity: 0.72;
    z-index: 3;
    pointer-events: none;
  }
  .lb-bar--top { top: 0; }
  .lb-bar--btm { bottom: 0; }

  .hero .container,
  .editorial-intro .container,
  .pillars .container,
  .latest .container {
    width: min(1280px, calc(100% - 2rem));
  }

  .hero__inner {
    max-width: 56rem;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .hero__title {
    position: relative;
    font-size: clamp(2.6rem, 6.5vw, 4.4rem);
    margin: 0.85rem 0 1.1rem;
  }
  .hero__title::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    width: min(520px, 70%);
    height: 180px;
    transform: translate(-50%, -50%);
    background: radial-gradient(
      closest-side,
      color-mix(in srgb, var(--green) 18%, transparent) 0%,
      transparent 75%
    );
    filter: blur(10px);
    z-index: -1;
    pointer-events: none;
  }

  .hero__accent {
    color: var(--green);
    font-size: 1.08em;
  }

  .hero__lead {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 44rem;
    margin-inline: auto;
    line-height: 1.75;
  }

  .hero__actions {
    display: flex;
    gap: 0.7rem;
    flex-wrap: wrap;
    margin-top: 1.75rem;
    justify-content: center;
  }

  .hero-proof {
    list-style: none;
    padding: 0;
    margin: 1.2rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    justify-content: center;
  }
  .hero-proof li {
    padding: 0.3rem 0.65rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--green-border);
    background: color-mix(in srgb, var(--green-light) 70%, #fff);
    color: var(--text-muted);
    font-size: 0.78rem;
    font-weight: 600;
  }

  .editorial-intro { padding: 0.5rem 0 1.6rem; }
  .editorial-intro .container { display: flex; justify-content: center; }

  @keyframes auroraA {
    0%   { transform: translate(0, 0) scale(1); }
    40%  { transform: translate(6%, 10%) scale(1.07); }
    100% { transform: translate(-3%, 6%) scale(0.95); }
  }

  @keyframes auroraB {
    0%   { transform: translate(0, 0) scale(1); }
    40%  { transform: translate(-7%, -9%) scale(1.10); }
    100% { transform: translate(4%, -4%) scale(0.93); }
  }

  .pillars { padding: 0.8rem 0 3.5rem; }
  .pillars .container { text-align: center; }

  .pillar-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.65rem;
    margin-top: 1.4rem;
    align-items: stretch;
  }

  .pillar {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 1.1rem 1.2rem;
    border-radius: var(--radius-lg);
    border: 1.5px solid var(--border-soft);
    background: var(--surface);
    transition: transform 240ms var(--ease-spring), border-color 180ms ease, box-shadow 240ms var(--ease-out);
  }
  .pillar:hover { transform: translateY(-3px); border-color: var(--p); box-shadow: var(--shadow-sm); }

  .pillar__dot {
    width: 9px; height: 9px; border-radius: 50%;
    background: var(--p); flex-shrink: 0; margin-top: 0.35rem;
    transition: transform 240ms var(--ease-spring);
  }
  .pillar:hover .pillar__dot { transform: scale(1.5); }
  .pillar > div { flex: 1; }
  .pillar__kicker {
    display: inline-flex; margin-bottom: 0.2rem;
    font-size: 0.66rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--text-dim); font-weight: 700;
  }
  .pillar strong { display: block; font-family: var(--font-display); font-weight: 600; font-size: 0.95rem; color: var(--text-main); margin-bottom: 0.18rem; }
  .pillar p { font-size: 0.84rem; color: var(--text-muted); line-height: 1.5; }
  .pillar__arrow { color: var(--text-dim); flex-shrink: 0; margin-top: 0.2rem; transition: color 180ms ease, transform 240ms var(--ease-spring); }
  .pillar:hover .pillar__arrow { color: var(--p); transform: translateX(3px); }

  .latest { padding: 1.5rem 0 5rem; }
  .latest .container { text-align: center; }

  .section-head {
    display: flex; justify-content: center; align-items: center;
    flex-direction: column; gap: 1rem; margin-bottom: 1.4rem;
  }

  .see-all { font-size: 0.88rem; font-weight: 600; color: var(--text-muted); transition: color 160ms ease; }
  .see-all:hover { color: var(--green); }

  .latest-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.85rem; text-align: left;
  }
  .latest-grid > :first-child { grid-column: 1 / -1; }

  @media (max-width: 1120px) { .pillar-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 860px) {
    .pillar-grid, .latest-grid { grid-template-columns: 1fr; }
    .latest-grid > :first-child { grid-column: auto; }
  }
  @media (max-width: 560px) {
    .hero { padding: 3.5rem 0 3rem; }
    .hero .container, .editorial-intro .container, .pillars .container, .latest .container {
      width: min(1280px, calc(100% - 1.25rem));
    }
    .section-head { flex-direction: column; align-items: center; }
    .hero-proof li { font-size: 0.74rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    .aurora-orb { animation: none; }
  }
</style>

<script>
/* ── Cinematic hero: selective-color reveal + diagonal wipes ── */
;(function () {
  const canvas = document.getElementById('heroCanvas');
  if (!(canvas instanceof HTMLCanvasElement)) return;
  const ctx = canvas.getContext('2d')!;
  const REDUCED = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let W = 0, H = 0;

  type RGB = [number, number, number];
  interface Glyph { ch: string; rx: number; ry: number; rs: number }
  interface Scene { bg: string; accent: RGB; glyphs: Glyph[] }

  const SCENES: Scene[] = [
    { bg: '#070605', accent: [200, 162, 38],
      glyphs: [
        { ch: '♚', rx: 0.72, ry: 0.44, rs: 0.38 },
        { ch: '♛', rx: 0.20, ry: 0.60, rs: 0.25 },
        { ch: '♝', rx: 0.50, ry: 0.18, rs: 0.16 },
      ] },
    { bg: '#030a03', accent: [52, 140, 50],
      glyphs: [
        { ch: '♞', rx: 0.26, ry: 0.40, rs: 0.36 },
        { ch: '♜', rx: 0.70, ry: 0.60, rs: 0.25 },
        { ch: '♟', rx: 0.48, ry: 0.74, rs: 0.16 },
      ] },
    { bg: '#0a0303', accent: [190, 40, 35],
      glyphs: [
        { ch: '♔', rx: 0.66, ry: 0.36, rs: 0.37 },
        { ch: '♖', rx: 0.20, ry: 0.56, rs: 0.23 },
        { ch: '♙', rx: 0.52, ry: 0.70, rs: 0.17 },
      ] },
  ];
  const SCENE_DUR = 5.2; const WIPE_DUR = 0.90;
  const REV_START = 0.12; const REV_END = 0.76;
  const TAN35 = Math.tan(35 * Math.PI / 180);
  const bokeh = Array.from({ length: 22 }, () => ({
    x: Math.random()*1.2-0.1, y: Math.random()*1.2-0.1,
    r: 5+Math.random()*16, vx: (Math.random()-0.5)*1.8e-4,
    vy: -(5e-5+Math.random()*1.5e-4), a: 0.06+Math.random()*0.14,
    ph: Math.random()*Math.PI*2, ps: 0.4+Math.random()*0.9,
  }));
  function resize() {
    const sec = canvas.closest('.hero') as HTMLElement;
    W = canvas.width = sec.offsetWidth; H = canvas.height = sec.offsetHeight;
  }
  resize(); window.addEventListener('resize', resize, { passive: true });
  function isDark() { return document.documentElement.dataset.theme === 'dark'; }
  function drawGrid() {
    const C = 44; ctx.globalAlpha = 0.022; ctx.fillStyle = '#fff';
    for (let r = -1; r*C < H+C; r++) for (let c = -1; c*C < W+C; c++)
      if ((r+c)%2===0) ctx.fillRect(c*C, r*C, C, C);
    ctx.globalAlpha = 1;
  }
  function clipReveal(revFrac: number) {
    const span = W+H*TAN35, front = Math.min(revFrac*span*1.05, span+2);
    const topX = Math.min(W,front), bottomX = Math.max(0,front-H*TAN35);
    const rightY = front>W ? Math.min(H,(front-W)/TAN35) : 0;
    ctx.beginPath(); ctx.moveTo(0,0); ctx.lineTo(topX,0);
    if (front>W) ctx.lineTo(W,rightY);
    if (front>=W+H*TAN35) ctx.lineTo(W,H);
    ctx.lineTo(bottomX,H); ctx.lineTo(0,H); ctx.closePath(); ctx.clip();
  }
  function drawGlyphs(scene: Scene, revFrac: number, dark: boolean) {
    const [ar,ag,ab] = scene.accent;
    const monoA = dark?0.22:0.10, colA = dark?0.88:0.52;
    ctx.textAlign='center'; ctx.textBaseline='middle';
    const gray = dark?'rgb(72,72,72)':'rgb(28,28,28)';
    for (const g of scene.glyphs) {
      ctx.globalAlpha=monoA; ctx.fillStyle=gray;
      ctx.font=`${Math.round(g.rs*Math.min(W,H))}px sans-serif`;
      ctx.fillText(g.ch, g.rx*W, g.ry*H);
    }
    ctx.globalAlpha=1; if (revFrac<=0) return;
    ctx.save(); clipReveal(revFrac);
    for (const g of scene.glyphs) {
      const px=g.rx*W, py=g.ry*H, fsz=Math.round(g.rs*Math.min(W,H));
      ctx.font=`${fsz}px sans-serif`;
      ctx.globalAlpha=colA*0.45; ctx.shadowColor=`rgba(${ar},${ag},${ab},0.9)`;
      ctx.shadowBlur=32; ctx.fillStyle=`rgb(${ar},${ag},${ab})`; ctx.fillText(g.ch,px,py);
      ctx.shadowBlur=0; ctx.globalAlpha=colA; ctx.fillText(g.ch,px,py);
    }
    ctx.shadowBlur=0; ctx.globalAlpha=1; ctx.restore();
  }
  function drawWipe(wipeFrac: number, next: Scene, dark: boolean) {
    const leadX=W*(1-wipeFrac)+W*0.06, slant=H*TAN35, [nr,ng,nb]=next.accent;
    ctx.save(); ctx.beginPath();
    ctx.moveTo(leadX-slant,H); ctx.lineTo(leadX,0); ctx.lineTo(W+12,0); ctx.lineTo(W+12,H);
    ctx.closePath(); ctx.clip();
    if (dark) { ctx.fillStyle=next.bg; ctx.fillRect(0,0,W,H); drawGrid(); }
    drawGlyphs(next,0,dark);
    const grd=ctx.createLinearGradient(leadX-slant-64,0,leadX+4,0);
    grd.addColorStop(0,`rgba(${nr},${ng},${nb},0)`);
    grd.addColorStop(1,`rgba(${nr},${ng},${nb},0.6)`);
    ctx.fillStyle=grd; ctx.fillRect(0,0,W,H);
    ctx.restore(); ctx.globalAlpha=1;
  }
  function drawBokeh(scene: Scene, dark: boolean) {
    const [ar,ag,ab]=scene.accent, scale=dark?1.0:0.45;
    for (const p of bokeh) {
      p.x+=p.vx; p.y+=p.vy; p.ph+=p.ps*0.016;
      if (p.y<-0.12){p.y=1.1;p.x=Math.random()*1.2-0.1;}
      if (p.x<-0.12) p.x=1.1; if (p.x>1.12) p.x=-0.1;
      const px=p.x*W, py=p.y*H, pr=Math.max(1,p.r*(0.72+0.28*Math.sin(p.ph))*scale);
      const pa=p.a*(0.5+0.5*Math.sin(p.ph*0.7))*scale;
      const grd=ctx.createRadialGradient(px,py,0,px,py,pr);
      grd.addColorStop(0,`rgba(${ar},${ag},${ab},${pa.toFixed(3)})`);
      grd.addColorStop(0.45,`rgba(255,255,255,${(pa*0.3).toFixed(3)})`);
      grd.addColorStop(1,'rgba(0,0,0,0)');
      ctx.beginPath(); ctx.arc(px,py,pr,0,Math.PI*2); ctx.fillStyle=grd; ctx.fill();
    }
  }
  function drawVignette() {
    const grd=ctx.createRadialGradient(W*.5,H*.4,Math.min(W,H)*.06,W*.5,H*.5,Math.max(W,H)*.78);
    grd.addColorStop(0,'rgba(0,0,0,0)'); grd.addColorStop(1,'rgba(0,0,0,0.62)');
    ctx.fillStyle=grd; ctx.fillRect(0,0,W,H);
  }
  let t0=0;
  function draw(ts: number) {
    if (!t0) t0=ts;
    const t=(ts-t0)/1000, dark=isDark();
    const cycle=SCENES.length*SCENE_DUR, ct=t%cycle;
    const si=Math.floor(ct/SCENE_DUR)%SCENES.length, st=ct%SCENE_DUR, sf=st/SCENE_DUR;
    const scene=SCENES[si], next=SCENES[(si+1)%SCENES.length];
    ctx.clearRect(0,0,W,H);
    const kb=1+sf*0.038;
    ctx.save(); ctx.translate(W/2,H/2); ctx.scale(kb,kb); ctx.translate(-W/2,-H/2);
    if (dark) { ctx.fillStyle=scene.bg; ctx.fillRect(-W,-H,W*3,H*3); drawGrid(); }
    const revFrac=Math.max(0,Math.min(1,(sf-REV_START)/(REV_END-REV_START)));
    drawGlyphs(scene,revFrac,dark);
    ctx.restore();
    const wipeStart=1-WIPE_DUR/SCENE_DUR;
    if (sf>=wipeStart) drawWipe(Math.min(1,(sf-wipeStart)/(WIPE_DUR/SCENE_DUR)),next,dark);
    drawBokeh(scene,dark); if (dark) drawVignette();
    requestAnimationFrame(draw);
  }
  if (REDUCED) {
    const dark=isDark(), s=SCENES[0];
    if (dark){ctx.fillStyle=s.bg;ctx.fillRect(0,0,W,H);drawGrid();}
    drawGlyphs(s,0.5,dark); if (dark) drawVignette(); return;
  }
  requestAnimationFrame(draw);

})();
</script>
