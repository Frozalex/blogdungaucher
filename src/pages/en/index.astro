---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HomeLanding from "../../components/HomeLanding.astro";

import { buildWebsiteJsonLd, getAllPosts, getLatestPosts, isFrenchOnlyPost } from "../../utils/blog";
import { categorySlugs } from "../../data/site";

const allPosts = await getAllPosts();
const totalPosts = allPosts.length;
const latestPosts = await getLatestPosts(6, "en");

const postsByCategory = Object.fromEntries(
  categorySlugs.map((slug) => [
    slug,
    allPosts.filter((p) => p.data.category === slug && !isFrenchOnlyPost(p)).length,
  ]),
) as Partial<Record<(typeof categorySlugs)[number], number>>;
---
<BaseLayout
  title="A Left-Hander's Blog - Chess Without Oversimplifying"
  description="Chess science, the competitive mindset, and chess in society: two new articles every week. A rigorous and human editorial space."
  canonicalPath="/en/"
  lang="en"
  frPath="/"
  enPath="/en/"
  structuredData={buildWebsiteJsonLd()}
>
  <HomeLanding lang="en" latestPosts={latestPosts} totalPosts={totalPosts} postsByCategory={postsByCategory} />
</BaseLayout>
