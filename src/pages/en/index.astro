---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HomeLanding from "../../components/HomeLanding.astro";

import { buildWebsiteJsonLd, getAllPosts, getLatestPosts } from "../../utils/blog";

const allPosts = await getAllPosts();
const totalPosts = allPosts.length;
const latestPosts = await getLatestPosts(6, "en");
---
<BaseLayout
  title="A Left-Hander's Blog - Chess Without Oversimplifying"
  description="Chess science, the competitive mindset, and chess in society: two new articles every week. A rigorous and human editorial space."
  canonicalPath="/en/"
  lang="en"
  frPath="/"
  enPath="/en/"
  structuredData={buildWebsiteJsonLd()}
>
  <HomeLanding lang="en" latestPosts={latestPosts} totalPosts={totalPosts} />
</BaseLayout>
