---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import BackToTop from "../components/BackToTop.astro";
import CookieConsent from "../components/CookieConsent.astro";

import { siteConfig } from "../data/site";
import { swapLangPrefix } from "../utils/lang-paths";

type StructuredData = Record<string, unknown> | Array<Record<string, unknown>>;

const {
  title = siteConfig.defaultTitle,
  description = siteConfig.defaultDescription,
  canonicalPath = Astro.url.pathname,
  image = siteConfig.defaultOgImage,
  type = "website",
  noindex = false,
  structuredData,
  accentColor,
  tags,
  publishDate,
  modifiedDate,
  section,
  lang = "fr",
  frPath,
  enPath,
  dePath,
  omitEnDeAlternateLinks = false,
} = Astro.props as {
  title?: string;
  description?: string;
  canonicalPath?: string;
  image?: string;
  type?: "website" | "article";
  noindex?: boolean;
  structuredData?: StructuredData;
  accentColor?: string;
  tags?: string[];
  publishDate?: Date;
  modifiedDate?: Date;
  section?: string;
  lang?: "fr" | "en" | "de";
  frPath?: string;
  enPath?: string;
  /** Chemin DE optionnel (sinon dérivé du canonical via swapLangPrefix). */
  dePath?: string;
  /** Articles FR uniquement (ex. Grand oral) : pas d’hreflang en/de vers des URLs inexistantes. */
  omitEnDeAlternateLinks?: boolean;
};

const resolvedFrPath = frPath ?? swapLangPrefix(canonicalPath, "fr");
const resolvedEnPath = enPath ?? swapLangPrefix(canonicalPath, "en");
const resolvedDePath = dePath ?? swapLangPrefix(canonicalPath, "de");
const canonicalUrl = new URL(canonicalPath, siteConfig.siteUrl).toString();
const frCanonicalUrl = new URL(resolvedFrPath, siteConfig.siteUrl).toString();
const enCanonicalUrl = new URL(resolvedEnPath, siteConfig.siteUrl).toString();
const deCanonicalUrl = new URL(resolvedDePath, siteConfig.siteUrl).toString();

const socialImage = new URL(image, siteConfig.siteUrl).toString();
const structuredDataItems = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];

const inLanguage = lang === "en" ? "en-US" : lang === "de" ? "de-DE" : "fr-FR";

// Fallback: si une page "article" oublie de fournir structuredData,
// on injecte un BlogPosting minimal pour ne jamais "perdre" le schema.org.
const fallbackArticleJsonLd =
  type === "article" && structuredDataItems.length === 0
    ? ({
        "@context": "https://schema.org",
        "@type": ["Article", "BlogPosting"],
        headline: title,
        name: title,
        description,
        inLanguage,
        url: canonicalUrl,
        mainEntityOfPage: {
          "@type": "WebPage",
          "@id": canonicalUrl,
        },
        image: {
          "@type": "ImageObject",
          url: socialImage,
        },
        ...(publishDate ? { datePublished: publishDate.toISOString() } : {}),
        ...(modifiedDate ? { dateModified: modifiedDate.toISOString() } : {}),
        ...(section ? { articleSection: section } : {}),
        ...(tags?.length ? { keywords: tags.join(", ") } : {}),
        publisher: {
          "@type": "Organization",
          name: siteConfig.name,
          url: siteConfig.siteUrl,
          logo: {
            "@type": "ImageObject",
            url: `${siteConfig.siteUrl}/images/logo.svg`,
          },
        },
        author: {
          "@type": "Person",
          name: "Le Gaucher",
          url: siteConfig.siteUrl,
        },
      } satisfies Record<string, unknown>)
    : null;

const allStructuredDataItems = fallbackArticleJsonLd
  ? [fallbackArticleJsonLd]
  : structuredDataItems;

const oneSignalAppId = import.meta.env.PUBLIC_ONESIGNAL_APP_ID ?? "";
---
