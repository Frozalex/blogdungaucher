            "blog.noResults": "No articles match your search on this page.",
            "blog.prev": "Previous",
            "blog.next": "Next",
            "category.featured": "Featured",
            "category.allArticles": "All articles",
            "category.seeAll": "See all posts",
            "category.comingSoon": "First articles coming soon.",
            "category.comingSoonDesc": "This section will be published soon. In the meantime, find all available articles.",
            "category.seeAllCta": "See all articles",
            "card.read": "Read",
            "categories.science.label": "Science",
            "categories.science.shortLabel": "Game science",
            "categories.esprit.label": "Mind",
            "categories.esprit.shortLabel": "Competitive mindset",
            "categories.societe.label": "Society",
            "categories.societe.shortLabel": "Chess and society",
            "categories.grand-oral.label": "Grand oral",
            "categories.grand-oral.shortLabel": "Baccalaureate",
            "categories.grand-oral.tagline":
              "Prepare the exam: outlines, Maths and CS around chess.",
            "categories.analyses.label": "Analyses",
            "categories.analyses.shortLabel": "Stockfish Analysis",
            "navLinks.science": "Science",
            "navLinks.esprit": "Mind",
            "navLinks.societe": "Society",
            "navLinks.grandOral": "Grand oral",
            "navLinks.blog": "Articles",
            "navLinks.about": "About"
          }
        };

        window.__i18n = T;

        function applyLang(lang) {
          // Update <html lang> attribute
          document.documentElement.lang = lang === "en" ? "en" : "fr";
          var dict = T[lang] || T.fr;
          // Texte simple
          document.querySelectorAll("[data-t]").forEach(function(el) {
            var key = el.getAttribute("data-t");
            if (dict[key] !== undefined) el.textContent = dict[key];
          });
          // HTML (pour les titres avec balises)
          document.querySelectorAll("[data-t-html]").forEach(function(el) {
            var key = el.getAttribute("data-t-html");
            if (dict[key] !== undefined) el.innerHTML = dict[key];
          });
          // Attribut placeholder
          document.querySelectorAll("[data-t-placeholder]").forEach(function(el) {
            var key = el.getAttribute("data-t-placeholder");
            if (dict[key] !== undefined) el.setAttribute("placeholder", dict[key]);
          });
          // Dates bilingues
          document.querySelectorAll("time[datetime]").forEach(function(el) {
            var iso = el.getAttribute("datetime");
            if (!iso) return;
            try {
              el.textContent = new Intl.DateTimeFormat(
                lang === "en" ? "en-GB" : "fr-FR",
                { day: "numeric", month: "long", year: "numeric", timeZone: "UTC" }
              ).format(new Date(iso));
            } catch(e) {}
          });
          // Attribut aria-label du burger / toggles
          document.querySelectorAll("[data-t-aria]").forEach(function(el) {
            var key = el.getAttribute("data-t-aria");
            if (dict[key] !== undefined) el.setAttribute("aria-label", dict[key]);
          });
        }

        window.__applyLang = applyLang;

        // On EN server-rendered pages, always use "en" regardless of localStorage
        var serverLang = document.documentElement.dataset.serverLang || "fr";
        var storedLang = serverLang === "en" ? "en" : (localStorage.getItem("blogdungaucher.lang") || "fr");
        window.__lang = storedLang;
        if (storedLang === "en") applyLang("en");
      })();
    </script>
    <meta name="google-adsense-account" content="ca-pub-1244325018333025" />
    {tags && tags.length > 0 && <meta name="keywords" content={tags.join(", ")} />}
    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    )}

    <title>{title}</title>
    <ClientRouter />
    <link rel="canonical" href={canonicalUrl} />
    {omitEnDeAlternateLinks ? (
      <>
        <link rel="alternate" hrefLang="fr" href={frCanonicalUrl} />
        <link rel="alternate" hrefLang="x-default" href={frCanonicalUrl} />
      </>
    ) : (
      <>
        <link rel="alternate" hrefLang="fr" href={frCanonicalUrl} />
        <link rel="alternate" hrefLang="en" href={enCanonicalUrl} />
        <link rel="alternate" hrefLang="de" href={deCanonicalUrl} />
        <link rel="alternate" hrefLang="x-default" href={frCanonicalUrl} />
      </>
    )}
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.name} RSS`} href={`${siteConfig.siteUrl}/rss.xml`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:secure_url" content={socialImage} />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content={lang === "en" ? "en_US" : lang === "de" ? "de_DE" : "fr_FR"} />
    {type === "article" && publishDate && (
      <meta property="article:published_time" content={publishDate.toISOString()} />
    )}
    {type === "article" && modifiedDate && (
      <meta property="article:modified_time" content={modifiedDate.toISOString()} />
    )}
    {type === "article" && section && <meta property="article:section" content={section} />}
    {type === "article" &&
      tags?.map((tag) => <meta property="article:tag" content={tag} />)}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:url" content={canonicalUrl} />

    {allStructuredDataItems.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}

    <script is:inline define:vars={{ oneSignalAppId }}>
      globalThis.__PUBLIC_ONESIGNAL_APP_ID__ = oneSignalAppId;
    </script>

    <script is:inline>
      (() => {
        const CONSENT_KEY = "blogdungaucher.cookieConsent.v1";
        const GA_MEASUREMENT_ID = "G-D31YHTHQT5";
        const ADS_CLIENT = "ca-pub-1244325018333025";

        const state = {
          analyticsLoaded: false,
          adsLoaded: false,
          onesignalLoaded: false,
        };

        function readConsent() {
          try {
            const raw = localStorage.getItem(CONSENT_KEY);
            if (!raw) return null;
            const p = JSON.parse(raw);
            if (p && typeof p === "object" && !("notifications" in p)) {
              return {
                ...p,
                notifications: Boolean(p.marketing),
              };
            }
            return p;
          } catch {
            return null;
          }
        }

        function loadScript(src, attrs = {}) {
          if (document.querySelector(`script[src="${src}"]`)) return;
          const script = document.createElement("script");
          script.src = src;
          script.async = true;
          Object.entries(attrs).forEach(([key, value]) => {
            script.setAttribute(key, value);
          });
          document.head.appendChild(script);
        }

        function enableAnalytics() {
          if (state.analyticsLoaded) return;
          state.analyticsLoaded = true;
          window.dataLayer = window.dataLayer || [];
          window.gtag = function gtag() {
            window.dataLayer.push(arguments);
          };
          loadScript(`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`);
          window.gtag("js", new Date());
          window.gtag("config", GA_MEASUREMENT_ID);
        }

        function enableAds() {
          if (state.adsLoaded) return;
          state.adsLoaded = true;
          loadScript(
            `https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADS_CLIENT}`,
            { crossorigin: "anonymous" },
          );
        }

        /** OneSignal : opt-in via la case « notifications » du bandeau cookies. App ID : PUBLIC_ONESIGNAL_APP_ID au build. */
        function enableOneSignal() {
          if (state.onesignalLoaded) return;
          const appId =
            typeof globalThis.__PUBLIC_ONESIGNAL_APP_ID__ === "string"
              ? globalThis.__PUBLIC_ONESIGNAL_APP_ID__.trim()
              : "";
          if (!appId) return;
          state.onesignalLoaded = true;
          window.OneSignalDeferred = window.OneSignalDeferred || [];
          window.OneSignalDeferred.push(async function (OneSignal) {
            await OneSignal.init({
              appId,
              safari_web_id: "web.onesignal.auto.29ad6177-53c3-46b5-8017-0e7b95131b37",
              notifyButton: { enable: true },
              serviceWorkerPath: "onesignal/OneSignalSDKWorker.js",
              serviceWorkerParam: { scope: "/onesignal/" },
            });
          });
          const os = document.createElement("script");
          os.src = "https://cdn.onesignal.com/sdks/web/v16/OneSignalSDK.page.js";
          os.defer = true;
          document.head.appendChild(os);
        }

        function applyConsent(consent) {
          if (!consent) return;
          if (consent.analytics) enableAnalytics();
          if (consent.marketing) enableAds();
          if (consent.notifications) enableOneSignal();
        }

        function bootConsentScripts() {
          applyConsent(readConsent());
        }

        document.addEventListener("astro:page-load", bootConsentScripts);
        document.addEventListener("cookie:updated", (event) => {
          applyConsent(event.detail);
        });
      })();
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" crossorigin="anonymous" />
  </head>
  <!-- Service worker + réapplication des préférences après chaque View Transition -->
  <body style={accentColor ? `--page-accent:${accentColor}` : ""}>
    <a class="skip-link" href="#main-content">Aller au contenu</a>
    <Navbar frHref={resolvedFrPath} enHref={resolvedEnPath} deHref={resolvedDePath} lang={lang} />
    <main id="main-content">
      <slot />
    </main>
    <Footer lang={lang} />
    <CookieConsent />
    <BackToTop />

    <!-- ── Service Worker + réapplication préférences après View Transitions ── -->
    <script>
      // Enregistrement du service worker (PWA)
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker.register("/sw.js").catch(() => {});
      }

      // Réappliquer dark mode + langue après chaque transition de page Astro
      function reapplyPreferences() {
        const theme = localStorage.getItem("blogdungaucher.theme") ||
          (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
        document.documentElement.dataset.theme = theme;

        const serverLang2 = document.documentElement.dataset.serverLang || "fr";
        const lang =
          serverLang2 === "en" || serverLang2 === "de"
            ? serverLang2
            : (localStorage.getItem("blogdungaucher.lang") || "fr");
        window.__lang = lang;
        if (typeof window.__applyLang === "function") window.__applyLang(lang);

        // Synchroniser le bouton dark mode
        const btn = document.getElementById("dark-toggle");
        if (btn) {
          const isDark = theme === "dark";
          btn.setAttribute("aria-pressed", String(isDark));
          btn.setAttribute("aria-label", isDark
            ? (window.__i18n?.[lang]?.["nav.darkOff"] || "Disable dark mode")
            : (window.__i18n?.[lang]?.["nav.darkOn"] || "Enable dark mode")
          );
        }

        // Synchroniser le bouton langue (affiche FR / EN)
        const desktopLangSpan = document.querySelector("#lang-toggle .lang-label");
        const mobileLangSpan  = document.querySelector("#lang-toggle-mobile .lang-label-mobile");
        if (desktopLangSpan) desktopLangSpan.textContent = lang.toUpperCase();
        if (mobileLangSpan)  mobileLangSpan.textContent  = lang.toUpperCase();
      }

      document.addEventListener("astro:page-load", reapplyPreferences);
    </script>

    <!-- ── Scroll reveal - re-déclenché à chaque transition de page ── -->
    <script>
      function initReveal() {
        const revealObs = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                revealObs.unobserve(e.target);
              }
            });
          },
          { threshold: 0.08 }
        );
        document.querySelectorAll(".reveal:not(.is-visible)").forEach((el) =>
          revealObs.observe(el)
        );

        const groupObs = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                groupObs.unobserve(e.target);
              }
            });
          },
          { threshold: 0.06 }
        );
        document.querySelectorAll(".reveal-group:not(.is-visible)").forEach((el) =>
          groupObs.observe(el)
        );
      }

      // premier chargement + chaque transition Astro
      document.addEventListener("astro:page-load", initReveal);
    </script>

  </body>
</html>
