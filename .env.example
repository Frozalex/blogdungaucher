# ── Variables locales pour `npm run build` / dev Astro ──────────────────────
# Copier vers `.env` si besoin (le fichier `.env` est ignoré par git).
# Les secrets CI/CD ne vont PAS ici : GitHub → Settings → Secrets → Actions.

# OneSignal (côté navigateur uniquement, ID public)
# https://documentation.onesignal.com/docs/web-push-setup
PUBLIC_ONESIGNAL_APP_ID=
# Safari Web Push (optionnel ; laisser vide si non utilisé)
# Ex. ancienne valeur du projet : web.onesignal.auto.29ad6177-53c3-46b5-8017-0e7b95131b37
PUBLIC_ONESIGNAL_SAFARI_WEB_ID=

# Google AdSense : slots d’unités publicitaires (optionnel si renseignés dans src/data/site.ts)
PUBLIC_ADSENSE_SLOT=
PUBLIC_ADSENSE_SLOT_LEADERBOARD=
PUBLIC_ADSENSE_SLOT_ARTICLE=
PUBLIC_ADSENSE_SLOT_SIDEBAR=

# ── Secrets réservés à GitHub Actions (ne pas mettre dans .env versionné) ──
# DEPLOY_HOST          : hôte SSH du VPS
# DEPLOY_USER          : utilisateur SSH de déploiement
# DEPLOY_SSH_KEY       : clé privée PEM (multi-ligne)
# ONESIGNAL_APP_ID     : même App ID (notification serveur post-déploiement)
# ONESIGNAL_API_KEYS   : clé API REST OneSignal (Authorization: Key …)
